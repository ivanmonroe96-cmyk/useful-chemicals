---
import { languages, defaultLang, getLocalizedPath } from '../i18n/languages';
import { getTranslations, t, localizedPath } from '../i18n/index';
import { getMerchantReturnPolicy } from '../lib/merchantStructuredData';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import ScrollTop from '../components/ScrollTop.astro';
import mainScriptUrl from '../scripts/main.js?url';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  activePage?: string;
  ogImage?: string;
  canonicalPath?: string;
  jsonLd?: object | object[];
  lang?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  keywords,
  activePage = '',
  ogImage = '/images/caluanie-muelear-oxidize-manufacturer-in-usa.webp',
  canonicalPath,
  jsonLd,
  lang = defaultLang,
  noindex = false,
} = Astro.props;

const tr = getTranslations(lang);
const siteUrl = 'https://useful-chemicals.com';
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;

function normalizeWhitespace(value: string): string {
  return value.replace(/\s+/g, ' ').trim();
}

function truncateAtWord(value: string, maxLength: number): string {
  if (value.length <= maxLength) return value;
  if (maxLength <= 3) return value.slice(0, maxLength);

  const sliced = value.slice(0, maxLength - 3);
  const boundary = sliced.lastIndexOf(' ');
  const trimmed = (boundary > Math.floor(maxLength * 0.6) ? sliced.slice(0, boundary) : sliced).trim();
  return `${trimmed}...`;
}

function normalizePathForSeo(path: string, locale: string): string {
  if (!path) return '/';
  const [pathWithoutHash] = path.split('#');
  const [pathname] = pathWithoutHash.split('?');
  return getLocalizedPath(pathname || '/', locale);
}

const pagePath = normalizePathForSeo(canonicalPath || Astro.url.pathname, lang);
const canonical = `${siteUrl}${pagePath}`;
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
const normalizedTitle = normalizeWhitespace(title);
const minTitleLength = 30;
const maxTitleLength = 60;
const brandSuffix = ' | UE Chemicals';
const locationSuffix = ' | Bangkok, Thailand';
const titleHasBrand = /\bue\b/i.test(normalizedTitle);
const safeTitleCore = truncateAtWord(
  normalizedTitle,
  titleHasBrand ? maxTitleLength : Math.max(20, maxTitleLength - brandSuffix.length),
);
let fullTitle = titleHasBrand ? safeTitleCore : `${safeTitleCore}${brandSuffix}`;
if (fullTitle.length < minTitleLength && !/bangkok|thailand/i.test(fullTitle)) {
  fullTitle = truncateAtWord(`${fullTitle}${locationSuffix}`, maxTitleLength);
}

const defaultDescription = normalizeWhitespace(t(tr, 'site.default_description'));
const organizationDescription = normalizeWhitespace(t(tr, 'site.organization_description'));
const websiteDescription = normalizeWhitespace(t(tr, 'site.website_description'));
const siteMetaKeywords = normalizeWhitespace(t(tr, 'site.meta_keywords'));
const metaKeywords = normalizeWhitespace(keywords || siteMetaKeywords);
const selectedDescription = normalizeWhitespace(description || defaultDescription);
const maxDescriptionLength = 160;
const minDescriptionLength = 120;
let metaDescription = selectedDescription;
const descriptionFallbacks = [defaultDescription, organizationDescription, websiteDescription];
for (const fallbackDescription of descriptionFallbacks) {
  if (metaDescription.length >= minDescriptionLength) break;
  if (fallbackDescription && fallbackDescription !== metaDescription && !metaDescription.includes(fallbackDescription)) {
    metaDescription = normalizeWhitespace(`${metaDescription} ${fallbackDescription}`);
  }
}
metaDescription = truncateAtWord(metaDescription, maxDescriptionLength);
const ogLocales: Record<string, string> = {
  en: 'en_US',
  de: 'de_DE',
  fr: 'fr_FR',
  es: 'es_ES',
  it: 'it_IT',
  pt: 'pt_BR',
  ru: 'ru_RU',
  zh: 'zh_CN',
  ko: 'ko_KR',
  ar: 'ar_SA',
  tr: 'tr_TR',
  pl: 'pl_PL',
  nl: 'nl_NL',
  bn: 'bn_BD',
  cs: 'cs_CZ',
  fa: 'fa_IR',
  id: 'id_ID',
  ro: 'ro_RO',
  vi: 'vi_VN',
};

const businessGeo = { region: 'TH-10', placename: 'Bangkok', lat: '13.7563', lng: '100.5018' };
const uiLabels = {
  formSending: t(tr, 'ui.form_sending'),
  formSent: t(tr, 'ui.form_sent'),
  formError: t(tr, 'ui.form_error'),
};

const cleanPath = getLocalizedPath(pagePath, defaultLang);
const returnPolicyUrl = `${siteUrl}${localizedPath('/returns-policy', lang)}`;

const langDir = languages.find(l => l.code === lang)?.dir || 'ltr';

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "UE Chemicals",
  "url": siteUrl,
  "logo": `${siteUrl}/images/favicon.png`,
  "image": `${siteUrl}/images/ue-chemicals.png`,
  "description": t(tr, 'site.organization_description'),
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Bangkok",
    "addressLocality": "Bangkok",
    "addressRegion": "Bangkok",
    "postalCode": "10110",
    "addressCountry": "TH"
  },
  "contactPoint": [
    {
      "@type": "ContactPoint",
      "contactType": "sales",
      "email": "info@useful-chemicals.com",
      "availableLanguage": languages.map(l => l.name)
    }
  ],
  "hasMerchantReturnPolicy": getMerchantReturnPolicy(returnPolicyUrl),
  "sameAs": [
    "https://www.facebook.com/uechemicals",
    "https://www.linkedin.com/company/ue-chemicals",
    "https://twitter.com/uechemicals"
  ],
  "foundingLocation": {
    "@type": "Place",
    "name": "Bangkok, Thailand"
  },
  "areaServed": [
    { "@type": "Country", "name": "United States" },
    { "@type": "Country", "name": "Germany" },
    { "@type": "Country", "name": "United Kingdom" },
    { "@type": "Country", "name": "France" },
    { "@type": "Country", "name": "Spain" },
    { "@type": "Country", "name": "Italy" },
    { "@type": "Country", "name": "Netherlands" },
    { "@type": "Country", "name": "Poland" },
    { "@type": "Country", "name": "Czech Republic" },
    { "@type": "Country", "name": "Romania" },
    { "@type": "Country", "name": "Russia" },
    { "@type": "Country", "name": "Turkey" },
    { "@type": "Country", "name": "Saudi Arabia" },
    { "@type": "Country", "name": "United Arab Emirates" },
    { "@type": "Country", "name": "Iran" },
    { "@type": "Country", "name": "China" },
    { "@type": "Country", "name": "South Korea" },
    { "@type": "Country", "name": "Indonesia" },
    { "@type": "Country", "name": "Vietnam" },
    { "@type": "Country", "name": "Bangladesh" },
    { "@type": "Country", "name": "Brazil" },
    { "@type": "Country", "name": "Thailand" }
  ],
  "knowsAbout": [
    "Caluanie Muelear Oxidize",
    "Red Liquid Mercury",
    "Silver Liquid Mercury",
    "Industrial Chemical Supply",
    "Chemical Export",
    "Hazardous Materials Shipping"
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Industrial Chemicals",
    "itemListElement": [
      {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock",
        "itemOffered": {
          "@type": "Product",
          "name": "Caluanie Muelear Oxidize",
          "sku": "UEC-CMO-HQ",
          "image": `${siteUrl}/images/home-caluanie-product.jpeg`
        }
      },
      {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock",
        "itemOffered": {
          "@type": "Product",
          "name": "Red Mercury 20/20-258",
          "sku": "UEC-RM-2020-258",
          "image": `${siteUrl}/images/home-red-mercury-product.jpeg`
        }
      },
      {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock",
        "itemOffered": {
          "@type": "Product",
          "name": "Silver Liquid Mercury",
          "sku": "UEC-SLM-Hg-995",
          "image": `${siteUrl}/images/home-silver-mercury-product.jpeg`
        }
      }
    ]
  }
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "UE Chemicals",
  "url": siteUrl,
  "description": t(tr, 'site.website_description'),
  "inLanguage": lang,
  "publisher": {
    "@type": "Organization",
    "name": "UE Chemicals"
  },
  "potentialAction": [
    {
      "@type": "SearchAction",
      "target": `${siteUrl}${localizedPath('/', lang)}?s={search_term_string}`,
      "query-input": "required name=search_term_string"
    }
  ],
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["h1", ".art-hero-sub", ".page-hero p", "meta[name='description']"]
  }
};

// Default BreadcrumbList based on URL path
const pathSegments = pagePath.replace(/^\/|\/$/g, '').split('/').filter(Boolean);
const langPrefix = languages.some(l => l.code === pathSegments[0] && l.code !== defaultLang);
const breadcrumbSegments = langPrefix ? pathSegments.slice(1) : pathSegments;
const breadcrumbItems: { "@type": string; position: number; name: string; item: string }[] = [
  { "@type": "ListItem", position: 1, name: t(tr, 'nav.home'), item: `${siteUrl}${localizedPath('/', lang)}` }
];
let cumulativePath = '';
breadcrumbSegments.forEach((segment, i) => {
  cumulativePath += `/${segment}`;
  const segmentName = segment.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
  breadcrumbItems.push({
    "@type": "ListItem",
    position: i + 2,
    name: segmentName,
    item: `${siteUrl}${localizedPath(cumulativePath, lang)}`
  });
});
const breadcrumbSchema = breadcrumbSegments.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems
} : null;

const baseSchemas = [orgSchema, websiteSchema, ...(breadcrumbSchema ? [breadcrumbSchema] : [])];
const allSchemas = jsonLd
  ? Array.isArray(jsonLd) ? [...baseSchemas, ...jsonLd] : [...baseSchemas, jsonLd]
  : baseSchemas;

---

<!DOCTYPE html>
<html lang={lang} dir={langDir}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={metaDescription} />
  {metaKeywords && <meta name="keywords" content={metaKeywords} />}
  {metaKeywords && <meta name="news_keywords" content={metaKeywords} />}
  {googleSiteVerification && <meta name="google-site-verification" content={googleSiteVerification} />}
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={metaDescription} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={fullOgImage} />
  <meta property="og:site_name" content="UE Chemicals" />
  <meta property="og:locale" content={ogLocales[lang] || 'en_US'} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={metaDescription} />
  <meta name="twitter:image" content={fullOgImage} />

  <!-- Geo Tags -->
  <meta name="geo.region" content={businessGeo.region} />
  <meta name="geo.placename" content={businessGeo.placename} />
  <meta name="geo.position" content={`${businessGeo.lat};${businessGeo.lng}`} />
  <meta name="ICBM" content={`${businessGeo.lat}, ${businessGeo.lng}`} />
  <meta http-equiv="content-language" content={lang} />

  <!-- Hreflang -->
  <link rel="alternate" hreflang="x-default" href={`${siteUrl}${cleanPath}`} />
  {languages.map(l => (
    <link rel="alternate" hreflang={l.code} href={`${siteUrl}${getLocalizedPath(cleanPath, l.code)}`} />
  ))}

  <!-- OG locale alternates -->
  {languages.filter(l => l.code !== lang).map(l => (
    <meta property="og:locale:alternate" content={ogLocales[l.code] || `${l.code}_${l.flag.toUpperCase()}`} />
  ))}

  <link rel="icon" type="image/webp" href="/images/favicon.png" />
  <link rel="apple-touch-icon" href="/images/apple-touch-icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

  <!-- Structured Data -->
  {allSchemas.map(schema => (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}
</head>
<body data-ui-labels={JSON.stringify(uiLabels)}>
  <Header activePage={activePage} lang={lang} />
  <main>
    <slot />
  </main>
  <Footer lang={lang} />
  <CookieBanner lang={lang} />
  <ScrollTop lang={lang} />

  <script is:inline type="module" src={mainScriptUrl}></script>
</body>
</html>
