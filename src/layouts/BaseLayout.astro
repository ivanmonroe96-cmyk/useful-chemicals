---
import { languages, defaultLang } from '../i18n/languages';
import { getTranslations, t, localizedPath } from '../i18n/index';

interface Props {
  title: string;
  description?: string;
  activePage?: string;
  ogImage?: string;
  canonicalPath?: string;
  jsonLd?: object | object[];
  lang?: string;
}

const {
  title,
  description,
  activePage = '',
  ogImage = '/images/caluanie-muelear-oxidize-manufacturer-in-usa.webp',
  canonicalPath,
  jsonLd,
  lang = defaultLang,
} = Astro.props;

const tr = getTranslations(lang);
const siteUrl = 'https://useful-chemicals.com';
const pagePath = canonicalPath || Astro.url.pathname;
const canonical = `${siteUrl}${pagePath}`;
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
const fullTitle = `${title} | UE Chemicals`;
const metaDescription = description || t(tr, 'site.default_description');
const currentLanguage = languages.find(language => language.code === lang);
const ogLocales: Record<string, string> = {
  en: 'en_US',
  de: 'de_DE',
  fr: 'fr_FR',
  es: 'es_ES',
  it: 'it_IT',
  pt: 'pt_PT',
  ru: 'ru_RU',
  zh: 'zh_CN',
  ja: 'ja_JP',
  ko: 'ko_KR',
  ar: 'ar_SA',
  hi: 'hi_IN',
  tr: 'tr_TR',
  pl: 'pl_PL',
  nl: 'nl_NL',
  el: 'el_GR',
  he: 'he_IL',
  th: 'th_TH',
  uk: 'uk_UA',
};
const uiLabels = {
  formSending: t(tr, 'ui.form_sending'),
  formSent: t(tr, 'ui.form_sent'),
  formError: t(tr, 'ui.form_error'),
};

// Determine the "clean" path (without lang prefix) for hreflang generation
const cleanPath = pagePath.replace(new RegExp(`^/(${languages.filter(l => l.code !== defaultLang).map(l => l.code).join('|')})/`), '/').replace(new RegExp(`^/(${languages.filter(l => l.code !== defaultLang).map(l => l.code).join('|')})$`), '/');

const langDir = languages.find(l => l.code === lang)?.dir || 'ltr';

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "UE Chemicals",
  "url": siteUrl,
  "logo": `${siteUrl}/images/favicon.png`,
  "description": t(tr, 'site.organization_description'),
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Bangkok",
    "addressLocality": "Bangkok",
    "postalCode": "10110",
    "addressCountry": "TH"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "sales",
    "email": "info@useful-chemicals.com",
    "availableLanguage": currentLanguage?.name || 'English'
  },
  "sameAs": []
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "UE Chemicals",
  "url": siteUrl,
  "description": t(tr, 'site.website_description'),
  "potentialAction": {
    "@type": "SearchAction",
    "target": `${siteUrl}${localizedPath('/', lang)}?s={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};

const allSchemas = jsonLd
  ? Array.isArray(jsonLd) ? [orgSchema, websiteSchema, ...jsonLd] : [orgSchema, websiteSchema, jsonLd]
  : [orgSchema, websiteSchema];

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import ScrollTop from '../components/ScrollTop.astro';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang={lang} dir={langDir}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={metaDescription} />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={metaDescription} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={fullOgImage} />
  <meta property="og:site_name" content="UE Chemicals" />
  <meta property="og:locale" content={ogLocales[lang] || 'en_US'} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={metaDescription} />
  <meta name="twitter:image" content={fullOgImage} />

  <!-- Geo Tags -->
  <meta name="geo.region" content="TH-10" />
  <meta name="geo.placename" content="Bangkok" />
  <meta name="geo.position" content="13.7563;100.5018" />
  <meta name="ICBM" content="13.7563, 100.5018" />

  <!-- Hreflang -->
  <link rel="alternate" hreflang="x-default" href={`${siteUrl}${cleanPath}`} />
  {languages.map(l => (
    <link rel="alternate" hreflang={l.code} href={`${siteUrl}${l.code === defaultLang ? cleanPath : `/${l.code}${cleanPath === '/' ? '' : cleanPath}`}`} />
  ))}

  <link rel="icon" type="image/webp" href="/images/favicon.png" />
  <link rel="apple-touch-icon" href="/images/apple-touch-icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

  <!-- Structured Data -->
  {allSchemas.map(schema => (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}
</head>
<body data-ui-labels={JSON.stringify(uiLabels)}>
  <Header activePage={activePage} lang={lang} />
  <main>
    <slot />
  </main>
  <Footer lang={lang} />
  <CookieBanner lang={lang} />
  <ScrollTop lang={lang} />

  <!-- WhatsApp Floating Button -->
  <a href="https://wa.me/66951690848" class="whatsapp-float" target="_blank" rel="noopener noreferrer" aria-label={t(tr, 'site.whatsapp_label')}>
    <i class="fab fa-whatsapp"></i>
  </a>

  <script src="../scripts/main.js"></script>
</body>
</html>
