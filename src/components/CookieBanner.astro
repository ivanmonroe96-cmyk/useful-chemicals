---
import { getTranslations, t } from '../i18n/index';
import { defaultLang } from '../i18n/languages';

interface Props {
  lang?: string;
}
const { lang = defaultLang } = Astro.props;
const tr = getTranslations(lang);
---

<div class="cookie-banner" id="cookieBanner">
  <div class="cookie-content">
    <p>{t(tr, 'cookie.message')}</p>
    <div class="cookie-buttons">
      <button class="btn btn-accent" id="acceptCookies">{t(tr, 'cookie.accept')}</button>
      <button class="btn btn-outline" id="declineCookies">{t(tr, 'cookie.decline')}</button>
    </div>
  </div>
</div>
