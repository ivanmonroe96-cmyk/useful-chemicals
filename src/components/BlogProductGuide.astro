---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTranslations, t, localizedPath } from '../i18n/index';
import { defaultLang } from '../i18n/languages';

interface Props {
  lang?: string;
  namespace: 'red_mercury' | 'silver_mercury';
  productNavKey: 'nav.red_mercury' | 'nav.silver_mercury';
  image: string;
  slug: string;
}

const { lang = defaultLang, namespace, productNavKey, image, slug } = Astro.props;
const tr = getTranslations(lang);
const lp = (path: string) => localizedPath(path, lang);
const key = (name: string) => `${namespace}.${name}`;

const productName = t(tr, productNavKey);
const title = t(tr, key('meta_title'));
const description = t(tr, key('meta_desc'));
const articleUrl = `https://useful-chemicals.com${lp(slug)}`;
const articleDate = new Intl.DateTimeFormat(lang, { month: 'long', year: 'numeric' }).format(new Date(Date.UTC(2026, 3, 1)));

const specKeys = [
  'tech_name',
  'tech_formula',
  'tech_cas',
  'tech_appearance',
  'tech_density',
  'tech_purity',
  'tech_hazard',
  'tech_un',
  'tech_packing',
];

const applications = [1, 2, 3].map((item) => ({
  title: t(tr, key(`app${item}_title`)),
  body: t(tr, key(`app${item}_desc`)),
}));

const safetyItems = [1, 2, 3, 4].map((item) => t(tr, key(`safety${item}`)));

const docs = namespace === 'red_mercury'
  ? [
      ['doc_tds_title', 'doc_tds_desc'],
      ['doc_sds_title', 'doc_sds_desc'],
      ['doc_coa_title', 'doc_coa_desc'],
    ]
  : [
      ['doc_sds_title', 'doc_sds_desc'],
      ['doc_coa_title', 'doc_coa_desc'],
    ];

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: { '@type': 'Organization', name: 'UE Chemicals', url: 'https://useful-chemicals.com' },
  publisher: { '@type': 'Organization', name: 'UE Chemicals' },
  datePublished: '2026-04-26',
  dateModified: '2026-04-26',
  image: `https://useful-chemicals.com${image}`,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t(tr, 'nav.home'), item: `https://useful-chemicals.com${lp('/')}` },
    { '@type': 'ListItem', position: 2, name: t(tr, 'nav.blog'), item: `https://useful-chemicals.com${lp('/blog')}` },
    { '@type': 'ListItem', position: 3, name: productName, item: articleUrl },
  ],
};
---

<BaseLayout lang={lang} title={title} description={description} activePage="blog" ogImage={image} jsonLd={[articleSchema, breadcrumbSchema]}>
  <section class="guide-hero">
    <div class="guide-hero-media">
      <img src={image} alt={title} />
      <div class="guide-hero-shade"></div>
    </div>
    <div class="container guide-hero-inner">
      <a class="guide-back" href={lp('/blog')}><i class="fas fa-arrow-left"></i> {t(tr, 'nav.blog')}</a>
      <span class="guide-badge">{t(tr, 'blog.cat_products')}</span>
      <h1>{t(tr, key('hero_title'))}</h1>
      <p>{t(tr, key('hero_sub'))}</p>
      <div class="guide-meta">
        <span><i class="fas fa-calendar"></i> {articleDate}</span>
        <span><i class="fas fa-flask"></i> {productName}</span>
      </div>
    </div>
  </section>

  <article class="guide-body">
    <div class="container guide-container">
      <section class="guide-section guide-intro">
        <h2>{t(tr, key('overview_title'))}</h2>
        <p>{t(tr, key('overview_desc1'))}</p>
        <p>{t(tr, key('overview_desc2'))}</p>
      </section>

      <section class="guide-section">
        <h2>{t(tr, key('tech_title'))}</h2>
        <p>{t(tr, key('tech_desc'))}</p>
        <div class="guide-table-wrap">
          <table class="guide-table">
            <tbody>
              {specKeys.map((specKey) => (
                <tr>
                  <th scope="row">{t(tr, key(specKey))}</th>
                  <td>{t(tr, key(`${specKey}_val`))}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="guide-section">
        <h2>{t(tr, key('docs_label'))}</h2>
        <div class="guide-card-grid">
          {docs.map(([docTitle, docDesc]) => (
            <div class="guide-card">
              <h3>{t(tr, key(docTitle))}</h3>
              <p>{t(tr, key(docDesc))}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="guide-section">
        <h2>{t(tr, key('apps_title'))}</h2>
        <div class="guide-card-grid">
          {applications.map((item) => (
            <div class="guide-card">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="guide-section guide-safety">
        <h2>{t(tr, key('safety_title'))}</h2>
        <p>{t(tr, key('safety_desc'))}</p>
        <ul>
          {safetyItems.map((item) => <li>{item}</li>)}
        </ul>
      </section>

      <section class="guide-section guide-quote">
        <h2>{t(tr, key('quote_title'))}</h2>
        <p>{t(tr, key('quote_desc'))}</p>
        <div class="guide-actions">
          <a href={lp(namespace === 'red_mercury' ? '/products/red-mercury' : '/products/silver-mercury')} class="btn btn-outline">{t(tr, 'common.view_product')} <i class="fas fa-arrow-right"></i></a>
          <a href={lp('/contact')} class="btn btn-accent">{t(tr, 'common.get_quote')} <i class="fas fa-arrow-right"></i></a>
        </div>
      </section>
    </div>
  </article>
</BaseLayout>

<style>
  .guide-hero {
    position: relative;
    min-height: 68vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .guide-hero-media,
  .guide-hero-media img,
  .guide-hero-shade {
    position: absolute;
    inset: 0;
  }

  .guide-hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .guide-hero-shade {
    background: linear-gradient(135deg, rgba(12, 18, 28, 0.94), rgba(12, 18, 28, 0.68));
  }

  .guide-hero-inner {
    position: relative;
    z-index: 1;
    padding-top: 138px;
    padding-bottom: 72px;
    max-width: 920px;
  }

  .guide-back,
  .guide-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.86rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .guide-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
  }

  .guide-back:hover { color: #fff; }

  .guide-badge {
    display: inline-flex;
    margin-bottom: 20px;
    padding: 8px 14px;
    border: 1px solid rgba(255, 255, 255, 0.22);
    color: #fff;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .guide-hero h1 {
    max-width: 900px;
    margin-bottom: 18px;
    color: #fff;
    font-size: clamp(2rem, 4.6vw, 4rem);
    line-height: 1.06;
  }

  .guide-hero p {
    max-width: 760px;
    color: rgba(255, 255, 255, 0.76);
    font-size: 1.08rem;
    line-height: 1.75;
  }

  .guide-body { padding: 82px 0; }
  .guide-container { max-width: 940px; }
  .guide-section { margin-bottom: 58px; }
  .guide-section h2 { margin-bottom: 16px; font-size: clamp(1.7rem, 3vw, 2.6rem); line-height: 1.12; }
  .guide-section p { font-size: 1rem; line-height: 1.78; color: var(--body-text); }

  .guide-table-wrap { overflow-x: auto; border: 1px solid var(--border); }
  .guide-table { width: 100%; border-collapse: collapse; min-width: 620px; }
  .guide-table th,
  .guide-table td { padding: 15px 18px; border-bottom: 1px solid var(--border); text-align: left; vertical-align: top; }
  .guide-table th { width: 34%; background: var(--light-bg); font-size: 0.9rem; }
  .guide-table tr:last-child th,
  .guide-table tr:last-child td { border-bottom: 0; }

  .guide-card-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 18px; }
  .guide-card { padding: 24px; border: 1px solid var(--border); background: #fff; }
  .guide-card h3 { margin-bottom: 10px; font-size: 1rem; line-height: 1.35; }
  .guide-card p { margin: 0; font-size: 0.94rem; }

  .guide-safety ul { margin: 20px 0 0; padding-left: 1.25rem; }
  .guide-safety li { margin-bottom: 12px; line-height: 1.72; color: var(--body-text); }
  .guide-quote { padding-top: 36px; border-top: 2px solid var(--near-black); }
  .guide-actions { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 24px; }

  @media (max-width: 768px) {
    .guide-hero { min-height: 58vh; }
    .guide-hero-inner { padding-top: 108px; padding-bottom: 54px; }
    .guide-body { padding: 64px 0; }
    .guide-card-grid { grid-template-columns: 1fr; }
    .guide-table { min-width: 560px; }
    .guide-actions { flex-direction: column; }
    .guide-actions .btn { width: 100%; }
  }
</style>