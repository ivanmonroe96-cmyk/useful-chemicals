---
import { getTranslations, t } from '../i18n/index';
import { defaultLang } from '../i18n/languages';

interface Props {
  lang?: string;
}

const { lang = defaultLang } = Astro.props;
const tr = getTranslations(lang);
---

<button class="scroll-top" id="scrollTop" aria-label={t(tr, 'ui.scroll_to_top')}>
  <i class="fas fa-chevron-up"></i>
</button>
