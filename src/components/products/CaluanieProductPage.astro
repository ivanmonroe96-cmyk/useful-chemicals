---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getTranslations, t, localizedPath } from '../../i18n/index';
import { defaultLang } from '../../i18n/languages';
import { getDocumentDownload } from '../../lib/documentDownloads';
import { getQuoteBasedOffer } from '../../lib/merchantStructuredData';
import heroImage from '../../assets/products/caluanie/caluanie-muelear-oxidize-stock-warehouse.jpeg';
import galleryImage from '../../assets/products/caluanie/caluanie-muelear-oxidize-export-pallets.jpeg';
import facilityImage from '../../assets/products/caluanie/ue-chemicals-caluanie-storage-facility.png';

interface Props {
  lang?: string;
}

const { lang = defaultLang } = Astro.props;
const tr = getTranslations(lang);
const lp = (path: string) => localizedPath(path, lang);
const docDownload = (id: string) => {
  const download = getDocumentDownload(id, lang);
  if (!download) throw new Error(`Missing document download: ${id}`);
  return download;
};

const siteUrl = 'https://useful-chemicals.com';
const productName = 'Caluanie Muelear Oxidize';
const pageTitle = t(tr, 'caluanie.meta_title');
const pageDescription = t(tr, 'caluanie.meta_desc');
const pageKeywords = t(tr, 'caluanie.meta_keywords');
const productPageUrl = `${siteUrl}${lp('/products/caluanie')}`;
const returnPolicyUrl = `${siteUrl}${lp('/returns-policy')}`;
const shippingPolicyUrl = `${siteUrl}${lp('/shipping')}`;
const imageUrls = [heroImage, galleryImage, facilityImage].map((image) => `${siteUrl}${image.src}`);

const anchorLinks = [
  { href: '#summary', label: t(tr, 'caluanie.overview_label') },
  { href: '#specifications', label: t(tr, 'caluanie.tech_label') },
  { href: '#documents', label: t(tr, 'caluanie.doc_tds_title') },
  { href: '#handling', label: t(tr, 'caluanie.safety_label') },
  { href: '#quote', label: t(tr, 'caluanie.quote_label') },
];

const heroChipItems = [
  t(tr, 'caluanie.hero_chip_tds'),
  t(tr, 'caluanie.hero_chip_sds'),
  t(tr, 'caluanie.hero_chip_coa'),
  t(tr, 'caluanie.hero_chip_use'),
];

const heroFacts = [
  { label: t(tr, 'caluanie.tech_packs'), value: t(tr, 'caluanie.tech_packs_val') },
  { label: t(tr, 'caluanie.tech_shelf'), value: t(tr, 'caluanie.tech_shelf_val') },
  { label: t(tr, 'caluanie.tech_origin'), value: t(tr, 'caluanie.tech_origin_val') },
  { label: t(tr, 'caluanie.doc_coa_title'), value: t(tr, 'caluanie.doc_coa_desc') },
];

const summaryCards = [
  {
    title: t(tr, 'caluanie.overview_feat1_title'),
    body: t(tr, 'caluanie.overview_feat1_desc'),
  },
  {
    title: t(tr, 'caluanie.overview_feat2_title'),
    body: t(tr, 'caluanie.overview_feat2_desc'),
  },
  {
    title: t(tr, 'caluanie.overview_feat3_title'),
    body: t(tr, 'caluanie.overview_feat3_desc'),
  },
  {
    title: t(tr, 'caluanie.tech_type'),
    body: t(tr, 'caluanie.tech_type_val'),
  },
];

const verifiedSpecs = [
  [t(tr, 'caluanie.tech_name'), t(tr, 'caluanie.tech_name_val')],
  [t(tr, 'caluanie.tech_type'), t(tr, 'caluanie.tech_type_val')],
  [t(tr, 'caluanie.tech_appearance'), t(tr, 'caluanie.tech_appearance_val')],
  [t(tr, 'caluanie.tech_application'), t(tr, 'caluanie.tech_application_val')],
  [t(tr, 'caluanie.tech_power'), t(tr, 'caluanie.tech_power_val')],
  [t(tr, 'caluanie.tech_density'), t(tr, 'caluanie.tech_density_val')],
  [t(tr, 'caluanie.tech_ph'), t(tr, 'caluanie.tech_ph_val')],
  [t(tr, 'caluanie.tech_solubility'), t(tr, 'caluanie.tech_solubility_val')],
  [t(tr, 'caluanie.tech_shelf'), t(tr, 'caluanie.tech_shelf_val')],
  [t(tr, 'caluanie.tech_packs'), t(tr, 'caluanie.tech_packs_val')],
  [t(tr, 'caluanie.tech_storage'), t(tr, 'caluanie.tech_storage_val')],
  [t(tr, 'caluanie.tech_origin'), t(tr, 'caluanie.tech_origin_val')],
];

const cautionItems = [
  t(tr, 'caluanie.tech_note1'),
  t(tr, 'caluanie.tech_note2'),
  t(tr, 'caluanie.tech_note3'),
  t(tr, 'caluanie.tech_note4'),
];

const documentCards = [
  {
    icon: 'fa-file-lines',
    title: t(tr, 'caluanie.doc_tds_title'),
    code: 'UEC-TDS-CMO-2026-01',
    kind: 'TDS',
    date: t(tr, 'caluanie.doc_tds_date'),
    summary: t(tr, 'caluanie.doc_tds_desc'),
    note: t(tr, 'caluanie.safety_desc'),
    download: docDownload('caluanie-tds'),
    cta: t(tr, 'caluanie.download_tds'),
    ariaLabel: t(tr, 'caluanie.doc_tds_aria'),
  },
  {
    icon: 'fa-shield-halved',
    title: t(tr, 'caluanie.doc_sds_title'),
    code: 'UEC-MSDS-CMO-2026-01',
    kind: 'SDS',
    date: t(tr, 'caluanie.doc_sds_date'),
    summary: t(tr, 'caluanie.doc_sds_desc'),
    note: t(tr, 'caluanie.safety4'),
    download: docDownload('caluanie-msds'),
    cta: t(tr, 'caluanie.download_sds'),
    ariaLabel: t(tr, 'caluanie.doc_sds_aria'),
  },
];

const applicationItems = [
  {
    title: t(tr, 'caluanie.app1_title'),
    body: t(tr, 'caluanie.app1_desc'),
  },
  {
    title: t(tr, 'caluanie.app2_title'),
    body: t(tr, 'caluanie.app2_desc'),
  },
  {
    title: t(tr, 'caluanie.app3_title'),
    body: t(tr, 'caluanie.app3_desc'),
  },
];

const handlingItems = [
  t(tr, 'caluanie.safety1'),
  t(tr, 'caluanie.safety2'),
  t(tr, 'caluanie.safety3'),
  t(tr, 'caluanie.safety4'),
  t(tr, 'caluanie.safety5'),
  t(tr, 'caluanie.safety6'),
];

const orderChecklist = [
  t(tr, 'caluanie.quote_check1'),
  t(tr, 'caluanie.quote_check2'),
  t(tr, 'caluanie.quote_check3'),
  t(tr, 'caluanie.quote_check4'),
];

const relatedLinks = [
  {
    href: lp('/products/red-mercury'),
    title: t(tr, 'nav.red_mercury'),
    description: t(tr, 'home.product2_desc'),
  },
  {
    href: lp('/products/silver-mercury'),
    title: t(tr, 'nav.silver_mercury'),
    description: t(tr, 'home.product3_desc'),
  },
  {
    href: lp('/applications'),
    title: t(tr, 'common.view_applications'),
    description: t(tr, 'caluanie.benefits_link1_desc'),
  },
  {
    href: lp('/certificates'),
    title: t(tr, 'common.request_documentation'),
    description: t(tr, 'caluanie.benefits_link3_desc'),
  },
  {
    href: lp('/ordering'),
    title: t(tr, 'common.how_to_order'),
    description: t(tr, 'caluanie.benefits_link4_desc'),
  },
  {
    href: lp('/contact'),
    title: t(tr, 'common.contact_us'),
    description: t(tr, 'caluanie.benefits_link6_desc'),
  },
];

const faqItems = [
  {
    question: t(tr, 'caluanie.faq1_q'),
    answer: t(tr, 'caluanie.faq1_a'),
  },
  {
    question: t(tr, 'caluanie.faq2_q'),
    answer: t(tr, 'caluanie.faq2_a'),
  },
  {
    question: t(tr, 'caluanie.faq3_q'),
    answer: t(tr, 'caluanie.faq3_a'),
  },
  {
    question: t(tr, 'caluanie.faq4_q'),
    answer: t(tr, 'caluanie.faq4_a'),
  },
  {
    question: t(tr, 'caluanie.faq5_q'),
    answer: t(tr, 'caluanie.faq5_a'),
  },
  {
    question: t(tr, 'caluanie.faq6_q'),
    answer: t(tr, 'caluanie.faq6_a'),
  },
];

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: productName,
  description: pageDescription,
  image: imageUrls,
  category: 'Industrial liquid oxidizer',
  sku: 'UEC-CMO-HQ',
  brand: { '@type': 'Brand', name: 'UE Chemicals' },
  manufacturer: {
    '@type': 'Organization',
    name: 'UE Chemicals',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Bangkok',
      postalCode: '10110',
      addressCountry: 'TH',
    },
  },
  countryOfOrigin: { '@type': 'Country', name: 'Thailand' },
  keywords: pageKeywords,
  offers: getQuoteBasedOffer(productPageUrl, returnPolicyUrl, shippingPolicyUrl),
  additionalProperty: verifiedSpecs.map(([label, value]) => ({
    '@type': 'PropertyValue',
    name: label,
    value,
  })),
  subjectOf: documentCards.map((card) => ({
    '@type': 'DigitalDocument',
    name: `${productName} ${card.title}`,
    encodingFormat: 'application/pdf',
    url: `${siteUrl}${card.download.directHref}`,
    inLanguage: card.download.language,
    datePublished: '2026-03-10',
  })),
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t(tr, 'nav.home'), item: `${siteUrl}${lp('/')}` },
    { '@type': 'ListItem', position: 2, name: t(tr, 'nav.products'), item: `${siteUrl}${lp('/products')}` },
    { '@type': 'ListItem', position: 3, name: productName, item: productPageUrl },
  ],
};

const speakableSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: pageTitle,
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['h1', '.calp-hero-lead', '.calp-summary-card p', '.calp-faq-question'],
  },
  url: productPageUrl,
};
---

<BaseLayout
  lang={lang}
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
  activePage="products"
  ogImage={heroImage.src}
  jsonLd={[productSchema, faqSchema, breadcrumbSchema, speakableSchema]}
>
  <section class="calp-hero" aria-labelledby="calp-hero-title">
    <div class="container calp-hero-grid">
      <div class="calp-hero-copy">
        <div class="calp-kicker">{t(tr, 'caluanie.hero_badge')}</div>
        <h1 id="calp-hero-title">{t(tr, 'caluanie.hero_title')}</h1>
        <p class="calp-hero-lead">{t(tr, 'caluanie.hero_sub')}</p>
        <div class="calp-chip-row" aria-label={t(tr, 'caluanie.hero_chip_row_label')}>
          {heroChipItems.map((item) => (
            <span>{item}</span>
          ))}
        </div>
        <div class="calp-hero-actions">
          <a href="#quote" class="btn btn-accent" aria-label={t(tr, 'common.get_quote')}>{t(tr, 'common.get_quote')} <i class="fas fa-arrow-right"></i></a>
        </div>
        <p class="calp-hero-note">{t(tr, 'caluanie.hero_note')}</p>
      </div>

      <div class="calp-hero-panel">
        <figure class="calp-figure calp-figure-primary">
          <Image
            src={heroImage}
            alt={t(tr, 'caluanie.hero_image_alt')}
            widths={[768, 1200, 1600]}
            sizes="(max-width: 1024px) 100vw, 48vw"
            quality={82}
            format="webp"
            loading="eager"
            fetchpriority="high"
            class="calp-image"
          />
          <figcaption>{t(tr, 'caluanie.hero_image_caption')}</figcaption>
        </figure>

        <dl class="calp-fact-list">
          {heroFacts.map((item) => (
            <div class="calp-fact-item">
              <dt>{item.label}</dt>
              <dd>{item.value}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>
  </section>

  <nav class="calp-anchor-nav" aria-label={t(tr, 'caluanie.anchor_nav_label')}>
    <div class="container calp-anchor-row">
      {anchorLinks.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </div>
  </nav>

  <section class="calp-summary" id="summary" aria-labelledby="calp-summary-title">
    <div class="container">
      <div class="calp-section-head">
        <div class="calp-kicker">{t(tr, 'caluanie.overview_label')}</div>
        <h2 id="calp-summary-title">{t(tr, 'caluanie.overview_title')}</h2>
        <p>{t(tr, 'caluanie.overview_desc1')}</p>
      </div>
      <div class="calp-summary-grid">
        {summaryCards.map((card) => (
          <article class="calp-summary-card">
            <h3>{card.title}</h3>
            <p>{card.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="calp-gallery" aria-labelledby="calp-gallery-title">
    <div class="container">
      <div class="calp-section-head calp-section-head-tight">
        <div class="calp-kicker">{t(tr, 'caluanie.overview_label')}</div>
        <h2 id="calp-gallery-title">{t(tr, 'caluanie.overview_title')}</h2>
        <p>{t(tr, 'caluanie.overview_desc2')}</p>
      </div>

      <div class="calp-gallery-grid">
        <figure class="calp-figure">
          <Image
            src={galleryImage}
            alt={t(tr, 'caluanie.gallery_image_alt')}
            widths={[640, 960, 1280]}
            sizes="(max-width: 1024px) 100vw, 50vw"
            quality={80}
            format="webp"
            loading="lazy"
            class="calp-image"
          />
          <figcaption>{t(tr, 'caluanie.gallery_image_caption')}</figcaption>
        </figure>

        <figure class="calp-figure">
          <Image
            src={facilityImage}
            alt={t(tr, 'caluanie.facility_image_alt')}
            widths={[640, 960, 1280]}
            sizes="(max-width: 1024px) 100vw, 50vw"
            quality={80}
            format="webp"
            loading="lazy"
            class="calp-image"
          />
          <figcaption>{t(tr, 'caluanie.facility_image_caption')}</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="calp-specs" id="specifications" aria-labelledby="calp-specs-title">
    <div class="container calp-specs-grid">
      <div class="calp-specs-copy">
        <div class="calp-kicker">{t(tr, 'caluanie.tech_label')}</div>
        <h2 id="calp-specs-title">{t(tr, 'caluanie.tech_title')}</h2>
        <p>{t(tr, 'caluanie.tech_desc')}</p>

        <div class="calp-note-card">
          <h3>{t(tr, 'caluanie.tech_note_title')}</h3>
          <ul>
            {cautionItems.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>

      <div class="calp-table-card">
        <table class="calp-spec-table">
          <caption class="calp-sr-only">{t(tr, 'caluanie.tech_table_caption')}</caption>
          <tbody>
            {verifiedSpecs.map(([label, value]) => (
              <tr>
                <th scope="row">{label}</th>
                <td>{value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="calp-docs" id="documents" aria-labelledby="calp-docs-title">
    <div class="container">
      <div class="calp-section-head">
        <div class="calp-kicker">{t(tr, 'caluanie.docs_label')}</div>
          <h2 id="calp-docs-title">{t(tr, 'caluanie.doc_tds_title')}</h2>
        <p>{t(tr, 'caluanie.doc_tds_desc')}</p>
      </div>

      <div class="calp-doc-grid">
        {documentCards.map((card) => (
          <article class="calp-doc-card">
            <div class="calp-doc-icon"><i class:list={['fas', card.icon]}></i></div>
            <div class="calp-doc-body">
              <div class="calp-doc-meta">{card.code}</div>
              <h3>{card.title}</h3>
              <p class="calp-doc-date">{card.date}</p>
              <p>{card.summary}</p>
              <p class="calp-doc-note">{card.note}</p>
            </div>
            <a href={card.download.directHref} download class="btn btn-outline doc-dl-btn" aria-label={card.ariaLabel} title={card.ariaLabel}>{card.kind}<svg class="doc-dl-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 3v12"/><path d="m7 10 5 5 5-5"/><path d="M5 21h14"/></svg></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="calp-columns" id="handling" aria-labelledby="calp-columns-title">
    <div class="container">
      <div class="calp-section-head calp-section-head-tight">
        <div class="calp-kicker">{t(tr, 'caluanie.safety_label')}</div>
        <h2 id="calp-columns-title">{t(tr, 'caluanie.safety_title')}</h2>
      </div>

      <div class="calp-columns-grid">
        <article class="calp-list-card">
          <h3>{t(tr, 'caluanie.apps_title')}</h3>
          <div class="calp-list-stack">
            {applicationItems.map((item) => (
              <div class="calp-list-item">
                <h4>{item.title}</h4>
                <p>{item.body}</p>
              </div>
            ))}
          </div>
        </article>

        <article class="calp-list-card calp-list-card-dark">
          <h3>{t(tr, 'caluanie.safety_title')}</h3>
          <ul class="calp-bullet-list">
            {handlingItems.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="calp-links" aria-labelledby="calp-links-title">
    <div class="container">
      <div class="calp-section-head calp-section-head-tight">
        <div class="calp-kicker">{t(tr, 'caluanie.benefits_label')}</div>
        <h2 id="calp-links-title">{t(tr, 'caluanie.benefits_title')}</h2>
        <p>{t(tr, 'caluanie.benefits_desc')}</p>
      </div>

      <div class="calp-link-grid">
        {relatedLinks.map((link) => (
          <a href={link.href} class="calp-link-card">
            <h3>{link.title}</h3>
            <p>{link.description}</p>
            <span>{t(tr, 'common.view_full_details')} <i class="fas fa-arrow-right"></i></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="calp-quote" id="quote" aria-labelledby="calp-quote-title">
    <div class="container calp-quote-grid">
      <div class="calp-quote-copy">
        <div class="calp-kicker">{t(tr, 'caluanie.quote_label')}</div>
        <h2 id="calp-quote-title">{t(tr, 'caluanie.quote_title')}</h2>
        <p>{t(tr, 'caluanie.quote_desc')}</p>

        <div class="calp-quote-badges">
          <span><i class="fas fa-clock"></i> {t(tr, 'caluanie.quote_badge1')}</span>
          <span><i class="fas fa-file-shield"></i> {t(tr, 'caluanie.quote_badge2')}</span>
          <span><i class="fas fa-globe"></i> {t(tr, 'caluanie.quote_badge3')}</span>
        </div>

        <ol class="calp-checklist">
          {orderChecklist.map((item) => (
            <li>{item}</li>
          ))}
        </ol>
      </div>

      <div class="calp-form-card">
        <form class="calp-form">
          <div class="calp-form-row">
            <div class="calp-form-group">
              <label for="calp-name">{t(tr, 'caluanie.form_name')}</label>
              <input id="calp-name" name="name" type="text" placeholder={t(tr, 'caluanie.form_placeholder_name')} required />
            </div>
            <div class="calp-form-group">
              <label for="calp-email">{t(tr, 'caluanie.form_email')}</label>
              <input id="calp-email" name="email" type="email" placeholder={t(tr, 'caluanie.form_placeholder_email')} required />
            </div>
          </div>

          <input type="hidden" name="product" value={productName} />

          <div class="calp-form-group">
            <label for="calp-message">{t(tr, 'caluanie.form_message')}</label>
            <textarea
              id="calp-message"
              name="message"
              rows="7"
              placeholder={t(tr, 'caluanie.form_placeholder_message')}
              required
            ></textarea>
          </div>

          <button type="submit" class="btn btn-accent calp-submit" aria-label={t(tr, 'caluanie.form_submit')}>{t(tr, 'caluanie.form_submit')} <i class="fas fa-paper-plane"></i></button>
        </form>
      </div>
    </div>
  </section>

  <section class="calp-faq" aria-labelledby="calp-faq-title">
    <div class="container">
      <div class="calp-section-head">
        <div class="calp-kicker">{t(tr, 'caluanie.faq_label')}</div>
        <h2 id="calp-faq-title">{t(tr, 'caluanie.faq_title')}</h2>
      </div>

      <div class="faq-list calp-faq-list">
        {faqItems.map((item) => (
          <article class="faq-item calp-faq-item">
            <button type="button" class="faq-question calp-faq-question">
              <span>{item.question}</span>
              <i class="fas fa-chevron-down"></i>
            </button>
            <div class="faq-answer calp-faq-answer">
              <div class="faq-answer-inner calp-faq-answer-inner">{item.answer}</div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .calp-sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .calp-hero {
    position: relative;
    padding: 160px 0 64px;
    background:
      radial-gradient(circle at top left, rgba(252, 82, 32, 0.18), transparent 34%),
