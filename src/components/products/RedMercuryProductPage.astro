---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getTranslations, localizedPath, t } from '../../i18n/index';
import { defaultLang } from '../../i18n/languages';
import { getDocumentDownload } from '../../lib/documentDownloads';
import { getQuoteBasedOffer } from '../../lib/merchantStructuredData';
import heroImage from '../../assets/products/red-mercury/red-mercury-20-20-258-rolling-liquid-sample.jpeg';
import vialImage from '../../assets/products/red-mercury/red-mercury-cherry-red-vial-laboratory.jpeg';
import qcImage from '../../assets/products/red-mercury/red-mercury-quality-control-inspection.jpeg';
import containerImage from '../../assets/products/red-mercury/red-mercury-sealed-export-container.jpeg';
import benchImage from '../../assets/products/red-mercury/red-mercury-density-test-bench.jpeg';

interface Props {
  lang?: string;
}

const { lang = defaultLang } = Astro.props;
const tr = getTranslations(lang);
const lp = (path: string) => localizedPath(path, lang);
const docDownload = (id: string) => {
  const download = getDocumentDownload(id, lang);
  if (!download) throw new Error(`Missing document download: ${id}`);
  return download;
};

const siteUrl = 'https://useful-chemicals.com';
const productName = 'Red Mercury 20/20-258';
const pageTitle = t(tr, 'red_mercury.meta_title');
const pageDescription = t(tr, 'red_mercury.meta_desc');
const pageKeywords = t(tr, 'red_mercury.meta_keywords');
const productPageUrl = `${siteUrl}${lp('/products/red-mercury')}`;
const returnPolicyUrl = `${siteUrl}${lp('/returns-policy')}`;
const shippingPolicyUrl = `${siteUrl}${lp('/shipping')}`;
const imageUrls = [heroImage, vialImage, qcImage, containerImage, benchImage].map((image) => `${siteUrl}${image.src}`);

const anchorLinks = [
  { href: '#summary', label: t(tr, 'red_mercury.overview_label') },
  { href: '#specifications', label: t(tr, 'red_mercury.tech_label') },
  { href: '#video', label: t(tr, 'red_mercury.anchor_nav_video') },
  { href: '#documents', label: t(tr, 'red_mercury.docs_label') },
  { href: '#handling', label: t(tr, 'red_mercury.safety_label') },
  { href: '#quote', label: t(tr, 'red_mercury.quote_label') },
];

const heroChipItems = [
  t(tr, 'red_mercury.hero_chip_tds'),
  t(tr, 'red_mercury.hero_chip_sds'),
  t(tr, 'red_mercury.hero_chip_coa'),
  t(tr, 'red_mercury.hero_chip_hazard'),
];

const heroFacts = [
  { label: t(tr, 'red_mercury.tech_formula'), value: t(tr, 'red_mercury.tech_formula_val') },
  { label: t(tr, 'red_mercury.tech_cas'), value: t(tr, 'red_mercury.tech_cas_val') },
  { label: t(tr, 'red_mercury.tech_purity'), value: t(tr, 'red_mercury.tech_purity_val') },
  { label: t(tr, 'red_mercury.tech_packing'), value: t(tr, 'red_mercury.tech_packing_val') },
];

const summaryCards = [
  {
    title: t(tr, 'red_mercury.overview_feat1_title'),
    body: t(tr, 'red_mercury.overview_feat1_desc'),
  },
  {
    title: t(tr, 'red_mercury.overview_feat2_title'),
    body: t(tr, 'red_mercury.overview_feat2_desc'),
  },
  {
    title: t(tr, 'red_mercury.overview_feat3_title'),
    body: t(tr, 'red_mercury.overview_feat3_desc'),
  },
  {
    title: t(tr, 'red_mercury.summary_doc_title'),
    body: t(tr, 'red_mercury.summary_doc_desc'),
  },
];

const verifiedSpecs = [
  [t(tr, 'red_mercury.tech_name'), t(tr, 'red_mercury.tech_name_val')],
  [t(tr, 'red_mercury.tech_formula'), t(tr, 'red_mercury.tech_formula_val')],
  [t(tr, 'red_mercury.tech_cas'), t(tr, 'red_mercury.tech_cas_val')],
  [t(tr, 'red_mercury.tech_appearance'), t(tr, 'red_mercury.tech_appearance_val')],
  [t(tr, 'red_mercury.tech_density'), t(tr, 'red_mercury.tech_density_val')],
  [t(tr, 'red_mercury.tech_purity'), t(tr, 'red_mercury.tech_purity_val')],
  [t(tr, 'red_mercury.tech_boiling'), t(tr, 'red_mercury.tech_boiling_val')],
  [t(tr, 'red_mercury.tech_solubility'), t(tr, 'red_mercury.tech_solubility_val')],
  [t(tr, 'red_mercury.tech_hazard'), t(tr, 'red_mercury.tech_hazard_val')],
  [t(tr, 'red_mercury.tech_un'), t(tr, 'red_mercury.tech_un_val')],
  [t(tr, 'red_mercury.tech_packing'), t(tr, 'red_mercury.tech_packing_val')],
  [t(tr, 'red_mercury.tech_shelf'), t(tr, 'red_mercury.tech_shelf_val')],
  [t(tr, 'red_mercury.tech_packs'), t(tr, 'red_mercury.tech_packs_val')],
];

const cautionItems = [
  t(tr, 'red_mercury.tech_note1'),
  t(tr, 'red_mercury.tech_note2'),
  t(tr, 'red_mercury.tech_note3'),
  t(tr, 'red_mercury.tech_note4'),
];

const documentCards = [
  {
    icon: 'fa-file-lines',
    title: t(tr, 'red_mercury.doc_tds_title'),
    code: 'TDS',
    date: t(tr, 'red_mercury.doc_tds_date'),
    summary: t(tr, 'red_mercury.doc_tds_desc'),
    note: t(tr, 'red_mercury.doc_tds_note'),
    download: docDownload('red-mercury-tds'),
    cta: t(tr, 'red_mercury.request_tds'),
    ariaLabel: `${t(tr, 'red_mercury.request_tds')} - ${t(tr, 'red_mercury.doc_tds_title')}`,
  },
  {
    icon: 'fa-shield-halved',
    title: t(tr, 'red_mercury.doc_sds_title'),
    code: 'SDS',
    date: t(tr, 'red_mercury.doc_sds_date'),
    summary: t(tr, 'red_mercury.doc_sds_desc'),
    note: t(tr, 'red_mercury.doc_sds_note'),
    download: docDownload('red-mercury-sds'),
    cta: t(tr, 'red_mercury.request_sds'),
    ariaLabel: `${t(tr, 'red_mercury.request_sds')} - ${t(tr, 'red_mercury.doc_sds_title')}`,
    publishedDate: '2023-06-01',
  },
  {
    icon: 'fa-certificate',
    title: t(tr, 'red_mercury.doc_coa_title'),
    code: 'COA',
    date: t(tr, 'red_mercury.doc_coa_date'),
    summary: t(tr, 'red_mercury.doc_coa_desc'),
    note: t(tr, 'red_mercury.doc_coa_note'),
    download: docDownload('red-mercury-coa'),
    cta: t(tr, 'red_mercury.request_coa'),
    ariaLabel: `${t(tr, 'red_mercury.request_coa')} - ${t(tr, 'red_mercury.doc_coa_title')}`,
    publishedDate: '2025-05-24',
  },
];

const applicationItems = [
  {
    title: t(tr, 'red_mercury.app1_title'),
    body: t(tr, 'red_mercury.app1_desc'),
  },
  {
    title: t(tr, 'red_mercury.app2_title'),
    body: t(tr, 'red_mercury.app2_desc'),
  },
  {
    title: t(tr, 'red_mercury.app3_title'),
    body: t(tr, 'red_mercury.app3_desc'),
  },
];

const handlingItems = [
  t(tr, 'red_mercury.safety1'),
  t(tr, 'red_mercury.safety2'),
  t(tr, 'red_mercury.safety3'),
  t(tr, 'red_mercury.safety4'),
];

const relatedLinks = [
  {
    href: lp('/products/caluanie'),
    title: t(tr, 'nav.caluanie'),
    description: t(tr, 'home.product1_desc'),
  },
  {
    href: lp('/products/silver-mercury'),
    title: t(tr, 'nav.silver_mercury'),
    description: t(tr, 'home.product3_desc'),
  },
  {
    href: lp('/certificates'),
    title: t(tr, 'red_mercury.link1_title'),
    description: t(tr, 'red_mercury.link1_desc'),
  },
  {
    href: lp('/ordering'),
    title: t(tr, 'red_mercury.link3_title'),
    description: t(tr, 'red_mercury.link3_desc'),
  },
  {
    href: lp('/shipping'),
    title: t(tr, 'red_mercury.link4_title'),
    description: t(tr, 'red_mercury.link4_desc'),
  },
  {
    href: lp('/contact'),
    title: t(tr, 'red_mercury.link6_title'),
    description: t(tr, 'red_mercury.link6_desc'),
  },
];

const quoteChecklist = [
  t(tr, 'red_mercury.quote_check1'),
  t(tr, 'red_mercury.quote_check2'),
  t(tr, 'red_mercury.quote_check3'),
  t(tr, 'red_mercury.quote_check4'),
];

const faqItems = [
  {
    question: t(tr, 'red_mercury.faq1_q'),
    answer: t(tr, 'red_mercury.faq1_a'),
  },
  {
    question: t(tr, 'red_mercury.faq2_q'),
    answer: t(tr, 'red_mercury.faq2_a'),
  },
  {
    question: t(tr, 'red_mercury.faq3_q'),
    answer: t(tr, 'red_mercury.faq3_a'),
  },
  {
    question: t(tr, 'red_mercury.faq4_q'),
    answer: t(tr, 'red_mercury.faq4_a'),
  },
];

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: productName,
  description: pageDescription,
  image: imageUrls,
  category: 'Specialty chemical',
  sku: 'UEC-RM-2020-258',
  brand: { '@type': 'Brand', name: 'UE Chemicals' },
  manufacturer: {
    '@type': 'Organization',
    name: 'UE Chemicals',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Bangkok',
      postalCode: '10260',
      addressCountry: 'TH',
    },
  },
  countryOfOrigin: { '@type': 'Country', name: 'Thailand' },
  keywords: pageKeywords,
  offers: getQuoteBasedOffer(productPageUrl, returnPolicyUrl, shippingPolicyUrl),
  additionalProperty: verifiedSpecs.map(([label, value]) => ({
    '@type': 'PropertyValue',
    name: label,
    value,
  })),
  subjectOf: documentCards.map((card) => ({
    '@type': 'DigitalDocument',
    name: `${productName} ${card.title}`,
    encodingFormat: 'application/pdf',
    url: `${siteUrl}${card.download.directHref}`,
    inLanguage: card.download.language,
    ...(card.publishedDate ? { datePublished: card.publishedDate } : {}),
  })),
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t(tr, 'nav.home'), item: `${siteUrl}${lp('/')}` },
    { '@type': 'ListItem', position: 2, name: t(tr, 'nav.products'), item: `${siteUrl}${lp('/products')}` },
    { '@type': 'ListItem', position: 3, name: productName, item: productPageUrl },
  ],
};

const speakableSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: pageTitle,
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['h1', '.rmp-hero-lead', '.rmp-summary-card p', '.rmp-faq-question'],
  },
  url: productPageUrl,
};
---

<BaseLayout
  lang={lang}
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
  activePage="products"
  ogImage={heroImage.src}
  jsonLd={[productSchema, faqSchema, breadcrumbSchema, speakableSchema]}
>
  <section class="rmp-hero" aria-labelledby="rmp-hero-title">
    <div class="container rmp-hero-grid">
      <div class="rmp-hero-copy">
        <div class="rmp-kicker">{t(tr, 'red_mercury.hero_badge')}</div>
        <h1 id="rmp-hero-title">{t(tr, 'red_mercury.hero_title')}</h1>
        <p class="rmp-hero-lead">{t(tr, 'red_mercury.hero_sub')}</p>
        <div class="rmp-chip-row" aria-label={t(tr, 'red_mercury.hero_chip_row_label')}>
          {heroChipItems.map((item) => (
            <span>{item}</span>
          ))}
        </div>
        <div class="rmp-hero-actions">
          <a href="#quote" class="btn btn-accent">{t(tr, 'common.get_quote')} <i class="fas fa-arrow-right"></i></a>
        </div>
        <p class="rmp-hero-note">{t(tr, 'red_mercury.hero_note')}</p>
      </div>

      <div class="rmp-hero-panel">
        <figure class="rmp-figure rmp-figure-primary">
          <Image
            src={heroImage}
            alt={t(tr, 'red_mercury.hero_image_alt')}
            widths={[768, 1200, 1600]}
            sizes="(max-width: 1024px) 100vw, 48vw"
            quality={82}
            format="webp"
            loading="eager"
            fetchpriority="high"
            class="rmp-image"
          />
          <figcaption>{t(tr, 'red_mercury.hero_image_caption')}</figcaption>
        </figure>

        <dl class="rmp-fact-list">
          {heroFacts.map((item) => (
            <div class="rmp-fact-item">
              <dt>{item.label}</dt>
              <dd>{item.value}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>
  </section>

  <nav class="rmp-anchor-nav" aria-label={t(tr, 'red_mercury.anchor_nav_label')}>
    <div class="container rmp-anchor-row">
      {anchorLinks.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </div>
  </nav>

  <section class="rmp-summary" id="summary" aria-labelledby="rmp-summary-title">
    <div class="container">
      <div class="rmp-section-head">
        <div class="rmp-kicker">{t(tr, 'red_mercury.overview_label')}</div>
        <h2 id="rmp-summary-title">{t(tr, 'red_mercury.overview_title')}</h2>
        <p>{t(tr, 'red_mercury.overview_desc1')}</p>
      </div>
      <div class="rmp-summary-grid">
        {summaryCards.map((card) => (
          <article class="rmp-summary-card">
            <h3>{card.title}</h3>
            <p>{card.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="rmp-gallery" aria-labelledby="rmp-gallery-title">
    <div class="container">
      <div class="rmp-section-head rmp-section-head-tight">
        <div class="rmp-kicker">{t(tr, 'red_mercury.overview_label')}</div>
        <h2 id="rmp-gallery-title">{t(tr, 'red_mercury.docs_label')}</h2>
        <p>{t(tr, 'red_mercury.overview_desc2')}</p>
      </div>

      <div class="rmp-gallery-grid">
        <figure class="rmp-figure">
          <Image
            src={vialImage}
            alt={t(tr, 'red_mercury.gallery_image_alt')}
            widths={[640, 960, 1280]}
            sizes="(max-width: 1024px) 100vw, 50vw"
            quality={80}
            format="webp"
            loading="lazy"
            class="rmp-image"
          />
          <figcaption>{t(tr, 'red_mercury.gallery_image_caption')}</figcaption>
        </figure>

        <figure class="rmp-figure">
          <Image
            src={qcImage}
            alt={t(tr, 'red_mercury.facility_image_alt')}
            widths={[640, 960, 1280]}
            sizes="(max-width: 1024px) 100vw, 50vw"
            quality={80}
            format="webp"
            loading="lazy"
            class="rmp-image"
          />
          <figcaption>{t(tr, 'red_mercury.facility_image_caption')}</figcaption>
        </figure>

        <figure class="rmp-figure">
          <Image
            src={containerImage}
            alt={t(tr, 'red_mercury.container_image_alt')}
            widths={[640, 960, 1280]}
            sizes="(max-width: 1024px) 100vw, 50vw"
            quality={80}
            format="webp"
            loading="lazy"
            class="rmp-image"
          />
          <figcaption>{t(tr, 'red_mercury.container_image_caption')}</figcaption>
        </figure>

        <figure class="rmp-figure">
          <Image
            src={benchImage}
            alt={t(tr, 'red_mercury.bench_image_alt')}
            widths={[640, 960, 1280]}
            sizes="(max-width: 1024px) 100vw, 50vw"
            quality={80}
            format="webp"
            loading="lazy"
            class="rmp-image"
          />
          <figcaption>{t(tr, 'red_mercury.bench_image_caption')}</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="rmp-specs" id="specifications" aria-labelledby="rmp-specs-title">
    <div class="container rmp-specs-grid">
      <div class="rmp-specs-copy">
        <div class="rmp-kicker">{t(tr, 'red_mercury.tech_label')}</div>
        <h2 id="rmp-specs-title">{t(tr, 'red_mercury.tech_title')}</h2>
        <p>{t(tr, 'red_mercury.tech_desc')}</p>

        <div class="rmp-note-card">
          <h3>{t(tr, 'red_mercury.tech_note_title')}</h3>
          <ul>
            {cautionItems.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>

      <div class="rmp-table-card">
        <table class="rmp-spec-table">
          <caption class="rmp-sr-only">{t(tr, 'red_mercury.tech_table_caption')}</caption>
          <tbody>
            {verifiedSpecs.map(([label, value]) => (
              <tr>
                <th scope="row">{label}</th>
                <td>{value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="rmp-video" id="video" aria-labelledby="rmp-video-title">
    <div class="container">
      <div class="rmp-section-head">
        <div class="rmp-kicker">{t(tr, 'red_mercury.video_label')}</div>
        <h2 id="rmp-video-title">{t(tr, 'red_mercury.video_title')}</h2>
        <p>{t(tr, 'red_mercury.video_desc')}</p>
      </div>

      <figure class="rmp-video-figure">
        <div
          class="rmp-video-frame"
          data-rmp-video
          oncontextmenu="return false;"
          ondragstart="event.preventDefault();"
        >
          <video
            class="rmp-video-el"
            preload="metadata"
            playsinline
            autoplay
            muted
            loop
            controls
            poster="/videos/red-mercury-rolling-liquid-test-poster.jpg"
            controlslist="nodownload noremoteplayback noplaybackrate"
            disablepictureinpicture
            oncontextmenu="return false;"
            aria-label={t(tr, 'red_mercury.video_title')}
          >
            <source src="/videos/red-mercury-rolling-liquid-test.mp4" type="video/mp4" />
            {t(tr, 'red_mercury.video_unsupported')}
          </video>
          <button
            type="button"
            class="rmp-video-playbtn"
            data-rmp-playbtn
            aria-label={t(tr, 'red_mercury.video_title')}
          >
            <svg viewBox="0 0 64 64" width="64" height="64" aria-hidden="true">
              <circle cx="32" cy="32" r="30" fill="rgba(0,0,0,0.55)" stroke="#fff" stroke-width="2"/>
              <polygon points="26,20 26,44 46,32" fill="#fff"/>
            </svg>
          </button>
          <div class="rmp-video-watermark" aria-hidden="true">
            <span class="rmp-watermark-text">{t(tr, 'red_mercury.video_watermark')}</span>
            <span class="rmp-watermark-text">{t(tr, 'red_mercury.video_watermark')}</span>
            <span class="rmp-watermark-text">{t(tr, 'red_mercury.video_watermark')}</span>
            <span class="rmp-watermark-text">{t(tr, 'red_mercury.video_watermark')}</span>
            <span class="rmp-watermark-text">{t(tr, 'red_mercury.video_watermark')}</span>
            <span class="rmp-watermark-text">{t(tr, 'red_mercury.video_watermark')}</span>
            <span class="rmp-watermark-text">{t(tr, 'red_mercury.video_watermark')}</span>
            <span class="rmp-watermark-text">{t(tr, 'red_mercury.video_watermark')}</span>
            <span class="rmp-watermark-text">{t(tr, 'red_mercury.video_watermark')}</span>
            <span class="rmp-watermark-text">{t(tr, 'red_mercury.video_watermark')}</span>
            <span class="rmp-watermark-text">{t(tr, 'red_mercury.video_watermark')}</span>
            <span class="rmp-watermark-text">{t(tr, 'red_mercury.video_watermark')}</span>
          </div>
          <div class="rmp-video-shield" aria-hidden="true"></div>
        </div>
        <figcaption>
          <span class="rmp-video-caption-text">{t(tr, 'red_mercury.video_caption')}</span>
          <span class="rmp-video-protect">{t(tr, 'red_mercury.video_protect_notice')}</span>
        </figcaption>
      </figure>
    </div>
  </section>

  <section class="rmp-docs" id="documents" aria-labelledby="rmp-docs-title">
    <div class="container">
      <div class="rmp-section-head">
        <div class="rmp-kicker">{t(tr, 'red_mercury.docs_label')}</div>
        <h2 id="rmp-docs-title">{t(tr, 'red_mercury.docs_label')}</h2>
        <p>{t(tr, 'red_mercury.doc_tds_desc')}</p>
      </div>

      <div class="rmp-doc-grid">
        {documentCards.map((card) => (
          <article class="rmp-doc-card">
            <div class="rmp-doc-icon"><i class:list={['fas', card.icon]}></i></div>
            <div class="rmp-doc-body">
              <div class="rmp-doc-meta">{card.code}</div>
              <h3>{card.title}</h3>
              <p class="rmp-doc-date">{card.date}</p>
              <p>{card.summary}</p>
              <p class="rmp-doc-note">{card.note}</p>
            </div>
