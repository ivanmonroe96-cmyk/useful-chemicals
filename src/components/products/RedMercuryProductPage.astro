<script>
  // Best-effort client-side download protection for the watermarked video.
  // Note: no client measure can defeat screen recording or determined network capture.
  (function () {
    const init = () => {
      const frames = document.querySelectorAll('[data-rmp-video]');
      frames.forEach((frame) => {
        const el = frame as HTMLElement;
        const video = el.querySelector('video') as HTMLVideoElement | null;
        const playBtn = el.querySelector('[data-rmp-playbtn]') as HTMLButtonElement | null;
        if (!video) return;

        const setPaused = (paused: boolean) => {
          el.classList.toggle('is-paused', paused);
        };

        ['contextmenu', 'dragstart'].forEach((evt) => {
          el.addEventListener(evt, (e) => e.preventDefault());
          video.addEventListener(evt, (e) => e.preventDefault());
        });
        video.addEventListener('keydown', (e) => {
          const k = (e as KeyboardEvent).key.toLowerCase();
          if ((e as KeyboardEvent).ctrlKey || (e as KeyboardEvent).metaKey) {
            if (k === 's' || k === 'u') e.preventDefault();
          }
        });

        video.addEventListener('play', () => setPaused(false));
        video.addEventListener('playing', () => setPaused(false));
        video.addEventListener('pause', () => setPaused(true));
        video.addEventListener('ended', () => setPaused(true));

        if (playBtn) {
          playBtn.addEventListener('click', () => {
            video.muted = true;
            const p = video.play();
            if (p && typeof p.then === 'function') {
              p.then(() => setPaused(false)).catch(() => setPaused(true));
            }
          });
        }

        // Pause on tab hide, resume on return
        document.addEventListener('visibilitychange', () => {
          if (document.hidden) {
            try { video.pause(); } catch (_) { /* noop */ }
          } else if (video.muted) {
            const p = video.play();
            if (p && typeof p.catch === 'function') p.catch(() => { /* noop */ });
          }
        });

        // Best-effort autoplay kick-start
        const tryPlay = () => {
          video.muted = true;
          const p = video.play();
          if (p && typeof p.then === 'function') {
            p.then(() => setPaused(false)).catch(() => setPaused(true));
          }
        };
        if (video.readyState >= 2) tryPlay();
        else video.addEventListener('loadeddata', tryPlay, { once: true });
        // Initial state
        setPaused(video.paused);
      });
    };
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
