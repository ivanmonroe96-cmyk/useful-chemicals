---
interface Props {
  activePage?: string;
}
const { activePage = '' } = Astro.props;
---

<header class="header" id="header">
  <div class="container">
    <a href="/" class="logo">
      <img src="/images/logo.webp" alt="UE Chemicals" />
    </a>
    <nav class="nav" id="nav">
      <a href="/" class:list={["nav-link", { active: activePage === 'home' }]}>Home</a>
      <a href="/about" class:list={["nav-link", { active: activePage === 'about' }]}>About</a>
      <a href="/applications" class:list={["nav-link", { active: activePage === 'applications' }]}>Applications</a>
      <a href="/safety" class:list={["nav-link", { active: activePage === 'safety' }]}>Safety Information</a>
      <div class="nav-dropdown">
        <a href="/products" class:list={["nav-link", { active: activePage === 'products' }]}>
          Our Products <i class="fas fa-chevron-down"></i>
        </a>
        <div class="dropdown-menu">
          <a href="/products/caluanie">Caluanie Muelear Oxidize</a>
          <a href="/products/red-mercury">Red Mercury</a>
          <a href="/products/silver-mercury">Silver Mercury</a>
        </div>
      </div>
      <a href="/ordering" class:list={["nav-link", { active: activePage === 'ordering' }]}>Ordering Information</a>
      <a href="/contact" class:list={["nav-link", { active: activePage === 'contact' }]}>Contact Us</a>
    </nav>
    <div class="header-actions">
      <button class="search-toggle" id="searchToggle" aria-label="Search">
        <i class="fas fa-search"></i>
      </button>
      <div class="menu-toggle" id="menuToggle">
        <span></span>
        <span></span>
        <span></span>
      </div>
    </div>
  </div>
</header>

<!-- Search Overlay -->
<div class="search-overlay" id="searchOverlay">
  <div class="search-overlay-inner">
    <button class="search-close" id="searchClose" aria-label="Close search"><i class="fas fa-times"></i></button>
    <form class="search-form" id="searchForm">
      <input type="text" class="search-input" id="searchInput" placeholder="Search products, pages..." autocomplete="off" />
      <button type="submit" class="search-submit"><i class="fas fa-search"></i></button>
    </form>
    <div class="search-results" id="searchResults"></div>
  </div>
</div>
