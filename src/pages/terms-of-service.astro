  .legal-inner h3:first-of-type { border-top: none; padding-top: 0; margin-top: 0; }
  .legal-inner h4 { font-size: 1.05rem; color: var(--heading); margin: 20px 0 10px; }
  .legal-inner p { color: var(--body-text); line-height: 1.8; margin-bottom: 16px; }
  .legal-inner ul { margin: 0 0 20px 24px; }
  .legal-inner li { color: var(--body-text); line-height: 1.8; margin-bottom: 8px; }
  .legal-inner a { color: var(--primary); text-decoration: underline; }
</style>
