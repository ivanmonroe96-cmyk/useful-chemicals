---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What products does UE Chemicals sell?", "acceptedAnswer": { "@type": "Answer", "text": "We supply three core specialty chemicals: Caluanie Muelear Oxidize (industrial oxidizer for metalworking and refining), Red Liquid Mercury (Sb₂O₇Hg₂, for research and industrial applications), and Silver Liquid Mercury (99.99% purity, for gold extraction, manufacturing, and laboratory use)." } },
    { "@type": "Question", "name": "What purity levels do your chemical products have?", "acceptedAnswer": { "@type": "Answer", "text": "Our Silver Liquid Mercury is certified at ≥99.99% purity (4N grade). Red Liquid Mercury purity is 99.999% (5N grade). Caluanie Muelear Oxidize is manufactured to premium industrial specifications. Certificates of Analysis (COA) are provided with every order." } },
    { "@type": "Question", "name": "Do you ship chemicals internationally from Germany?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, we ship worldwide from our facility in Essen, Germany. We deliver to Europe, Asia, Africa, North and South America, and Oceania using licensed hazardous materials carriers." } },
    { "@type": "Question", "name": "How do I place an order for chemicals?", "acceptedAnswer": { "@type": "Answer", "text": "Submit a quote request through our contact form or email us at info@useful-chemicals.com. Include the product, quantity, and delivery destination. We'll respond with a Proforma Invoice within 24 hours." } },
    { "@type": "Question", "name": "Do you provide Certificates of Analysis (COA)?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, a Certificate of Analysis (COA) is provided with every order, verifying product purity, composition, and batch-specific quality data." } },
    { "@type": "Question", "name": "Are your chemicals REACH compliant?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, we comply with EU REACH Regulation (EC 1907/2006) and the EU Mercury Regulation (EU 2017/852). All products meet applicable EU chemical safety and registration requirements." } },
    { "@type": "Question", "name": "Do you offer bulk discounts on chemicals?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, we offer competitive wholesale pricing for bulk orders. Contact our sales team with your quantity requirements for custom pricing." } },
    { "@type": "Question", "name": "How long does chemical delivery take?", "acceptedAnswer": { "@type": "Answer", "text": "Delivery timelines vary by destination: Germany 1–3 days, EU 3–7 days, North America 7–14 days, Asia 10–21 days. Tracking is provided with every order." } }
  ]
};
---

<BaseLayout title="FAQ – Ordering, Shipping & Products" description="Frequently asked questions about ordering Caluanie, Red Mercury & Silver Mercury from UE Chemicals. Shipping, safety, pricing & product information answered." activePage="faq" jsonLd={faqSchema}>

  <!-- ========== HERO ========== -->
  <section class="fq-hero">
    <div class="fq-hero-bg">
      <img src="/images/pexels-los-muertos-crew-10041264.jpg" alt="FAQ - UE Chemicals support" />
      <div class="fq-hero-overlay"></div>
    </div>
    <div class="container fq-hero-inner">
      <div class="fq-hero-content">
        <div class="fq-hero-badge"><i class="fas fa-circle-question"></i> Help Center</div>
        <h1>Frequently Asked<br />Questions</h1>
        <p class="fq-hero-sub">Find answers to common questions about our products, ordering process, shipping, safety guidelines, and compliance documentation.</p>
      </div>
      <div class="fq-hero-stats">
        <div class="fq-stat-pill"><i class="fas fa-flask"></i> 3 Core Products</div>
        <div class="fq-stat-pill"><i class="fas fa-earth-europe"></i> Global Shipping</div>
        <div class="fq-stat-pill"><i class="fas fa-clock"></i> 24h Response</div>
        <div class="fq-stat-pill"><i class="fas fa-file-lines"></i> Full Documentation</div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ Content ========== -->
  <section class="fq-content">
    <div class="container">
      <div class="fq-grid">

        <!-- Sidebar -->
        <aside class="fq-sidebar">
          <div class="fq-sidebar-inner">
            <h5><i class="fas fa-layer-group"></i> Categories</h5>
            <nav class="fq-nav">
              <a href="#general" class="fq-nav-link active" data-cat="general"><span class="fq-nav-icon"><i class="fas fa-building"></i></span> General <span class="fq-nav-count">4</span></a>
              <a href="#products" class="fq-nav-link" data-cat="products"><span class="fq-nav-icon"><i class="fas fa-flask"></i></span> Products <span class="fq-nav-count">7</span></a>
              <a href="#ordering" class="fq-nav-link" data-cat="ordering"><span class="fq-nav-icon"><i class="fas fa-shopping-cart"></i></span> Ordering <span class="fq-nav-count">4</span></a>
              <a href="#shipping" class="fq-nav-link" data-cat="shipping"><span class="fq-nav-icon"><i class="fas fa-truck"></i></span> Shipping <span class="fq-nav-count">5</span></a>
              <a href="#safety" class="fq-nav-link" data-cat="safety"><span class="fq-nav-icon"><i class="fas fa-shield-halved"></i></span> Safety <span class="fq-nav-count">4</span></a>
              <a href="#compliance" class="fq-nav-link" data-cat="compliance"><span class="fq-nav-icon"><i class="fas fa-file-lines"></i></span> Compliance <span class="fq-nav-count">5</span></a>
            </nav>
            <div class="fq-sidebar-cta">
              <p>Can't find your answer?</p>
              <a href="/contact" class="btn btn-accent" style="width:100%;text-align:center;font-size:.88rem;padding:12px;">Contact Us <i class="fas fa-arrow-right"></i></a>
            </div>
          </div>
        </aside>

        <!-- Main FAQ -->
        <div class="fq-main">

          <!-- General -->
          <div class="fq-category" id="general">
            <div class="fq-cat-header">
              <div class="fq-cat-icon"><i class="fas fa-building"></i></div>
              <div>
                <h3>General</h3>
                <p>About UE Chemicals and our operations</p>
              </div>
            </div>
            <div class="fq-list">
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>Who is UE Chemicals?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">UE Chemicals is a specialty chemical supplier based in Essen, Germany. We supply industrial-grade chemicals including Caluanie Muelear Oxidize, Red Liquid Mercury, and Silver Liquid Mercury for legitimate industrial, research, and commercial applications worldwide.</div></div>
              </div>
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>Where are you located?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">Our facility and offices are located at 104 Essen, 45001, Germany. We ship internationally to destinations across Europe, Asia, Africa, the Americas, and Oceania.</div></div>
              </div>
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>How long have you been in business?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">UE Chemicals has been serving industrial and research clients with premium specialty chemicals, building a reputation for reliability, quality, and safety compliance.</div></div>
              </div>
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>Do you offer customer support?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">Yes, our team is available to assist you with product questions, ordering, safety guidance, and technical support. Contact us via email at info@useful-chemicals.com or through our <a href="/contact">contact form</a>.</div></div>
              </div>
            </div>
          </div>

          <!-- Products -->
          <div class="fq-category" id="products">
            <div class="fq-cat-header">
              <div class="fq-cat-icon fq-icon-blue"><i class="fas fa-flask"></i></div>
              <div>
                <h3>Products</h3>
                <p>Product details, purity, and specifications</p>
              </div>
            </div>
            <div class="fq-list">
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>What products do you sell?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">We supply three core specialty chemicals: <strong>Caluanie Muelear Oxidize</strong> (industrial oxidizer for metalworking and refining), <strong>Red Liquid Mercury</strong> (Sb₂O₇Hg₂, for research and industrial applications), and <strong>Silver Liquid Mercury</strong> (99.99% purity, for gold extraction, manufacturing, and laboratory use).</div></div>
              </div>
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>What purity levels do your products have?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">Our Silver Liquid Mercury is certified at ≥99.99% purity (4N grade). Red Liquid Mercury purity is 99.999% (5N grade). Caluanie Muelear Oxidize is manufactured to premium industrial specifications. Certificates of Analysis (COA) are provided with every order.</div></div>
              </div>
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>What is Caluanie Muelear Oxidize used for?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">Caluanie Muelear Oxidize is primarily used in metalworking, mineral extraction, chemical manufacturing, and industrial refining. It's a highly effective oxidizing agent that breaks down metals efficiently, reducing labor and processing time.</div></div>
              </div>
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>Is Red Liquid Mercury real?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">Red Liquid Mercury (Sb₂O₇Hg₂ — antimony mercury oxide) is a rare compound with unique properties. Our product is sourced from verified suppliers and comes with full certification and documentation to verify authenticity.</div></div>
              </div>
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>What is Silver Mercury used for?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">Silver Liquid Mercury is widely used in gold mining and extraction, dental amalgams, medical devices, manufacturing of industrial instruments, thermometers, barometers, and scientific laboratory research.</div></div>
              </div>
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>Do you provide product samples?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">Sample orders may be available depending on the product. Minimum order quantities apply. Please contact us with your specific requirements for sample pricing and availability.</div></div>
              </div>
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>Do you offer bulk discounts?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">Yes, we offer competitive wholesale pricing for bulk orders. Contact our sales team with your quantity requirements for custom pricing. Visit our <a href="/wholesale">wholesale page</a> for more details.</div></div>
              </div>
            </div>
          </div>

          <!-- Ordering -->
          <div class="fq-category" id="ordering">
            <div class="fq-cat-header">
              <div class="fq-cat-icon fq-icon-green"><i class="fas fa-shopping-cart"></i></div>
              <div>
                <h3>Ordering &amp; Payment</h3>
                <p>How to place orders and payment methods</p>
              </div>
            </div>
            <div class="fq-list">
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>How do I place an order?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">Submit a quote request through our <a href="/contact">contact form</a> or email us at info@useful-chemicals.com. Include the product, quantity, and delivery destination. We'll respond with a Proforma Invoice within 24 hours.</div></div>
              </div>
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>What payment methods do you accept?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">We accept bank wire transfers and cryptocurrency (Bitcoin). Payment details are provided on the Proforma Invoice. Bank transfers may take up to 5 business days to process.</div></div>
              </div>
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>What is a Proforma Invoice?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">A Proforma Invoice is a preliminary invoice sent before the sale is finalized. It includes product details, pricing, shipping costs, payment instructions, and estimated delivery timeline. It serves as a formal quote and order confirmation.</div></div>
              </div>
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>Can I cancel my order?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">Orders may be canceled before shipment. Once the product has been dispatched, cancellation is no longer possible. Please contact us as soon as possible if you need to modify or cancel an order.</div></div>
              </div>
            </div>
          </div>

          <!-- Shipping -->
          <div class="fq-category" id="shipping">
            <div class="fq-cat-header">
              <div class="fq-cat-icon fq-icon-purple"><i class="fas fa-truck"></i></div>
              <div>
                <h3>Shipping &amp; Delivery</h3>
                <p>International shipping and tracking</p>
              </div>
            </div>
            <div class="fq-list">
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>Do you ship internationally?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">Yes, we ship worldwide from our facility in Essen, Germany. We deliver to Europe, Asia, Africa, North and South America, and Oceania using licensed hazardous materials carriers.</div></div>
              </div>
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>How long does delivery take?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">Delivery timelines vary by destination: Germany 1–3 days, EU 3–7 days, North America 7–14 days, Asia 10–21 days. Full details are on our <a href="/shipping">Shipping page</a>. Tracking is provided with every order.</div></div>
              </div>
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>Is the packaging discreet?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">All products are shipped in UN-approved packaging with proper hazmat labeling as required by international transport regulations. We also offer specialized discreet packaging solutions — contact us for details.</div></div>
              </div>
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>Do you provide tracking information?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">Yes, tracking details are provided for all shipments. You'll receive tracking information via email once your order has been dispatched.</div></div>
              </div>
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>What happens if my shipment is delayed by customs?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">Customs processing times are outside our control, but we provide comprehensive documentation (SDS, COA, TDS, customs declarations) to facilitate smooth clearance. Our team can assist with any customs-related inquiries.</div></div>
              </div>
            </div>
          </div>

          <!-- Safety -->
          <div class="fq-category" id="safety">
            <div class="fq-cat-header">
              <div class="fq-cat-icon fq-icon-red"><i class="fas fa-shield-halved"></i></div>
              <div>
                <h3>Safety &amp; Handling</h3>
                <p>Safe handling, PPE, and storage guidelines</p>
              </div>
            </div>
            <div class="fq-list">
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>Are your products safe to handle?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">Our products are safe when handled according to the Safety Data Sheet (SDS) guidelines provided with every order. Proper personal protective equipment (PPE), ventilation, and storage conditions must be maintained at all times.</div></div>
              </div>
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>What PPE is required?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">At minimum, protective gloves, safety goggles, and a lab coat or protective clothing are required. For mercury products, work in well-ventilated areas or use respiratory protection to avoid vapor inhalation. Full PPE requirements are detailed in each product's SDS.</div></div>
              </div>
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>How should chemicals be stored?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">Store in a cool, dry, well-ventilated area away from direct sunlight and incompatible materials. Keep containers tightly sealed when not in use. Follow all storage guidelines in the product's Safety Data Sheet.</div></div>
              </div>
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>What should I do in case of a spill?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">Evacuate the area and ventilate. Do not touch or walk through spilled material. Use appropriate spill kits for containment. For mercury spills, use mercury spill kits and avoid vacuuming. Refer to the SDS for detailed emergency procedures and contact local hazardous waste authorities if necessary.</div></div>
              </div>
            </div>
          </div>

          <!-- Compliance -->
          <div class="fq-category" id="compliance">
            <div class="fq-cat-header">
              <div class="fq-cat-icon fq-icon-gold"><i class="fas fa-file-lines"></i></div>
              <div>
                <h3>Compliance &amp; Documentation</h3>
                <p>Regulatory compliance and certifications</p>
              </div>
            </div>
            <div class="fq-list">
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>Do you provide Certificates of Analysis (COA)?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">Yes, a Certificate of Analysis (COA) is provided with every order, verifying product purity, composition, and batch-specific quality data.</div></div>
              </div>
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>Do you provide Safety Data Sheets (SDS)?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">Yes, Safety Data Sheets compliant with GHS and EU REACH regulations are provided with all shipments. SDS documents include hazard identification, first aid measures, handling and storage instructions, and disposal considerations.</div></div>
              </div>
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>Are you REACH compliant?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">Yes, we comply with EU REACH Regulation (EC 1907/2006) and the EU Mercury Regulation (EU 2017/852). All products meet applicable EU chemical safety and registration requirements.</div></div>
              </div>
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>Do I need a license to purchase your products?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">Requirements vary by country and product. Some jurisdictions require permits or end-use declarations for mercury products. Our team can help you understand the requirements for your specific location and intended use.</div></div>
              </div>
              <div class="fq-item">
                <button class="fq-question" aria-expanded="false">
                  <span>Do you provide Technical Data Sheets (TDS)?</span>
                  <div class="fq-toggle"><i class="fas fa-plus"></i></div>
                </button>
                <div class="fq-answer"><div class="fq-answer-inner">Yes, Technical Data Sheets with detailed chemical specifications, physical properties, and application guidelines are available for all products. Contact us or visit individual product pages for TDS information.</div></div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ========== CTA ========== -->
  <section class="fq-cta">
    <div class="container">
      <div class="fq-cta-inner">
        <div class="fq-cta-icon"><i class="fas fa-comments"></i></div>
        <h2>Still Have Questions?</h2>
        <p>Our team is ready to help with any product, ordering, or technical questions. We respond within 24 hours.</p>
        <div class="fq-cta-actions">
          <a href="/contact" class="btn btn-white">Contact Us <i class="fas fa-arrow-right"></i></a>
          <a href="/products" class="btn btn-outline-white">Browse Products <i class="fas fa-flask"></i></a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ===== Hero ===== */
  .fq-hero { position: relative; min-height: 50vh; display: flex; align-items: center; }
  .fq-hero-bg { position: absolute; inset: 0; z-index: 0; }
  .fq-hero-bg img { width: 100%; height: 100%; object-fit: cover; }
  .fq-hero-overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(10,15,30,.92), rgba(10,15,30,.72)); }
  .fq-hero-inner { position: relative; z-index: 1; padding: 110px 0 70px; }
  .fq-hero-content { max-width: 680px; margin-bottom: 32px; }
  .fq-hero-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.12); backdrop-filter: blur(8px); padding: 8px 18px; border-radius: 100px; font-size: .85rem; color: var(--accent); margin-bottom: 20px; }
  .fq-hero h1 { font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 800; color: #fff; line-height: 1.15; margin-bottom: 18px; }
  .fq-hero-sub { color: rgba(255,255,255,.75); font-size: 1.1rem; line-height: 1.7; }
  .fq-hero-stats { display: flex; gap: 12px; flex-wrap: wrap; }
  .fq-stat-pill { display: flex; align-items: center; gap: 8px; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); padding: 10px 18px; border-radius: 10px; color: rgba(255,255,255,.85); font-size: .86rem; font-weight: 500; backdrop-filter: blur(4px); }
  .fq-stat-pill i { color: var(--accent); }

  /* ===== Content ===== */
  .fq-content { padding: 80px 0; }
  .fq-grid { display: grid; grid-template-columns: 260px 1fr; gap: 48px; }

  /* ===== Sidebar ===== */
  .fq-sidebar { position: sticky; top: 100px; align-self: start; }
  .fq-sidebar-inner { background: #fff; border: 1px solid var(--border); border-radius: 16px; padding: 28px 24px; }
  .fq-sidebar-inner h5 { font-size: .82rem; text-transform: uppercase; letter-spacing: .1em; color: var(--body-text); margin-bottom: 18px; display: flex; align-items: center; gap: 8px; }
