---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Frequently Asked Questions" description="Find answers to common questions about UE Chemicals products, ordering, shipping, safety, and more." activePage="">

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="section-label">Support</div>
      <h1>Frequently Asked Questions</h1>
      <p>Find answers to common questions about our products, ordering, shipping, and safety.</p>
    </div>
  </section>

  <!-- FAQ Content -->
  <section class="faq-page">
    <div class="container">
      <div class="faq-page-grid">

        <!-- Sidebar Nav -->
        <div class="faq-sidebar">
          <h5>Categories</h5>
          <a href="#general" class="faq-cat-link active"><i class="fas fa-building"></i> General</a>
          <a href="#products" class="faq-cat-link"><i class="fas fa-flask"></i> Products</a>
          <a href="#ordering" class="faq-cat-link"><i class="fas fa-shopping-cart"></i> Ordering & Payment</a>
          <a href="#shipping" class="faq-cat-link"><i class="fas fa-truck"></i> Shipping & Delivery</a>
          <a href="#safety" class="faq-cat-link"><i class="fas fa-shield-halved"></i> Safety & Handling</a>
          <a href="#compliance" class="faq-cat-link"><i class="fas fa-file-lines"></i> Compliance & Documentation</a>
        </div>

        <!-- FAQ Sections -->
        <div class="faq-main">

          <!-- General -->
          <div class="faq-category" id="general">
            <h3><i class="fas fa-building"></i> General</h3>
            <div class="faq-list">
              <div class="faq-item">
                <div class="faq-question">Who is UE Chemicals? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">UE Chemicals is a specialty chemical supplier based in Essen, Germany. We supply industrial-grade chemicals including Caluanie Muelear Oxidize, Red Liquid Mercury, and Silver Liquid Mercury for legitimate industrial, research, and commercial applications worldwide.</div></div>
              </div>
              <div class="faq-item">
                <div class="faq-question">Where are you located? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">Our facility and offices are located at 104 Essen, 45001, Germany. We ship internationally to destinations across Europe, Asia, Africa, the Americas, and Oceania.</div></div>
              </div>
              <div class="faq-item">
                <div class="faq-question">How long have you been in business? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">UE Chemicals has been serving industrial and research clients with premium specialty chemicals, building a reputation for reliability, quality, and safety compliance.</div></div>
              </div>
              <div class="faq-item">
                <div class="faq-question">Do you offer customer support? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">Yes, our team is available to assist you with product questions, ordering, safety guidance, and technical support. Contact us via email at info@useful-chemicals.com or through our <a href="/contact">contact form</a>.</div></div>
              </div>
            </div>
          </div>

          <!-- Products -->
          <div class="faq-category" id="products">
            <h3><i class="fas fa-flask"></i> Products</h3>
            <div class="faq-list">
              <div class="faq-item">
                <div class="faq-question">What products do you sell? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">We supply three core specialty chemicals: <strong>Caluanie Muelear Oxidize</strong> (industrial oxidizer for metalworking and refining), <strong>Red Liquid Mercury</strong> (Sb₂O₇Hg₂, for research and industrial applications), and <strong>Silver Liquid Mercury</strong> (99.99% purity, for gold extraction, manufacturing, and laboratory use).</div></div>
              </div>
              <div class="faq-item">
                <div class="faq-question">What purity levels do your products have? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">Our Silver Liquid Mercury is certified at ≥99.99% purity (4N grade). Red Liquid Mercury purity is 99.999% (5N grade). Caluanie Muelear Oxidize is manufactured to premium industrial specifications. Certificates of Analysis (COA) are provided with every order.</div></div>
              </div>
              <div class="faq-item">
                <div class="faq-question">What is Caluanie Muelear Oxidize used for? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">Caluanie Muelear Oxidize is primarily used in metalworking, mineral extraction, chemical manufacturing, and industrial refining. It's a highly effective oxidizing agent that breaks down metals efficiently, reducing labor and processing time.</div></div>
              </div>
              <div class="faq-item">
                <div class="faq-question">Is Red Liquid Mercury real? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">Red Liquid Mercury (Sb₂O₇Hg₂ — antimony mercury oxide) is a rare compound with unique properties. Our product is sourced from verified suppliers and comes with full certification and documentation to verify authenticity.</div></div>
              </div>
              <div class="faq-item">
                <div class="faq-question">What is Silver Mercury used for? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">Silver Liquid Mercury is widely used in gold mining and extraction, dental amalgams, medical devices, manufacturing of industrial instruments, thermometers, barometers, and scientific laboratory research.</div></div>
              </div>
              <div class="faq-item">
                <div class="faq-question">Do you provide product samples? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">Sample orders may be available depending on the product. Minimum order quantities apply. Please contact us with your specific requirements for sample pricing and availability.</div></div>
              </div>
              <div class="faq-item">
                <div class="faq-question">Do you offer bulk discounts? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">Yes, we offer competitive wholesale pricing for bulk orders. Contact our sales team with your quantity requirements for custom pricing.</div></div>
              </div>
            </div>
          </div>

          <!-- Ordering -->
          <div class="faq-category" id="ordering">
            <h3><i class="fas fa-shopping-cart"></i> Ordering & Payment</h3>
            <div class="faq-list">
              <div class="faq-item">
                <div class="faq-question">How do I place an order? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">Submit a quote request through our <a href="/contact">contact form</a> or email us at info@useful-chemicals.com. Include the product, quantity, and delivery destination. We'll respond with a Proforma Invoice within 24 hours.</div></div>
              </div>
              <div class="faq-item">
                <div class="faq-question">What payment methods do you accept? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">We accept bank wire transfers and cryptocurrency (Bitcoin). Payment details are provided on the Proforma Invoice. Bank transfers may take up to 5 business days to process.</div></div>
              </div>
              <div class="faq-item">
                <div class="faq-question">What is a Proforma Invoice? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">A Proforma Invoice is a preliminary invoice sent before the sale is finalized. It includes product details, pricing, shipping costs, payment instructions, and estimated delivery timeline. It serves as a formal quote and order confirmation.</div></div>
              </div>
              <div class="faq-item">
                <div class="faq-question">Can I cancel my order? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">Orders may be canceled before shipment. Once the product has been dispatched, cancellation is no longer possible. Please contact us as soon as possible if you need to modify or cancel an order.</div></div>
              </div>
            </div>
          </div>

          <!-- Shipping -->
          <div class="faq-category" id="shipping">
            <h3><i class="fas fa-truck"></i> Shipping & Delivery</h3>
            <div class="faq-list">
              <div class="faq-item">
                <div class="faq-question">Do you ship internationally? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">Yes, we ship worldwide from our facility in Essen, Germany. We deliver to Europe, Asia, Africa, North and South America, and Oceania using licensed hazardous materials carriers.</div></div>
              </div>
              <div class="faq-item">
                <div class="faq-question">How long does delivery take? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">Delivery timelines vary by destination: Germany 1–3 days, EU 3–7 days, North America 7–14 days, Asia 10–21 days. Full details are on our <a href="/shipping">Shipping page</a>. Tracking is provided with every order.</div></div>
              </div>
              <div class="faq-item">
                <div class="faq-question">Is the packaging discreet? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">All products are shipped in UN-approved packaging with proper hazmat labeling as required by international transport regulations. We also offer specialized discreet packaging solutions — contact us for details.</div></div>
              </div>
              <div class="faq-item">
                <div class="faq-question">Do you provide tracking information? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">Yes, tracking details are provided for all shipments. You'll receive tracking information via email once your order has been dispatched.</div></div>
              </div>
              <div class="faq-item">
                <div class="faq-question">What happens if my shipment is delayed by customs? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">Customs processing times are outside our control, but we provide comprehensive documentation (SDS, COA, TDS, customs declarations) to facilitate smooth clearance. Our team can assist with any customs-related inquiries.</div></div>
              </div>
            </div>
          </div>

          <!-- Safety -->
          <div class="faq-category" id="safety">
            <h3><i class="fas fa-shield-halved"></i> Safety & Handling</h3>
            <div class="faq-list">
              <div class="faq-item">
                <div class="faq-question">Are your products safe to handle? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">Our products are safe when handled according to the Safety Data Sheet (SDS) guidelines provided with every order. Proper personal protective equipment (PPE), ventilation, and storage conditions must be maintained at all times.</div></div>
              </div>
              <div class="faq-item">
                <div class="faq-question">What PPE is required? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">At minimum, protective gloves, safety goggles, and a lab coat or protective clothing are required. For mercury products, work in well-ventilated areas or use respiratory protection to avoid vapor inhalation. Full PPE requirements are detailed in each product's SDS.</div></div>
              </div>
              <div class="faq-item">
                <div class="faq-question">How should chemicals be stored? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">Store in a cool, dry, well-ventilated area away from direct sunlight and incompatible materials. Keep containers tightly sealed when not in use. Follow all storage guidelines in the product's Safety Data Sheet.</div></div>
              </div>
              <div class="faq-item">
                <div class="faq-question">What should I do in case of a spill? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">Evacuate the area and ventilate. Do not touch or walk through spilled material. Use appropriate spill kits for containment. For mercury spills, use mercury spill kits and avoid vacuuming. Refer to the SDS for detailed emergency procedures and contact local hazardous waste authorities if necessary.</div></div>
              </div>
            </div>
          </div>

          <!-- Compliance -->
          <div class="faq-category" id="compliance">
            <h3><i class="fas fa-file-lines"></i> Compliance & Documentation</h3>
            <div class="faq-list">
              <div class="faq-item">
                <div class="faq-question">Do you provide Certificates of Analysis (COA)? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">Yes, a Certificate of Analysis (COA) is provided with every order, verifying product purity, composition, and batch-specific quality data.</div></div>
              </div>
              <div class="faq-item">
                <div class="faq-question">Do you provide Safety Data Sheets (SDS)? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">Yes, Safety Data Sheets compliant with GHS and EU REACH regulations are provided with all shipments. SDS documents include hazard identification, first aid measures, handling and storage instructions, and disposal considerations.</div></div>
              </div>
              <div class="faq-item">
                <div class="faq-question">Are you REACH compliant? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">Yes, we comply with EU REACH Regulation (EC 1907/2006) and the EU Mercury Regulation (EU 2017/852). All products meet applicable EU chemical safety and registration requirements.</div></div>
              </div>
              <div class="faq-item">
                <div class="faq-question">Do I need a license to purchase your products? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">Requirements vary by country and product. Some jurisdictions require permits or end-use declarations for mercury products. Our team can help you understand the requirements for your specific location and intended use.</div></div>
              </div>
              <div class="faq-item">
                <div class="faq-question">Do you provide Technical Data Sheets (TDS)? <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">Yes, Technical Data Sheets with detailed chemical specifications, physical properties, and application guidelines are available for all products. Contact us or visit individual product pages for TDS information.</div></div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container text-center">
      <h2>Still Have Questions?</h2>
      <p>Our team is ready to help with any product, ordering, or technical questions.</p>
      <div class="cta-actions">
        <a href="/contact" class="btn btn-accent">Contact Us <i class="fas fa-arrow-right"></i></a>
        <a href="/products" class="btn btn-outline">Browse Products <i class="fas fa-arrow-right"></i></a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .faq-page { padding: 80px 0; }
  .faq-page-grid { display: grid; grid-template-columns: 240px 1fr; gap: 50px; }

  /* Sidebar */
  .faq-sidebar { position: sticky; top: 100px; }
  .faq-sidebar h5 { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--body-text); margin-bottom: 16px; }
  .faq-cat-link { display: flex; align-items: center; gap: 10px; padding: 10px 14px; border-radius: 8px; color: var(--body-text); font-size: 0.9rem; font-weight: 500; transition: all 0.2s; text-decoration: none; }
  .faq-cat-link:hover, .faq-cat-link.active { background: var(--primary); color: #fff; }
  .faq-cat-link i { width: 18px; text-align: center; }

  /* FAQ Main */
  .faq-category { margin-bottom: 50px; }
  .faq-category h3 { font-size: 1.3rem; margin-bottom: 24px; display: flex; align-items: center; gap: 10px; padding-bottom: 12px; border-bottom: 2px solid var(--primary); }
  .faq-category h3 i { color: var(--primary); }

  /* CTA */
  .cta-section { padding: 80px 0; background: var(--dark); }
  .cta-section h2 { color: #fff; margin-bottom: 16px; }
  .cta-section p { color: rgba(255,255,255,0.7); margin-bottom: 30px; }
  .cta-actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }

  @media (max-width: 768px) {
    .faq-page-grid { grid-template-columns: 1fr; gap: 30px; }
    .faq-sidebar { position: static; display: flex; flex-wrap: wrap; gap: 8px; }
    .faq-sidebar h5 { width: 100%; }
  }
</style>
