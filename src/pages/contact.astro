---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact Us – Get a Quote Today" description="Contact UE Chemicals in Essen, Germany for product inquiries, quotes & technical support. Reach our team for Caluanie, Red Mercury & Silver Mercury orders." activePage="contact">

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="section-label">Get in Touch</div>
      <h1>Contact UE Chemicals</h1>
      <p>Whether you have questions about our products, need technical support, or are ready to place an order, our team is ready to assist you.</p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="quote-section">
    <div class="container">
      <div class="quote-grid">
        <!-- Contact Info -->
        <div>
          <div class="section-label">Have Questions?</div>
          <h2 class="section-title">Contact Information</h2>
          <p>Contact us today for personalized service from experts in industrial chemical solutions. We're here to help with product inquiries, order details, and technical support.</p>

          <div class="contact-info-list">
            <div class="contact-info-item">
              <i class="fas fa-map-marker-alt"></i>
              <span>104 Essen, 45001, Germany</span>
            </div>
            <div class="contact-info-item">
              <i class="fas fa-envelope"></i>
              <span>Email: info@useful-chemicals.com</span>
            </div>
          </div>

          <!-- Map Placeholder -->
          <div style="margin-top:30px;background:var(--white);border:1px solid var(--border);height:250px;display:flex;align-items:center;justify-content:center;color:var(--body-text);">
            <div style="text-align:center;">
              <i class="fas fa-map" style="font-size:2.5rem;margin-bottom:10px;display:block;color:var(--accent);"></i>
              <p style="margin:0;font-size:0.9rem;">Essen, 45001, Germany</p>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div>
          <div class="product-specs">
            <h4 style="margin-bottom:25px;">Send Us a Message</h4>
            <div id="formStatus" style="display:none;padding:12px 16px;margin-bottom:20px;border-radius:6px;font-size:0.95rem;"></div>
            <form id="contactForm">
              <div class="form-group">
                <label>Full Name</label>
                <input type="text" name="name" class="form-control" placeholder="Your full name" required>
              </div>
              <div class="form-group">
                <label>Email Address</label>
                <input type="email" name="email" class="form-control" placeholder="Your email address" required>
              </div>
              <div class="form-group">
                <label>Phone Number</label>
                <div class="phone-input">
                  <select name="phoneCode" class="form-control">
                    <option>+49 DE</option>
                    <option>+1 USA</option>
                    <option>+44 UK</option>
                    <option>+61 AU</option>
                    <option>+33 FR</option>
                    <option>+237 CM</option>
                  </select>
                  <input type="tel" name="phone" class="form-control" placeholder="Phone number">
                </div>
              </div>
              <div class="form-group">
                <label>Select Product</label>
                <select name="product" class="form-control">
                  <option>Select Product</option>
                  <option>Caluanie Muelear Oxidize</option>
                  <option>Red Liquid Mercury</option>
                  <option>Silver Liquid Mercury</option>
                </select>
              </div>
              <div class="form-group">
                <label>Message</label>
                <textarea name="message" class="form-control" placeholder="How can we help you?" rows="5" required></textarea>
              </div>
              <button type="submit" id="submitBtn" class="btn btn-primary" style="width:100%;justify-content:center;">Send</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('contactForm') as HTMLFormElement;
    const status = document.getElementById('formStatus') as HTMLDivElement;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
      status.style.display = 'none';

      const formData = new FormData(form);
      const phoneCode = (formData.get('phoneCode') as string)?.split(' ')[0] || '';
      const phoneNum = formData.get('phone') as string || '';

      const body = {
        name: formData.get('name'),
        email: formData.get('email'),
        phone: phoneNum ? `${phoneCode} ${phoneNum}` : '',
        product: formData.get('product'),
        message: formData.get('message'),
      };

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });

        const result = await res.json();

        if (res.ok) {
          status.style.display = 'block';
          status.style.background = '#d4edda';
          status.style.color = '#155724';
          status.textContent = 'Message sent successfully! We will get back to you soon.';
          form.reset();
        } else {
          status.style.display = 'block';
          status.style.background = '#f8d7da';
          status.style.color = '#721c24';
          status.textContent = result.error || 'Something went wrong. Please try again.';
        }
      } catch {
        status.style.display = 'block';
        status.style.background = '#f8d7da';
        status.style.color = '#721c24';
        status.textContent = 'Network error. Please check your connection and try again.';
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send';
      }
    });
  </script>

</BaseLayout>
