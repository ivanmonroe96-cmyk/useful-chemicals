---
import BaseLayout from '../../layouts/BaseLayout.astro';

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Red Liquid Mercury 99.999% (5N Grade)",
  "description": "High-purity Red Liquid Mercury (Sb₂O₇Hg₂) with 99.999% purity for industrial and research applications. Manufactured in Thailand by UE Chemicals.",
  "brand": { "@type": "Brand", "name": "UE Chemicals" },
  "manufacturer": { "@type": "Organization", "name": "UE Chemicals", "address": { "@type": "PostalAddress", "addressLocality": "Bangkok", "addressCountry": "TH" } },
  "sku": "UEC-RLM-5N",
  "material": "Sb₂O₇Hg₂",
  "additionalProperty": [
    { "@type": "PropertyValue", "name": "Purity", "value": "99.999% (5N)" },
    { "@type": "PropertyValue", "name": "Density", "value": "20.2 g/cm³" },
    { "@type": "PropertyValue", "name": "Formula", "value": "Sb₂O₇Hg₂" }
  ],
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "price": "0",
    "priceValidUntil": "2026-12-31",
    "url": "https://useful-chemicals.com/products/red-mercury",
    "seller": { "@type": "Organization", "name": "UE Chemicals" }
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What is red mercury?", "acceptedAnswer": { "@type": "Answer", "text": "Red mercury refers to Red Liquid Mercury with the chemical formula Sb₂O₇Hg₂. It is a high-density substance (20.2 g/cm³) with 99.999% purity (5N grade) used in specialized industrial and research applications. UE Chemicals supplies certified Red Liquid Mercury with full documentation." } },
    { "@type": "Question", "name": "What is red mercury used for?", "acceptedAnswer": { "@type": "Answer", "text": "Red Liquid Mercury is used in specialized industrial processes, advanced research applications, and certain chemical synthesis procedures. Its unique chemical properties and high density make it suitable for precision applications requiring extremely pure compounds." } },
    { "@type": "Question", "name": "Is it legal to buy red liquid mercury?", "acceptedAnswer": { "@type": "Answer", "text": "Regulations for purchasing Red Liquid Mercury vary by country and jurisdiction. UE Chemicals ensures full regulatory compliance and can provide guidance on legal requirements for your region. Contact our team for specific compliance information." } },
    { "@type": "Question", "name": "How can I ensure authenticity of red mercury?", "acceptedAnswer": { "@type": "Answer", "text": "Purchase from verified, reputable suppliers like UE Chemicals who provide detailed certification, Certificate of Analysis (COA), and quality documentation with every order. Our Red Liquid Mercury is tested for 99.999% purity before shipping." } },
    { "@type": "Question", "name": "What safety precautions should I follow for red mercury?", "acceptedAnswer": { "@type": "Answer", "text": "Always wear appropriate PPE including chemical-resistant gloves, safety goggles, and protective clothing. Handle in well-ventilated areas, store in a cool dry place away from incompatible materials, and follow EPA or local guidelines for safe handling and disposal." } },
    { "@type": "Question", "name": "Can I buy red mercury online?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, you can purchase Red Liquid Mercury online from UE Chemicals at useful-chemicals.com. We offer worldwide shipping with secure packaging, full compliance documentation, and Certificate of Analysis for every order." } },
    { "@type": "Question", "name": "What are the chemical properties of red mercury?", "acceptedAnswer": { "@type": "Answer", "text": "Red Liquid Mercury (Sb₂O₇Hg₂) has a density of 20.2 g/cm³, purity of 99.999% (5N grade), and distinctive red coloration. It is supplied in liquid form with verified composition confirmed by Certificate of Analysis." } }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://useful-chemicals.com/" },
    { "@type": "ListItem", "position": 2, "name": "Products", "item": "https://useful-chemicals.com/products" },
    { "@type": "ListItem", "position": 3, "name": "Red Liquid Mercury", "item": "https://useful-chemicals.com/products/red-mercury" }
  ]
};
---

<BaseLayout title="Buy Red Liquid Mercury 99.999% | Red Mercury for Sale" description="Buy Red Liquid Mercury (Sb₂O₇Hg₂) with 99.999% purity from UE Chemicals. What is red mercury used for? Industrial and research applications. Red mercury for sale with certified quality and worldwide shipping." activePage="products" jsonLd={[productSchema, faqSchema, breadcrumbSchema]}>

  <!-- ========== HERO ========== -->
  <section class="pd-hero">
    <div class="pd-hero-bg">
      <img src="/images/buy-red-liquid-mercury-usa.jpg" alt="Buy Red Liquid Mercury for sale - 99.999% purity" />
      <div class="pd-hero-overlay"></div>
    </div>
    <div class="container pd-hero-inner">
      <div class="pd-hero-content">
        <div class="pd-hero-badge"><i class="fas fa-flask"></i> Product Details</div>
        <h1>Red Liquid Mercury for Sale</h1>
        <p class="pd-hero-sub">Buy Red Liquid Mercury (Sb₂O₇Hg₂) with 99.999% purity. Used in research, industrial and specialized applications. Certified quality from a verified, reputable supplier.</p>
        <div class="pd-hero-actions">
          <a href="/contact" class="btn btn-accent">Get a Quote <i class="fas fa-arrow-right"></i></a>
          <a href="/safety" class="btn btn-outline-white">Safety Info <i class="fas fa-arrow-right"></i></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== KEY SPECS BAR ========== -->
  <section class="pd-specs-bar">
    <div class="container">
      <div class="pd-specs-row">
        <div class="pd-spec-item">
          <span class="pd-spec-label">Application</span>
          <span class="pd-spec-value">Research &amp; Industrial</span>
        </div>
        <div class="pd-spec-item">
          <span class="pd-spec-label">Purity</span>
          <span class="pd-spec-value">99.999% (5N)</span>
        </div>
        <div class="pd-spec-item">
          <span class="pd-spec-label">Pricing</span>
          <span class="pd-spec-value">Request Quote</span>
        </div>
        <div class="pd-spec-item">
          <span class="pd-spec-label">Availability</span>
          <span class="pd-spec-value">In Stock</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== OVERVIEW SPLIT ========== -->
  <section class="pd-overview">
    <div class="pd-overview-image">
      <img src="/images/red-liquid-mercury-for-sale-usa.png" alt="Red Liquid Mercury" />
    </div>
    <div class="pd-overview-content">
      <div class="section-label">Overview</div>
      <h2>What Is Red Liquid Mercury?</h2>
      <p>Red liquid mercury is a term often used to describe a rare substance with unique properties. This product is mainly used in specific industries that require its unique chemical makeup.</p>
      <p>Before purchasing, it's essential to understand the exact purpose, potential applications, and safety measures associated with it. Our team provides full guidance on proper use and handling.</p>
      <div class="pd-overview-features">
        <div class="pd-overview-feat">
          <div class="pd-overview-feat-icon"><i class="fas fa-check-circle"></i></div>
          <div>
            <h6>Quality Assured</h6>
            <p>Our product is sourced from reputable suppliers and meets all regulatory standards.</p>
          </div>
        </div>
        <div class="pd-overview-feat">
          <div class="pd-overview-feat-icon"><i class="fas fa-check-circle"></i></div>
          <div>
            <h6>Detailed Certification</h6>
            <p>We provide detailed certification with every purchase for your records.</p>
          </div>
        </div>
        <div class="pd-overview-feat">
          <div class="pd-overview-feat-icon"><i class="fas fa-check-circle"></i></div>
          <div>
            <h6>Customer Service</h6>
            <p>Our customer service team is available to help with any questions about authenticity, safety, and use.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TECHNICAL SPECIFICATIONS ========== -->
  <section class="pd-tech-specs">
    <div class="container">
      <div class="pd-tech-grid">
        <div class="pd-tech-content">
          <div class="section-label">Technical Data</div>
          <h2>Chemical Specifications</h2>
          <p>Detailed technical specifications for Red Liquid Mercury as verified by our quality control laboratory.</p>
        </div>
        <div class="pd-tech-table-wrap">
          <table class="pd-tech-table">
            <tbody>
              <tr><td>Chemical Name</td><td>Antimony Mercury Oxide</td></tr>
              <tr><td>Molecular Formula</td><td>Sb₂O₇Hg₂</td></tr>
              <tr><td>Appearance</td><td>Cherry red metallic liquid</td></tr>
              <tr><td>Purity</td><td>99.999% (5N)</td></tr>
              <tr><td>Density</td><td>20.2 g/cm³</td></tr>
              <tr><td>Molar Mass</td><td>756.70 g/mol</td></tr>
              <tr><td>Melting Point</td><td>-37.67°C</td></tr>
              <tr><td>Boiling Point</td><td>356.72°C</td></tr>
              <tr><td>Flash Point</td><td>170.03°C</td></tr>
              <tr><td>CAS Number</td><td>7439-97-6 (Hg base)</td></tr>
              <tr><td>UN Number</td><td>UN2809</td></tr>
              <tr><td>Hazard Class</td><td>8 (Corrosive) / 6.1 (Toxic)</td></tr>
              <tr><td>Packing Group</td><td>III</td></tr>
              <tr><td>Pack Sizes</td><td>1 kg, 5 kg, 17.5 kg, 34.5 kg</td></tr>
            </tbody>
          </table>
        </div>
      </div>
      <div class="pd-docs-row">
        <div class="pd-doc-card">
          <i class="fas fa-file-pdf"></i>
          <div>
            <h5>Technical Data Sheet (TDS)</h5>
            <p>Complete chemical specifications and physical properties.</p>
          </div>
          <a href="/contact" class="btn btn-outline btn-sm">Request TDS <i class="fas fa-download"></i></a>
        </div>
        <div class="pd-doc-card">
          <i class="fas fa-file-shield"></i>
          <div>
            <h5>Safety Data Sheet (SDS)</h5>
            <p>Hazard identification, handling, and emergency procedures.</p>
          </div>
          <a href="/contact" class="btn btn-outline btn-sm">Request SDS <i class="fas fa-download"></i></a>
        </div>
        <div class="pd-doc-card">
          <i class="fas fa-file-certificate"></i>
          <div>
            <h5>Certificate of Analysis (COA)</h5>
            <p>Batch-specific purity and quality verification.</p>
          </div>
          <a href="/contact" class="btn btn-outline btn-sm">Request COA <i class="fas fa-download"></i></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== APPLICATIONS ========== -->
  <section class="pd-apps">
    <div class="container">
      <div class="text-center" style="margin-bottom:60px;">
        <div class="section-label">Applications</div>
        <h2>Why Choose Red Liquid Mercury?</h2>
      </div>
      <div class="pd-apps-grid">
        <div class="pd-app-card">
          <div class="pd-app-num">01</div>
          <h5>Research &amp; Industrial</h5>
          <p>Red liquid mercury can be used in research, industrial, and educational settings. Its unique chemical properties make it valuable for specialized applications.</p>
        </div>
        <div class="pd-app-card">
          <div class="pd-app-num">02</div>
          <h5>Safety &amp; Handling</h5>
          <p>Due to its hazardous nature, it requires careful handling and storage. We provide complete safety documentation and handling guidelines with every order.</p>
        </div>
        <div class="pd-app-card">
          <div class="pd-app-num">03</div>
          <h5>Verified Authenticity</h5>
          <p>With the rarity of this substance, ensuring you're purchasing from a trustworthy source is crucial. Every order includes verification and certification documents.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== BUYING GUIDE (DARK) ========== -->
  <section class="pd-benefits">
    <div class="container">
      <div class="pd-benefits-grid">
        <div class="pd-benefits-content">
          <div class="section-label">Buying Guide</div>
          <h2>How to Buy<br />Safely</h2>
          <p>Ensure a safe and compliant purchasing experience by following these key guidelines.</p>
        </div>
        <div class="pd-benefits-cards">
          <div class="pd-benefit-card">
            <div class="pd-benefit-num">01</div>
            <div>
              <h5>Find a Reputable Seller</h5>
              <p>Look for verified sellers with high ratings and positive reviews. UE Chemicals provides full transparency and certification.</p>
            </div>
          </div>
          <div class="pd-benefit-card">
            <div class="pd-benefit-num">02</div>
            <div>
              <h5>Check Legality</h5>
              <p>Regulations can vary by state. Verify legal requirements and any import/export restrictions in your region before ordering.</p>
            </div>
          </div>
          <div class="pd-benefit-card">
            <div class="pd-benefit-num">03</div>
            <div>
              <h5>Ensure Proper Shipping</h5>
              <p>Verify that the seller follows strict safety guidelines for storage and shipment. All our packaging meets industry safety standards.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== SAFETY ========== -->
  <section class="pd-safety">
    <div class="container">
      <div class="pd-safety-inner">
        <div class="pd-safety-text">
          <div class="section-label">Safety &amp; Handling</div>
          <h2>Handling Information</h2>
          <p>Follow these important safety and handling guidelines to ensure safe use of Red Liquid Mercury.</p>
        </div>
        <div class="pd-safety-items">
          <div class="pd-safety-item">
            <i class="fas fa-box"></i>
            <span><strong>Storage:</strong> Keep in a cool, dry area away from sunlight and incompatible materials.</span>
          </div>
          <div class="pd-safety-item">
            <i class="fas fa-shield-halved"></i>
            <span><strong>Handling:</strong> Use protective gloves and eye protection when handling at all times.</span>
          </div>
          <div class="pd-safety-item">
            <i class="fas fa-recycle"></i>
            <span><strong>Disposal:</strong> Follow EPA or local guidelines for hazardous waste disposal procedures.</span>
          </div>
          <div class="pd-safety-item">
            <i class="fas fa-file-lines"></i>
            <span><strong>Documentation:</strong> Safety Data Sheets (SDS) provided with every shipment for reference.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== QUOTE FORM ========== -->
  <section class="pd-quote">
    <div class="container">
      <div class="pd-quote-grid">
        <div class="pd-quote-text">
          <div class="section-label">Get Started</div>
          <h2>Request a Quote</h2>
          <p>Ready to order Red Liquid Mercury? Fill out the form and our team will respond with a customized quote within 24 hours.</p>
          <div class="pd-quote-badges">
            <div class="pd-quote-badge"><i class="fas fa-clock"></i> 24hr Response</div>
            <div class="pd-quote-badge"><i class="fas fa-lock"></i> Secure &amp; Private</div>
            <div class="pd-quote-badge"><i class="fas fa-certificate"></i> Full Certification</div>
          </div>
        </div>
        <div class="pd-quote-form-wrap">
          <form>
            <div class="form-group">
              <label>Full Name</label>
              <input type="text" name="name" class="form-control" placeholder="Your full name" required>
            </div>
            <div class="form-group">
              <label>Email Address</label>
              <input type="email" name="email" class="form-control" placeholder="Your email address" required>
            </div>
            <div class="form-group">
              <label>Phone Number</label>
              <div class="phone-input">
                <select class="form-control">
                  <option>+49 DE</option>
                  <option>+1 USA</option>
                  <option>+44 UK</option>
                  <option>+61 AU</option>
                  <option>+33 FR</option>
                </select>
                <input type="tel" name="phone" class="form-control" placeholder="Phone number">
              </div>
            </div>
            <input type="hidden" name="product" value="Red Liquid Mercury">
            <div class="form-group">
              <label>Message</label>
              <textarea name="message" class="form-control" placeholder="Tell us about your desired quantity, intended use, delivery location, or any special requirements..." rows="4"></textarea>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">Request Quote <i class="fas fa-arrow-right"></i></button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="faq-section">
    <div class="container">
      <div class="faq-row">
        <div class="faq-content-col">
          <div class="section-label">Common Concerns</div>
          <h2 class="section-title">Common Concerns About Red Liquid Mercury</h2>
          <div class="faq-list">
            <div class="faq-item">
              <div class="faq-question">Is it legal to buy? <i class="fas fa-chevron-down"></i></div>
              <div class="faq-answer"><div class="faq-answer-inner">Depending on the state, there may be regulations for purchasing and handling. Check with your local authorities to confirm compliance.</div></div>
            </div>
            <div class="faq-item">
              <div class="faq-question">How can I ensure authenticity? <i class="fas fa-chevron-down"></i></div>
              <div class="faq-answer"><div class="faq-answer-inner">Purchase from verified, reputable suppliers like UE Chemicals who provide detailed certification and quality documentation with every order.</div></div>
            </div>
            <div class="faq-item">
              <div class="faq-question">What safety precautions should I follow? <i class="fas fa-chevron-down"></i></div>
              <div class="faq-answer"><div class="faq-answer-inner">Always wear appropriate PPE including gloves and eye protection. Store in a cool, dry area and follow EPA or local guidelines for disposal.</div></div>
            </div>
            <div class="faq-item">
              <div class="faq-question">Can I import from overseas? <i class="fas fa-chevron-down"></i></div>
              <div class="faq-answer"><div class="faq-answer-inner">Import regulations vary by country and state. Contact our team for guidance on international shipping and compliance requirements.</div></div>
            </div>
          </div>
        </div>
        <div class="faq-image-col">
          <img src="/images/buy-red-liquid-mercury-usa.jpg" alt="Red Liquid Mercury" />
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .pd-hero { position: relative; min-height: 70vh; display: flex; align-items: center; overflow: hidden; }
  .pd-hero-bg { position: absolute; inset: 0; z-index: 0; }
  .pd-hero-bg img { width: 100%; height: 100%; object-fit: cover; }
  .pd-hero-overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(25,24,23,0.94) 0%, rgba(25,24,23,0.8) 50%, rgba(25,24,23,0.65) 100%); }
  .pd-hero-inner { position: relative; z-index: 1; padding-top: 140px; padding-bottom: 80px; }
  .pd-hero-content { max-width: 650px; }
  .pd-hero-badge { display: inline-flex; align-items: center; gap: 10px; padding: 8px 20px; border: 1px solid rgba(255,255,255,0.2); font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: rgba(255,255,255,0.8); margin-bottom: 24px; }
  .pd-hero-badge i { color: var(--accent); font-size: 13px; }
  .pd-hero h1 { color: var(--white); font-size: clamp(36px, 5vw, 68px); line-height: 1.05; margin-bottom: 20px; letter-spacing: -1px; }
  .pd-hero-sub { color: rgba(255,255,255,0.65); font-size: 18px; line-height: 1.7; max-width: 500px; margin-bottom: 36px; }
  .pd-hero-actions { display: flex; gap: 16px; flex-wrap: wrap; }
  .btn-outline-white { background: transparent; color: var(--white); border: 2px solid rgba(255,255,255,0.3); }
  .btn-outline-white:hover { background: var(--white); color: var(--near-black); border-color: var(--white); }

  /* Specs Bar */
  .pd-specs-bar { background: var(--near-black); padding: 0; border-bottom: 1px solid rgba(255,255,255,0.06); }
  .pd-specs-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; }
  .pd-spec-item { padding: 28px 24px; border-left: 1px solid rgba(255,255,255,0.08); display: flex; flex-direction: column; gap: 4px; }
  .pd-spec-item:last-child { border-right: 1px solid rgba(255,255,255,0.08); }
  .pd-spec-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: rgba(255,255,255,0.4); }
  .pd-spec-value { font-size: 15px; font-weight: 700; color: var(--white); }

  /* Overview Split */
  .pd-overview { display: grid; grid-template-columns: 1fr 1fr; min-height: 600px; }
  .pd-overview-image { overflow: hidden; }
  .pd-overview-image img { width: 100%; height: 100%; object-fit: cover; }
  .pd-overview-content { padding: 80px 60px; display: flex; flex-direction: column; justify-content: center; background: var(--light-bg); }
  .pd-overview-content h2 { font-size: clamp(24px, 3vw, 38px); margin-bottom: 20px; line-height: 1.15; }
  .pd-overview-content > p { max-width: 480px; }
  .pd-overview-features { margin-top: 30px; display: flex; flex-direction: column; gap: 20px; }
  .pd-overview-feat { display: flex; gap: 14px; align-items: flex-start; }
  .pd-overview-feat-icon { color: var(--near-black); font-size: 16px; margin-top: 2px; flex-shrink: 0; }
  .pd-overview-feat h6 { font-size: 15px; margin-bottom: 3px; }
  .pd-overview-feat p { font-size: 14px; margin: 0; color: var(--body-text); }

  /* Tech Specs */
  .pd-tech-specs { padding: 100px 0; background: var(--white); border-top: 1px solid var(--border); }
  .pd-tech-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 50px; align-items: start; margin-bottom: 50px; }
  .pd-tech-content h2 { font-size: clamp(24px, 3vw, 38px); margin-bottom: 16px; line-height: 1.15; }
  .pd-tech-content p { color: var(--body-text); }
  .pd-tech-table-wrap { overflow-x: auto; }
  .pd-tech-table { width: 100%; border-collapse: collapse; background: var(--surface); border-radius: 8px; overflow: hidden; }
  .pd-tech-table td { padding: 12px 18px; border-bottom: 1px solid var(--border-light); font-size: 0.9rem; }
  .pd-tech-table td:first-child { font-weight: 600; color: var(--heading); width: 40%; background: rgba(0,0,0,0.02); }
  .pd-tech-table td:last-child { color: var(--body-text); }
  .pd-tech-table tr:last-child td { border-bottom: none; }
  .pd-docs-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .pd-doc-card { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 12px; padding: 28px 24px; background: var(--surface); border: 1px solid var(--border-light); border-radius: 10px; }
  .pd-doc-card i { font-size: 1.8rem; color: var(--primary); flex-shrink: 0; }
  .pd-doc-card div { flex: 1; }
  .pd-doc-card h5 { font-size: 0.9rem; margin-bottom: 4px; }
  .pd-doc-card p { font-size: 0.8rem; color: var(--body-text); margin: 0; }
  .pd-doc-card .btn { margin-top: auto; }
  .btn-sm { padding: 8px 16px; font-size: 0.75rem; white-space: nowrap; }

  /* Applications */
  .pd-apps { padding: 120px 0; background: var(--white); border-top: 1px solid var(--border); }
  .pd-apps h2 { font-size: clamp(28px, 3.5vw, 50px); line-height: 1.15; }
  .pd-apps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; }
  .pd-app-card { padding: 50px 35px; border-left: 1px solid var(--border); transition: var(--transition); }
  .pd-app-card:last-child { border-right: 1px solid var(--border); }
  .pd-app-card:hover { background: var(--light-bg); }
  .pd-app-num { font-size: 14px; font-weight: 800; color: var(--accent); letter-spacing: 1px; margin-bottom: 16px; }
  .pd-app-card h5 { font-size: 17px; text-transform: uppercase; margin-bottom: 12px; }
