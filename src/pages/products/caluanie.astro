---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations, t, localizedPath } from '../../i18n/index';
import { defaultLang } from '../../i18n/languages';

const lang = defaultLang;
const tr = getTranslations(lang);
const lp = (path: string) => localizedPath(path, lang);
const techSpecs = [
  [t(tr, 'caluanie.tech_name'), t(tr, 'caluanie.tech_name_val')],
  [t(tr, 'caluanie.tech_type'), t(tr, 'caluanie.tech_type_val')],
  [t(tr, 'caluanie.tech_appearance'), t(tr, 'caluanie.tech_appearance_val')],
  [t(tr, 'caluanie.tech_application'), t(tr, 'caluanie.tech_application_val')],
  [t(tr, 'caluanie.tech_power'), t(tr, 'caluanie.tech_power_val')],
  [t(tr, 'caluanie.tech_density'), t(tr, 'caluanie.tech_density_val')],
  [t(tr, 'caluanie.tech_ph'), t(tr, 'caluanie.tech_ph_val')],
  [t(tr, 'caluanie.tech_solubility'), t(tr, 'caluanie.tech_solubility_val')],
  [t(tr, 'caluanie.tech_shelf'), t(tr, 'caluanie.tech_shelf_val')],
  [t(tr, 'caluanie.tech_packs'), t(tr, 'caluanie.tech_packs_val')],
  [t(tr, 'caluanie.tech_storage'), t(tr, 'caluanie.tech_storage_val')],
  [t(tr, 'caluanie.tech_origin'), t(tr, 'caluanie.tech_origin_val')],
];
const overviewFeatures = [
  { title: t(tr, 'caluanie.overview_feat1_title'), description: t(tr, 'caluanie.overview_feat1_desc') },
  { title: t(tr, 'caluanie.overview_feat2_title'), description: t(tr, 'caluanie.overview_feat2_desc') },
  { title: t(tr, 'caluanie.overview_feat3_title'), description: t(tr, 'caluanie.overview_feat3_desc') },
];
const benefitItems = [
  { title: t(tr, 'caluanie.ben1_title'), description: t(tr, 'caluanie.ben1_desc') },
  { title: t(tr, 'caluanie.ben2_title'), description: t(tr, 'caluanie.ben2_desc') },
  { title: t(tr, 'caluanie.ben3_title'), description: t(tr, 'caluanie.ben3_desc') },
  { title: t(tr, 'caluanie.ben4_title'), description: t(tr, 'caluanie.ben4_desc') },
];
const safetyItems = [
  t(tr, 'caluanie.safety1'),
  t(tr, 'caluanie.safety2'),
  t(tr, 'caluanie.safety3'),
  t(tr, 'caluanie.safety4'),
];
const faqItems = [
  { question: t(tr, 'caluanie.faq1_q'), answer: t(tr, 'caluanie.faq1_a') },
  { question: t(tr, 'caluanie.faq2_q'), answer: t(tr, 'caluanie.faq2_a') },
  { question: t(tr, 'caluanie.faq3_q'), answer: t(tr, 'caluanie.faq3_a') },
  { question: t(tr, 'caluanie.faq4_q'), answer: t(tr, 'caluanie.faq4_a') },
  { question: t(tr, 'caluanie.faq5_q'), answer: t(tr, 'caluanie.faq5_a') },
  { question: t(tr, 'caluanie.faq6_q'), answer: t(tr, 'caluanie.faq6_a') },
  { question: t(tr, 'caluanie.faq7_q'), answer: t(tr, 'caluanie.faq7_a') },
  { question: t(tr, 'caluanie.faq8_q'), answer: t(tr, 'caluanie.faq8_a') },
];

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": t(tr, 'nav.caluanie'),
  "description": t(tr, 'caluanie.meta_desc'),
  "brand": { "@type": "Brand", "name": "UE Chemicals" },
  "manufacturer": { "@type": "Organization", "name": "UE Chemicals", "address": { "@type": "PostalAddress", "addressLocality": "Bangkok", "addressCountry": "TH" } },
  "sku": "UEC-CMO-HQ",
  "additionalProperty": [
    { "@type": "PropertyValue", "name": t(tr, 'caluanie.spec_type_label'), "value": t(tr, 'caluanie.spec_type') },
    { "@type": "PropertyValue", "name": t(tr, 'caluanie.spec_app_label'), "value": t(tr, 'caluanie.spec_app') },
    { "@type": "PropertyValue", "name": t(tr, 'caluanie.tech_density'), "value": t(tr, 'caluanie.tech_density_val') }
  ],
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "price": "0",
    "priceValidUntil": "2026-12-31",
    "url": `https://useful-chemicals.com${lp('/products/caluanie')}`,
    "seller": { "@type": "Organization", "name": "UE Chemicals" }
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": { "@type": "Answer", "text": item.answer }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": t(tr, 'nav.home'), "item": `https://useful-chemicals.com${lp('/')}` },
    { "@type": "ListItem", "position": 2, "name": t(tr, 'nav.products'), "item": `https://useful-chemicals.com${lp('/products')}` },
    { "@type": "ListItem", "position": 3, "name": t(tr, 'nav.caluanie'), "item": `https://useful-chemicals.com${lp('/products/caluanie')}` }
  ]
};
---


<BaseLayout lang={lang} title={t(tr, "caluanie.meta_title")} description={t(tr, "caluanie.meta_desc")} activePage="products" jsonLd={[productSchema, faqSchema, breadcrumbSchema]}>

  <!-- ========== HERO ========== -->
  <section class="pd-hero">
    <div class="pd-hero-bg">
      <img src="/images/buy-new-stock-caluanie-muelear-oxidize.jpg" alt={t(tr, 'nav.caluanie')} />
      <div class="pd-hero-overlay"></div>
    </div>
    <div class="container pd-hero-inner">
      <div class="pd-hero-content">
        <div class="pd-hero-badge"><i class="fas fa-vial"></i> {t(tr, 'caluanie.hero_badge')}</div>
        <h1>{t(tr, "caluanie.hero_title")}</h1>
        <p class="pd-hero-sub">{t(tr, 'caluanie.hero_sub')}</p>
        <div class="pd-hero-actions">
          <a href={lp("/contact")} class="btn btn-accent">{t(tr, 'common.get_quote')} <i class="fas fa-arrow-right"></i></a>
          <a href={lp("/safety")} class="btn btn-outline-white">{t(tr, 'caluanie.safety_label')} <i class="fas fa-arrow-right"></i></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== KEY SPECS BAR ========== -->
  <section class="pd-specs-bar">
    <div class="container">
      <div class="pd-specs-row">
        <div class="pd-spec-item">
          <span class="pd-spec-label">{t(tr, 'caluanie.spec_type_label')}</span>
          <span class="pd-spec-value">{t(tr, "caluanie.spec_type")}</span>
        </div>
        <div class="pd-spec-item">
          <span class="pd-spec-label">{t(tr, 'caluanie.spec_app_label')}</span>
          <span class="pd-spec-value">{t(tr, "caluanie.spec_app")}</span>
        </div>
        <div class="pd-spec-item">
          <span class="pd-spec-label">{t(tr, 'caluanie.spec_price_label')}</span>
          <span class="pd-spec-value">{t(tr, "caluanie.spec_price")}</span>
        </div>
        <div class="pd-spec-item">
          <span class="pd-spec-label">{t(tr, 'caluanie.spec_avail_label')}</span>
          <span class="pd-spec-value">{t(tr, "caluanie.spec_avail")}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== OVERVIEW SPLIT ========== -->
  <section class="pd-overview">
    <div class="pd-overview-image">
      <img src="/images/caluanie-muelear-oxidize-for-sale.jpg" alt={t(tr, 'nav.caluanie')} />
    </div>
    <div class="pd-overview-content">
      <div class="section-label">{t(tr, "caluanie.overview_label")}</div>
      <h2>{t(tr, "caluanie.overview_title")}</h2>
      <p>{t(tr, 'caluanie.overview_desc1')}</p>
      <p>{t(tr, 'caluanie.overview_desc2')}</p>
      <div class="pd-overview-features">
        {overviewFeatures.map(feature => (
          <div class="pd-overview-feat">
            <div class="pd-overview-feat-icon"><i class="fas fa-check-circle"></i></div>
            <div>
              <h6>{feature.title}</h6>
              <p>{feature.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== TECHNICAL SPECIFICATIONS ========== -->
  <section class="pd-tech-specs">
    <div class="container">
      <div class="pd-tech-grid">
        <div class="pd-tech-content">
          <div class="section-label">{t(tr, "caluanie.tech_label")}</div>
          <h2>{t(tr, "caluanie.tech_title")}</h2>
          <p>{t(tr, 'caluanie.tech_desc')}</p>
        </div>
        <div class="pd-tech-table-wrap">
          <table class="pd-tech-table">
            <tbody>
              {techSpecs.map(([label, value]) => (
                <tr><td>{label}</td><td>{value}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
      <div class="pd-docs-row">
        <div class="pd-doc-card">
          <i class="fas fa-file-pdf"></i>
          <div>
            <h5>{t(tr, 'caluanie.doc_tds_title')}</h5>
            <p>{t(tr, 'caluanie.doc_tds_desc')}</p>
          </div>
          <a href="/docs/caluanie/UE-Chemicals-Caluanie-Muelear-Oxidize-TDS.pdf" download class="btn btn-outline btn-sm">{t(tr, 'caluanie.download_tds')} <i class="fas fa-download"></i></a>
        </div>
        <div class="pd-doc-card">
          <i class="fas fa-file-shield"></i>
          <div>
            <h5>{t(tr, 'caluanie.doc_sds_title')}</h5>
            <p>{t(tr, 'caluanie.doc_sds_desc')}</p>
          </div>
          <a href="/docs/caluanie/UE-Chemicals-Caluanie-Muelear-Oxidize-SDS.pdf" download class="btn btn-outline btn-sm">{t(tr, 'caluanie.download_sds')} <i class="fas fa-download"></i></a>
        </div>
        <div class="pd-doc-card">
          <i class="fas fa-file-certificate"></i>
          <div>
            <h5>{t(tr, 'caluanie.doc_coa_title')}</h5>
            <p>{t(tr, 'caluanie.doc_coa_desc')}</p>
          </div>
          <a href="/docs/caluanie/UE-Chemicals-Caluanie-Muelear-Oxidize-COA.pdf" download class="btn btn-outline btn-sm">{t(tr, 'caluanie.download_coa')} <i class="fas fa-download"></i></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== APPLICATIONS ========== -->
  <section class="pd-apps">
    <div class="container">
      <div class="text-center" style="margin-bottom:60px;">
        <div class="section-label">{t(tr, "caluanie.apps_label")}</div>
        <h2>{t(tr, "caluanie.apps_title")}</h2>
      </div>
      <div class="pd-apps-grid">
        <div class="pd-app-card">
          <div class="pd-app-num">01</div>
          <h5>{t(tr, "caluanie.app1_title")}</h5>
          <p>{t(tr, 'caluanie.app1_desc')}</p>
        </div>
        <div class="pd-app-card">
          <div class="pd-app-num">02</div>
          <h5>{t(tr, "caluanie.app2_title")}</h5>
          <p>{t(tr, 'caluanie.app2_desc')}</p>
        </div>
        <div class="pd-app-card">
          <div class="pd-app-num">03</div>
          <h5>{t(tr, "caluanie.app3_title")}</h5>
          <p>{t(tr, 'caluanie.app3_desc')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== BENEFITS (DARK) ========== -->
  <section class="pd-benefits">
    <div class="container">
      <div class="pd-benefits-grid">
        <div class="pd-benefits-content">
          <div class="section-label">{t(tr, "caluanie.benefits_label")}</div>
          <h2>{t(tr, 'caluanie.benefits_title')}</h2>
          <p>{t(tr, 'caluanie.benefits_desc')}</p>
        </div>
        <div class="pd-benefits-cards">
          {benefitItems.map((item, index) => (
            <div class="pd-benefit-card">
              <div class="pd-benefit-num">{String(index + 1).padStart(2, '0')}</div>
              <div>
                <h5>{item.title}</h5>
                <p>{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ========== SAFETY ========== -->
  <section class="pd-safety">
    <div class="container">
      <div class="pd-safety-inner">
        <div class="pd-safety-text">
          <div class="section-label">{t(tr, "caluanie.safety_label")}</div>
          <h2>{t(tr, "caluanie.safety_title")}</h2>
          <p>{t(tr, 'caluanie.safety_desc')}</p>
        </div>
        <div class="pd-safety-items">
          {safetyItems.map((item, index) => (
            <div class="pd-safety-item">
              <i class:list={[
                'fas',
                index === 0 ? 'fa-shield-halved' : index === 1 ? 'fa-box' : index === 2 ? 'fa-wind' : 'fa-file-lines'
              ]}></i>
              <span>{item}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ========== QUOTE FORM ========== -->
  <section class="pd-quote">
    <div class="container">
      <div class="pd-quote-grid">
        <div class="pd-quote-text">
          <div class="section-label">{t(tr, "caluanie.quote_label")}</div>
          <h2>{t(tr, "caluanie.quote_title")}</h2>
          <p>{t(tr, 'caluanie.quote_desc')}</p>
          <div class="pd-quote-badges">
            <div class="pd-quote-badge"><i class="fas fa-clock"></i> {t(tr, 'caluanie.quote_badge1')}</div>
            <div class="pd-quote-badge"><i class="fas fa-lock"></i> {t(tr, 'caluanie.quote_badge2')}</div>
            <div class="pd-quote-badge"><i class="fas fa-certificate"></i> {t(tr, 'caluanie.quote_badge3')}</div>
          </div>
        </div>
        <div class="pd-quote-form-wrap">
          <form>
            <div class="form-group">
              <label>{t(tr, 'caluanie.form_name')}</label>
              <input type="text" name="name" class="form-control" placeholder={t(tr, 'caluanie.form_placeholder_name')} required>
            </div>
            <div class="form-group">
              <label>{t(tr, 'caluanie.form_email')}</label>
              <input type="email" name="email" class="form-control" placeholder={t(tr, 'caluanie.form_placeholder_email')} required>
            </div>
            <div class="form-group">
              <label>{t(tr, 'caluanie.form_phone')}</label>
              <div class="phone-input">
                <select class="form-control">
                  <option>+49 DE</option>
                  <option>+1 USA</option>
                  <option>+44 UK</option>
                  <option>+61 AU</option>
                  <option>+33 FR</option>
                </select>
                <input type="tel" name="phone" class="form-control" placeholder={t(tr, 'caluanie.form_placeholder_phone')}>
              </div>
            </div>
            <input type="hidden" name="product" value={t(tr, 'nav.caluanie')}>
            <div class="form-group">
              <label>{t(tr, 'caluanie.form_message')}</label>
              <textarea name="message" class="form-control" placeholder={t(tr, 'caluanie.form_placeholder_message')} rows="4"></textarea>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">{t(tr, 'caluanie.form_submit')} <i class="fas fa-arrow-right"></i></button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="faq-section">
    <div class="container">
      <div class="faq-row">
        <div class="faq-content-col">
          <div class="section-label">{t(tr, "caluanie.faq_label")}</div>
          <h2 class="section-title">{t(tr, "caluanie.faq_title")}</h2>
          <div class="faq-list">
            {faqItems.map(item => (
              <div class="faq-item">
                <div class="faq-question">{item.question} <i class="fas fa-chevron-down"></i></div>
                <div class="faq-answer"><div class="faq-answer-inner">{item.answer}</div></div>
              </div>
            ))}
          </div>
        </div>
        <div class="faq-image-col">
          <img src="/images/buy-new-stock-caluanie-muelear-oxidize-usa.png" alt={t(tr, 'nav.caluanie')} />
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .pd-hero { position: relative; min-height: 70vh; display: flex; align-items: center; overflow: hidden; }
  .pd-hero-bg { position: absolute; inset: 0; z-index: 0; }
  .pd-hero-bg img { width: 100%; height: 100%; object-fit: cover; }
  .pd-hero-overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(25,24,23,0.94) 0%, rgba(25,24,23,0.8) 50%, rgba(25,24,23,0.65) 100%); }
  .pd-hero-inner { position: relative; z-index: 1; padding-top: 140px; padding-bottom: 80px; }
  .pd-hero-content { max-width: 650px; }
  .pd-hero-badge { display: inline-flex; align-items: center; gap: 10px; padding: 8px 20px; border: 1px solid rgba(255,255,255,0.2); font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: rgba(255,255,255,0.8); margin-bottom: 24px; }
  .pd-hero-badge i { color: var(--accent); font-size: 13px; }
  .pd-hero h1 { color: var(--white); font-size: clamp(36px, 5vw, 68px); line-height: 1.05; margin-bottom: 20px; letter-spacing: -1px; }
  .pd-hero-sub { color: rgba(255,255,255,0.65); font-size: 18px; line-height: 1.7; max-width: 500px; margin-bottom: 36px; }
  .pd-hero-actions { display: flex; gap: 16px; flex-wrap: wrap; }
  .btn-outline-white { background: transparent; color: var(--white); border: 2px solid rgba(255,255,255,0.3); }
  .btn-outline-white:hover { background: var(--white); color: var(--near-black); border-color: var(--white); }

  /* Specs Bar */
  .pd-specs-bar { background: var(--near-black); padding: 0; border-bottom: 1px solid rgba(255,255,255,0.06); }
  .pd-specs-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; }
  .pd-spec-item { padding: 28px 24px; border-left: 1px solid rgba(255,255,255,0.08); display: flex; flex-direction: column; gap: 4px; }
  .pd-spec-item:last-child { border-right: 1px solid rgba(255,255,255,0.08); }
  .pd-spec-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: rgba(255,255,255,0.4); }
  .pd-spec-value { font-size: 15px; font-weight: 700; color: var(--white); }

  /* Overview Split */
  .pd-overview { display: grid; grid-template-columns: 1fr 1fr; min-height: 600px; }
  .pd-overview-image { overflow: hidden; }
  .pd-overview-image img { width: 100%; height: 100%; object-fit: cover; }
  .pd-overview-content { padding: 80px 60px; display: flex; flex-direction: column; justify-content: center; background: var(--light-bg); }
  .pd-overview-content h2 { font-size: clamp(24px, 3vw, 38px); margin-bottom: 20px; line-height: 1.15; }
  .pd-overview-content > p { max-width: 480px; }
  .pd-overview-features { margin-top: 30px; display: flex; flex-direction: column; gap: 20px; }
  .pd-overview-feat { display: flex; gap: 14px; align-items: flex-start; }
  .pd-overview-feat-icon { color: var(--near-black); font-size: 16px; margin-top: 2px; flex-shrink: 0; }
  .pd-overview-feat h6 { font-size: 15px; margin-bottom: 3px; }
  .pd-overview-feat p { font-size: 14px; margin: 0; color: var(--body-text); }

  /* Tech Specs */
  .pd-tech-specs { padding: 100px 0; background: var(--white); border-top: 1px solid var(--border); }
  .pd-tech-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 50px; align-items: start; margin-bottom: 50px; }
  .pd-tech-content h2 { font-size: clamp(24px, 3vw, 38px); margin-bottom: 16px; line-height: 1.15; }
  .pd-tech-content p { color: var(--body-text); }
  .pd-tech-table-wrap { overflow-x: auto; }
  .pd-tech-table { width: 100%; border-collapse: collapse; background: var(--surface); border-radius: 8px; overflow: hidden; }
  .pd-tech-table td { padding: 12px 18px; border-bottom: 1px solid var(--border-light); font-size: 0.9rem; }
  .pd-tech-table td:first-child { font-weight: 600; color: var(--heading); width: 40%; background: rgba(0,0,0,0.02); }
  .pd-tech-table td:last-child { color: var(--body-text); }
  .pd-tech-table tr:last-child td { border-bottom: none; }
  .pd-docs-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .pd-doc-card { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 12px; padding: 28px 24px; background: var(--surface); border: 1px solid var(--border-light); border-radius: 10px; }
  .pd-doc-card i { font-size: 1.8rem; color: var(--primary); flex-shrink: 0; }
  .pd-doc-card div { flex: 1; }
  .pd-doc-card h5 { font-size: 0.9rem; margin-bottom: 4px; }
  .pd-doc-card p { font-size: 0.8rem; color: var(--body-text); margin: 0; }
  .pd-doc-card .btn { margin-top: auto; }
  .btn-sm { padding: 8px 16px; font-size: 0.75rem; white-space: nowrap; }

  /* Applications */
  .pd-apps { padding: 120px 0; background: var(--white); border-top: 1px solid var(--border); }
  .pd-apps h2 { font-size: clamp(28px, 3.5vw, 50px); line-height: 1.15; }
  .pd-apps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; }
  .pd-app-card { padding: 50px 35px; border-left: 1px solid var(--border); transition: var(--transition); }
  .pd-app-card:last-child { border-right: 1px solid var(--border); }
  .pd-app-card:hover { background: var(--light-bg); }
  .pd-app-num { font-size: 14px; font-weight: 800; color: var(--accent); letter-spacing: 1px; margin-bottom: 16px; }
  .pd-app-card h5 { font-size: 17px; text-transform: uppercase; margin-bottom: 12px; }
