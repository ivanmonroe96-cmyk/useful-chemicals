---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Caluanie Muelear Oxidize" activePage="products">

  <!-- ========== HERO ========== -->
  <section class="pd-hero">
    <div class="pd-hero-bg">
      <img src="/images/buy-new-stock-caluanie-muelear-oxidize.jpg" alt="" />
      <div class="pd-hero-overlay"></div>
    </div>
    <div class="container pd-hero-inner">
      <div class="pd-hero-content">
        <div class="pd-hero-badge"><i class="fas fa-vial"></i> Product Details</div>
        <h1>Caluanie<br />Muelear Oxidize</h1>
        <p class="pd-hero-sub">Premium-quality chemical for industrial processes. Now available with fresh stock, high purity, and reliable supply from our Essen facility.</p>
        <div class="pd-hero-actions">
          <a href="/contact" class="btn btn-accent">Get a Quote <i class="fas fa-arrow-right"></i></a>
          <a href="/safety" class="btn btn-outline-white">Safety Info <i class="fas fa-arrow-right"></i></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== KEY SPECS BAR ========== -->
  <section class="pd-specs-bar">
    <div class="container">
      <div class="pd-specs-row">
        <div class="pd-spec-item">
          <span class="pd-spec-label">Type</span>
          <span class="pd-spec-value">Liquid Oxidizer</span>
        </div>
        <div class="pd-spec-item">
          <span class="pd-spec-label">Application</span>
          <span class="pd-spec-value">Metalworking &amp; Refining</span>
        </div>
        <div class="pd-spec-item">
          <span class="pd-spec-label">Pricing</span>
          <span class="pd-spec-value">Request Quote</span>
        </div>
        <div class="pd-spec-item">
          <span class="pd-spec-label">Availability</span>
          <span class="pd-spec-value">In Stock</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== OVERVIEW SPLIT ========== -->
  <section class="pd-overview">
    <div class="pd-overview-image">
      <img src="/images/caluanie-muelear-oxidize-for-sale.jpg" alt="Caluanie Muelear Oxidize" />
    </div>
    <div class="pd-overview-content">
      <div class="section-label">Overview</div>
      <h2>What Is Caluanie Muelear Oxidize?</h2>
      <p>Caluanie Muelear Oxidize is a highly effective chemical used in the processing of metals and minerals. It is a key ingredient in various industrial applications, particularly in the extraction and refining of valuable metals.</p>
      <p>With our new stock guarantee, you can trust that our product is fresh, reliable, and ready to meet your business needs. Our premium-quality formulation delivers excellent results for businesses across metalworking, chemical manufacturing, and mineral extraction sectors.</p>
      <div class="pd-overview-features">
        <div class="pd-overview-feat">
          <div class="pd-overview-feat-icon"><i class="fas fa-check-circle"></i></div>
          <div>
            <h6>Fresh Stock, High Purity</h6>
            <p>Newly manufactured product with guaranteed purity for optimum performance.</p>
          </div>
        </div>
        <div class="pd-overview-feat">
          <div class="pd-overview-feat-icon"><i class="fas fa-check-circle"></i></div>
          <div>
            <h6>Reliable Supply</h6>
            <p>Our stock is regularly replenished, ensuring continuous access to high-quality solutions.</p>
          </div>
        </div>
        <div class="pd-overview-feat">
          <div class="pd-overview-feat-icon"><i class="fas fa-check-circle"></i></div>
          <div>
            <h6>Trusted Supplier</h6>
            <p>Years of experience in the industrial chemical market make us your reliable partner.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TECHNICAL SPECIFICATIONS ========== -->
  <section class="pd-tech-specs">
    <div class="container">
      <div class="pd-tech-grid">
        <div class="pd-tech-content">
          <div class="section-label">Technical Data</div>
          <h2>Product Specifications</h2>
          <p>Detailed technical specifications for Caluanie Muelear Oxidize as verified by our quality control laboratory.</p>
        </div>
        <div class="pd-tech-table-wrap">
          <table class="pd-tech-table">
            <tbody>
              <tr><td>Product Name</td><td>Caluanie Muelear Oxidize</td></tr>
              <tr><td>Type</td><td>Heavy Water / Liquid Oxidizer</td></tr>
              <tr><td>Appearance</td><td>Clear to slightly amber liquid</td></tr>
              <tr><td>Application</td><td>Metalworking, Refining, Processing</td></tr>
              <tr><td>Oxidizing Power</td><td>Premium Industrial Grade</td></tr>
              <tr><td>Density</td><td>~1.2 g/cm³</td></tr>
              <tr><td>pH</td><td>Acidic</td></tr>
              <tr><td>Solubility</td><td>Miscible with water</td></tr>
              <tr><td>Shelf Life</td><td>24 months from manufacture</td></tr>
              <tr><td>Pack Sizes</td><td>1 L, 5 L, 10 L, 25 L, 200 L drums</td></tr>
              <tr><td>Storage</td><td>Cool, dry, well-ventilated area</td></tr>
              <tr><td>Origin</td><td>Essen, Germany</td></tr>
            </tbody>
          </table>
        </div>
      </div>
      <div class="pd-docs-row">
        <div class="pd-doc-card">
          <i class="fas fa-file-pdf"></i>
          <div>
            <h5>Technical Data Sheet (TDS)</h5>
            <p>Complete product specifications and properties.</p>
          </div>
          <a href="/contact" class="btn btn-outline btn-sm">Request TDS <i class="fas fa-arrow-right"></i></a>
        </div>
        <div class="pd-doc-card">
          <i class="fas fa-file-shield"></i>
          <div>
            <h5>Safety Data Sheet (SDS)</h5>
            <p>Hazard identification, handling, and emergency procedures.</p>
          </div>
          <a href="/contact" class="btn btn-outline btn-sm">Request SDS <i class="fas fa-arrow-right"></i></a>
        </div>
        <div class="pd-doc-card">
          <i class="fas fa-file-certificate"></i>
          <div>
            <h5>Certificate of Analysis (COA)</h5>
            <p>Batch-specific purity and quality verification.</p>
          </div>
          <a href="/contact" class="btn btn-outline btn-sm">Request COA <i class="fas fa-arrow-right"></i></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== APPLICATIONS ========== -->
  <section class="pd-apps">
    <div class="container">
      <div class="text-center" style="margin-bottom:60px;">
        <div class="section-label">Applications</div>
        <h2>Industrial Applications</h2>
      </div>
      <div class="pd-apps-grid">
        <div class="pd-app-card">
          <div class="pd-app-num">01</div>
          <h5>Metalworking &amp; Refining</h5>
          <p>Widely used to improve metalworking processes by breaking down metals efficiently, reducing labor and time costs. Its strong oxidation properties enable industries to refine metals with precision.</p>
        </div>
        <div class="pd-app-card">
          <div class="pd-app-num">02</div>
          <h5>Chemical Manufacturing</h5>
          <p>An essential component in chemical manufacturing processes, serving as a catalyst and processing agent for various industrial chemical reactions.</p>
        </div>
        <div class="pd-app-card">
          <div class="pd-app-num">03</div>
          <h5>Mineral Extraction</h5>
          <p>Plays a key role in mineral extraction and processing operations, helping to break down and separate valuable minerals from raw materials efficiently.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== BENEFITS (DARK) ========== -->
  <section class="pd-benefits">
    <div class="container">
      <div class="pd-benefits-grid">
        <div class="pd-benefits-content">
          <div class="section-label">Why Buy From Us</div>
          <h2>Benefits of Choosing<br />UE Chemicals</h2>
          <p>We combine premium quality with exceptional service to ensure your operations run smoothly and efficiently.</p>
        </div>
        <div class="pd-benefits-cards">
          <div class="pd-benefit-card">
            <div class="pd-benefit-num">01</div>
            <div>
              <h5>Fast &amp; Secure Shipping</h5>
              <p>Order with confidence and have your chemicals delivered safely and on time to any destination worldwide.</p>
            </div>
          </div>
          <div class="pd-benefit-card">
            <div class="pd-benefit-num">02</div>
            <div>
              <h5>Expert Support</h5>
              <p>Our team is ready to assist you with any questions or concerns regarding the use or handling of our products.</p>
            </div>
          </div>
          <div class="pd-benefit-card">
            <div class="pd-benefit-num">03</div>
            <div>
              <h5>Competitive Pricing</h5>
              <p>Get the best value for your money with our reasonable pricing on premium stock products.</p>
            </div>
          </div>
          <div class="pd-benefit-card">
            <div class="pd-benefit-num">04</div>
            <div>
              <h5>Full Documentation</h5>
              <p>Every order ships with Certificate of Analysis (COA) and Safety Data Sheets (SDS) for complete traceability.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== SAFETY ========== -->
  <section class="pd-safety">
    <div class="container">
      <div class="pd-safety-inner">
        <div class="pd-safety-text">
          <div class="section-label">Safety &amp; Handling</div>
          <h2>Handling Information</h2>
          <p>Our product meets all the necessary legal and safety requirements. Follow these guidelines for safe use:</p>
        </div>
        <div class="pd-safety-items">
          <div class="pd-safety-item">
            <i class="fas fa-shield-halved"></i>
            <span>Always wear protective gloves and eyewear when handling the chemical.</span>
          </div>
          <div class="pd-safety-item">
            <i class="fas fa-box"></i>
            <span>Store in a cool, dry place, away from direct sunlight and incompatible materials.</span>
          </div>
          <div class="pd-safety-item">
            <i class="fas fa-wind"></i>
            <span>Handle in a well-ventilated area to minimize the risk of inhaling fumes.</span>
          </div>
          <div class="pd-safety-item">
            <i class="fas fa-file-lines"></i>
            <span>Follow local regulations for safe storage and disposal of industrial chemicals.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== QUOTE FORM ========== -->
  <section class="pd-quote">
    <div class="container">
      <div class="pd-quote-grid">
        <div class="pd-quote-text">
          <div class="section-label">Get Started</div>
          <h2>Request a Quote</h2>
          <p>Ready to order Caluanie Muelear Oxidize? Fill out the form and our team will respond with a customized quote within 24 hours.</p>
          <div class="pd-quote-badges">
            <div class="pd-quote-badge"><i class="fas fa-clock"></i> 24hr Response</div>
            <div class="pd-quote-badge"><i class="fas fa-lock"></i> Secure &amp; Private</div>
            <div class="pd-quote-badge"><i class="fas fa-certificate"></i> COA Included</div>
          </div>
        </div>
        <div class="pd-quote-form-wrap">
          <form>
            <div class="form-group">
              <label>Full Name</label>
              <input type="text" name="name" class="form-control" placeholder="Your full name" required>
            </div>
            <div class="form-group">
              <label>Email Address</label>
              <input type="email" name="email" class="form-control" placeholder="Your email address" required>
            </div>
            <div class="form-group">
              <label>Phone Number</label>
              <div class="phone-input">
                <select class="form-control">
                  <option>+49 DE</option>
                  <option>+1 USA</option>
                  <option>+44 UK</option>
                  <option>+61 AU</option>
                  <option>+33 FR</option>
                </select>
                <input type="tel" name="phone" class="form-control" placeholder="Phone number">
              </div>
            </div>
            <input type="hidden" name="product" value="Caluanie Muelear Oxidize">
            <div class="form-group">
              <label>Message</label>
              <textarea name="message" class="form-control" placeholder="Tell us about your desired quantity, intended use, delivery location, or any special requirements..." rows="4"></textarea>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">Request Quote <i class="fas fa-arrow-right"></i></button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="faq-section">
    <div class="container">
      <div class="faq-row">
        <div class="faq-content-col">
          <div class="section-label">Common Questions</div>
          <h2 class="section-title">Frequently Asked Questions</h2>
          <div class="faq-list">
            <div class="faq-item">
              <div class="faq-question">Is Caluanie Muelear Oxidize safe to use? <i class="fas fa-chevron-down"></i></div>
              <div class="faq-answer"><div class="faq-answer-inner">Yes, when handled with the proper safety precautions, Caluanie Muelear Oxidize is safe for industrial use. Be sure to follow recommended safety guidelines for handling and storage.</div></div>
            </div>
            <div class="faq-item">
              <div class="faq-question">What industries use this product? <i class="fas fa-chevron-down"></i></div>
              <div class="faq-answer"><div class="faq-answer-inner">It is widely used in metalworking, mineral extraction, chemical manufacturing, and refining industries.</div></div>
            </div>
            <div class="faq-item">
              <div class="faq-question">Can you ship internationally? <i class="fas fa-chevron-down"></i></div>
              <div class="faq-answer"><div class="faq-answer-inner">Yes, we offer international shipping services. Please contact our team for specific delivery options and estimated timelines for your region.</div></div>
            </div>
            <div class="faq-item">
              <div class="faq-question">How should it be stored? <i class="fas fa-chevron-down"></i></div>
              <div class="faq-answer"><div class="faq-answer-inner">Store in a cool, dry place away from direct sunlight and incompatible materials. Keep the container tightly sealed when not in use.</div></div>
            </div>
            <div class="faq-item">
              <div class="faq-question">Does it require special handling? <i class="fas fa-chevron-down"></i></div>
              <div class="faq-answer"><div class="faq-answer-inner">Yes, always wear appropriate PPE including gloves and eye protection. Handle in well-ventilated areas and follow local safety regulations.</div></div>
            </div>
            <div class="faq-item">
              <div class="faq-question">Do you offer bulk discounts? <i class="fas fa-chevron-down"></i></div>
              <div class="faq-answer"><div class="faq-answer-inner">Yes, we offer competitive pricing for bulk orders. Contact our sales team for custom quantities and special requirements.</div></div>
            </div>
            <div class="faq-item">
              <div class="faq-question">How quickly can I receive my order? <i class="fas fa-chevron-down"></i></div>
              <div class="faq-answer"><div class="faq-answer-inner">Delivery times vary based on location and product availability. Estimated timelines will be provided when your order is confirmed.</div></div>
            </div>
            <div class="faq-item">
              <div class="faq-question">Do you provide a Certificate of Analysis? <i class="fas fa-chevron-down"></i></div>
              <div class="faq-answer"><div class="faq-answer-inner">Yes, all our products come with detailed Certificates of Analysis to verify purity and quality standards.</div></div>
            </div>
          </div>
        </div>
        <div class="faq-image-col">
          <img src="/images/buy-new-stock-caluanie-muelear-oxidize-usa.png" alt="Caluanie Muelear Oxidize" />
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .pd-hero { position: relative; min-height: 70vh; display: flex; align-items: center; overflow: hidden; }
  .pd-hero-bg { position: absolute; inset: 0; z-index: 0; }
  .pd-hero-bg img { width: 100%; height: 100%; object-fit: cover; }
  .pd-hero-overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(25,24,23,0.94) 0%, rgba(25,24,23,0.8) 50%, rgba(25,24,23,0.65) 100%); }
  .pd-hero-inner { position: relative; z-index: 1; padding-top: 140px; padding-bottom: 80px; }
  .pd-hero-content { max-width: 650px; }
  .pd-hero-badge { display: inline-flex; align-items: center; gap: 10px; padding: 8px 20px; border: 1px solid rgba(255,255,255,0.2); font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: rgba(255,255,255,0.8); margin-bottom: 24px; }
  .pd-hero-badge i { color: var(--accent); font-size: 13px; }
  .pd-hero h1 { color: var(--white); font-size: clamp(36px, 5vw, 68px); line-height: 1.05; margin-bottom: 20px; letter-spacing: -1px; }
  .pd-hero-sub { color: rgba(255,255,255,0.65); font-size: 18px; line-height: 1.7; max-width: 500px; margin-bottom: 36px; }
  .pd-hero-actions { display: flex; gap: 16px; flex-wrap: wrap; }
  .btn-outline-white { background: transparent; color: var(--white); border: 2px solid rgba(255,255,255,0.3); }
  .btn-outline-white:hover { background: var(--white); color: var(--near-black); border-color: var(--white); }

  /* Specs Bar */
  .pd-specs-bar { background: var(--near-black); padding: 0; border-bottom: 1px solid rgba(255,255,255,0.06); }
  .pd-specs-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; }
  .pd-spec-item { padding: 28px 24px; border-left: 1px solid rgba(255,255,255,0.08); display: flex; flex-direction: column; gap: 4px; }
  .pd-spec-item:last-child { border-right: 1px solid rgba(255,255,255,0.08); }
  .pd-spec-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: rgba(255,255,255,0.4); }
  .pd-spec-value { font-size: 15px; font-weight: 700; color: var(--white); }

  /* Overview Split */
  .pd-overview { display: grid; grid-template-columns: 1fr 1fr; min-height: 600px; }
  .pd-overview-image { overflow: hidden; }
  .pd-overview-image img { width: 100%; height: 100%; object-fit: cover; }
  .pd-overview-content { padding: 80px 60px; display: flex; flex-direction: column; justify-content: center; background: var(--light-bg); }
  .pd-overview-content h2 { font-size: clamp(24px, 3vw, 38px); margin-bottom: 20px; line-height: 1.15; }
  .pd-overview-content > p { max-width: 480px; }
  .pd-overview-features { margin-top: 30px; display: flex; flex-direction: column; gap: 20px; }
  .pd-overview-feat { display: flex; gap: 14px; align-items: flex-start; }
  .pd-overview-feat-icon { color: var(--near-black); font-size: 16px; margin-top: 2px; flex-shrink: 0; }
  .pd-overview-feat h6 { font-size: 15px; margin-bottom: 3px; }
  .pd-overview-feat p { font-size: 14px; margin: 0; color: var(--body-text); }

  /* Tech Specs */
  .pd-tech-specs { padding: 100px 0; background: var(--white); border-top: 1px solid var(--border); }
  .pd-tech-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 50px; align-items: start; margin-bottom: 50px; }
  .pd-tech-content h2 { font-size: clamp(24px, 3vw, 38px); margin-bottom: 16px; line-height: 1.15; }
  .pd-tech-content p { color: var(--body-text); }
  .pd-tech-table-wrap { overflow-x: auto; }
  .pd-tech-table { width: 100%; border-collapse: collapse; background: var(--surface); border-radius: 8px; overflow: hidden; }
  .pd-tech-table td { padding: 12px 18px; border-bottom: 1px solid var(--border-light); font-size: 0.9rem; }
  .pd-tech-table td:first-child { font-weight: 600; color: var(--heading); width: 40%; background: rgba(0,0,0,0.02); }
  .pd-tech-table td:last-child { color: var(--body-text); }
  .pd-tech-table tr:last-child td { border-bottom: none; }
  .pd-docs-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .pd-doc-card { display: flex; align-items: center; gap: 16px; padding: 20px 24px; background: var(--surface); border: 1px solid var(--border-light); border-radius: 10px; }
  .pd-doc-card i { font-size: 1.8rem; color: var(--primary); flex-shrink: 0; }
  .pd-doc-card div { flex: 1; }
  .pd-doc-card h5 { font-size: 0.9rem; margin-bottom: 4px; }
  .pd-doc-card p { font-size: 0.8rem; color: var(--body-text); margin: 0; }
  .btn-sm { padding: 8px 16px; font-size: 0.75rem; white-space: nowrap; }

  /* Applications */
  .pd-apps { padding: 120px 0; background: var(--white); border-top: 1px solid var(--border); }
  .pd-apps h2 { font-size: clamp(28px, 3.5vw, 50px); line-height: 1.15; }
  .pd-apps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; }
  .pd-app-card { padding: 50px 35px; border-left: 1px solid var(--border); transition: var(--transition); }
  .pd-app-card:last-child { border-right: 1px solid var(--border); }
  .pd-app-card:hover { background: var(--light-bg); }
  .pd-app-num { font-size: 14px; font-weight: 800; color: var(--accent); letter-spacing: 1px; margin-bottom: 16px; }
  .pd-app-card h5 { font-size: 17px; text-transform: uppercase; margin-bottom: 12px; }
  .pd-app-card p { font-size: 14px; color: var(--body-text); margin: 0; line-height: 1.6; }

  /* Benefits (Dark) */
  .pd-benefits { padding: 120px 0; background: var(--near-black); }
  .pd-benefits-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; }
  .pd-benefits-content .section-label { color: rgba(255,255,255,0.6); }
  .pd-benefits-content .section-label::before { background: var(--accent); }
  .pd-benefits-content h2 { color: var(--white); font-size: clamp(24px, 3vw, 42px); margin-bottom: 20px; line-height: 1.15; }
  .pd-benefits-content p { color: rgba(255,255,255,0.5); max-width: 440px; }
  .pd-benefits-cards { display: flex; flex-direction: column; }
  .pd-benefit-card { display: flex; gap: 24px; padding: 28px 0; border-bottom: 1px solid rgba(255,255,255,0.1); align-items: flex-start; }
  .pd-benefit-card:first-child { padding-top: 0; }
  .pd-benefit-num { font-size: 14px; font-weight: 800; color: var(--accent); letter-spacing: 1px; flex-shrink: 0; padding-top: 2px; }
  .pd-benefit-card h5 { color: var(--white); font-size: 16px; margin-bottom: 6px; text-transform: uppercase; }
  .pd-benefit-card p { color: rgba(255,255,255,0.45); font-size: 14px; margin: 0; }

  /* Safety */
  .pd-safety { padding: 100px 0; background: var(--light-bg); border-top: 1px solid var(--border); }
  .pd-safety-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
  .pd-safety-text h2 { font-size: clamp(24px, 3vw, 38px); margin-bottom: 16px; line-height: 1.15; }
  .pd-safety-items { display: flex; flex-direction: column; gap: 0; }
  .pd-safety-item { display: flex; gap: 16px; align-items: flex-start; padding: 20px 0; border-bottom: 1px solid var(--border); font-size: 15px; color: var(--body-text); line-height: 1.6; }
  .pd-safety-item:first-child { padding-top: 0; }
  .pd-safety-item:last-child { border-bottom: none; }
  .pd-safety-item i { color: var(--near-black); font-size: 16px; margin-top: 3px; flex-shrink: 0; }

  /* Quote */
  .pd-quote { padding: 120px 0; background: var(--white); border-top: 1px solid var(--border); }
  .pd-quote-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
  .pd-quote-text h2 { font-size: clamp(24px, 3vw, 42px); margin-bottom: 16px; line-height: 1.15; }
  .pd-quote-text > p { max-width: 440px; }
