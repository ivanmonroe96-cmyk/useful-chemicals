---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Silver Liquid Mercury" activePage="products">

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="section-label">Product Details</div>
      <h1>Silver Liquid Mercury</h1>
      <p>High-purity silver liquid mercury certified at 99.99% purity. Suitable for precision tasks from scientific lab work to industrial applications.</p>
    </div>
  </section>

  <!-- Product Detail -->
  <section class="product-detail">
    <div class="container">
      <div class="product-detail-grid">
        <div class="product-info">
          <h5>Why Choose High-Purity Silver Liquid Mercury?</h5>
          <p>Purity matters when it comes to mercury, especially for sensitive applications. Our silver liquid mercury is certified with 99.99% purity (free from heavy metals), ensuring it's suitable for precision tasks, from scientific lab work to industrial applications.</p>

          <h5>Common Uses</h5>
          <ul>
            <li><strong>Mining and Extraction:</strong> Widely used in gold extraction due to its binding properties.</li>
            <li><strong>Medical Applications:</strong> Useful in dental amalgams and some medical devices.</li>
            <li><strong>Manufacturing:</strong> Employed in various industrial tools and measurement devices.</li>
            <li><strong>Scientific Research:</strong> Essential for laboratories requiring controlled, high-purity materials.</li>
          </ul>

          <h5>Product Specifications</h5>
          <div class="product-specs">
            <ul>
              <li><strong>Purity Level</strong> <span>99.99% certified</span></li>
              <li><strong>Packaging</strong> <span>Safe, tamper-resistant cylinders (25g–5kg)</span></li>
              <li><strong>Safety</strong> <span>Heavy metal-free for precision tasks</span></li>
              <li><strong>Delivery</strong> <span>Worldwide from our Essen, Germany facility</span></li>
            </ul>
          </div>

          <h5>Handling and Safety Precautions</h5>
          <p>Silver mercury is a powerful substance but requires careful handling. Always store it in a temperature-controlled environment, ideally in containers designed to prevent leakage and minimize evaporation.</p>
          <ul>
            <li>Keep in well-ventilated areas.</li>
            <li>Wear protective gloves and eye protection.</li>
            <li>Avoid prolonged exposure to vapors by handling in controlled, low-temperature environments.</li>
          </ul>
        </div>

        <div>
          <!-- Product Image -->
          <div class="about-image" style="overflow:hidden;">
            <img src="/images/Buy-Silver-Liquid-Mercury.jpg" alt="Silver Liquid Mercury" style="width:100%;height:350px;object-fit:cover;display:block;">
          </div>

          <!-- Quote Form -->
          <div class="product-specs" style="margin-top:30px;">
            <h4 style="margin-bottom:20px;">Get Quote</h4>
            <form>
              <div class="form-group">
                <input type="text" name="name" class="form-control" placeholder="Full Name" required>
              </div>
              <div class="form-group">
                <input type="email" name="email" class="form-control" placeholder="Email Address" required>
              </div>
              <div class="form-group">
                <div class="phone-input">
                  <select class="form-control">
                    <option>+49 DE</option>
                    <option>+1 USA</option>
                    <option>+33 FR</option>
                  </select>
                  <input type="tel" name="phone" class="form-control" placeholder="Phone Number">
                </div>
              </div>
              <div class="form-group">
                <select name="product" class="form-control">
                  <option>Select Product</option>
                  <option>Caluanie Muelear Oxidize</option>
                  <option>Red Liquid Mercury</option>
                  <option selected>Silver Liquid Mercury</option>
                </select>
              </div>
              <div class="form-group">
                <textarea name="message" class="form-control" placeholder="Message" rows="4"></textarea>
              </div>
              <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">Send</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- Technical Specifications -->
  <section class="sm-tech-specs">
    <div class="container">
      <div class="sm-tech-header">
        <div class="section-label">Technical Data</div>
        <h2>Detailed Chemical Specifications</h2>
      </div>
      <div class="sm-tech-grid">
        <div class="sm-tech-table-wrap">
          <table class="sm-tech-table">
            <tbody>
              <tr><td>Chemical Name</td><td>Mercury (Liquid Silver)</td></tr>
              <tr><td>Chemical Symbol</td><td>Hg</td></tr>
              <tr><td>CAS Number</td><td>7439-97-6</td></tr>
              <tr><td>Purity</td><td>≥99.99% (4N Grade)</td></tr>
              <tr><td>Appearance</td><td>Bright silver metallic liquid, odorless</td></tr>
              <tr><td>Molecular Weight</td><td>200.59 g/mol</td></tr>
              <tr><td>Density</td><td>13.534 g/cm³ at 25°C</td></tr>
              <tr><td>Melting Point</td><td>-38.87°C</td></tr>
              <tr><td>Boiling Point</td><td>357°C</td></tr>
              <tr><td>Vapor Pressure</td><td>0.00185 mm Hg at 25°C</td></tr>
              <tr><td>Solubility in Water</td><td>Insoluble</td></tr>
              <tr><td>UN Number</td><td>UN2809</td></tr>
              <tr><td>Hazard Classification</td><td>Class 8 (Corrosive) / 6.1 (Toxic)</td></tr>
              <tr><td>Packing Group</td><td>III</td></tr>
              <tr><td>Pack Sizes</td><td>34.5 kg (76 lbs) UN-approved steel flasks</td></tr>
              <tr><td>Origin</td><td>Germany</td></tr>
            </tbody>
          </table>
        </div>
        <div class="sm-docs-col">
          <h4>Documentation</h4>
          <p>Request product documentation for compliance and quality verification.</p>
          <div class="sm-doc-items">
            <div class="sm-doc-item">
              <i class="fas fa-file-pdf"></i>
              <div>
                <strong>Technical Data Sheet (TDS)</strong>
                <span>Complete chemical specifications</span>
              </div>
              <a href="/contact">Request</a>
            </div>
            <div class="sm-doc-item">
              <i class="fas fa-file-shield"></i>
              <div>
                <strong>Safety Data Sheet (SDS)</strong>
                <span>Hazard, handling & emergency info</span>
              </div>
              <a href="/contact">Request</a>
            </div>
            <div class="sm-doc-item">
              <i class="fas fa-file-certificate"></i>
              <div>
                <strong>Certificate of Analysis (COA)</strong>
                <span>Batch purity verification</span>
              </div>
              <a href="/contact">Request</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="container text-center">
      <div class="section-label">Common Questions</div>
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        <div class="faq-item">
          <div class="faq-question">Can I purchase in bulk? <i class="fas fa-chevron-down"></i></div>
          <div class="faq-answer"><div class="faq-answer-inner">Yes, we offer bulk purchasing options to meet both small and large-scale needs. Contact our sales team for custom quantities or special requirements.</div></div>
        </div>
        <div class="faq-item">
          <div class="faq-question">How do I know if this mercury is suitable for my industry? <i class="fas fa-chevron-down"></i></div>
          <div class="faq-answer"><div class="faq-answer-inner">Our team can help you determine if silver liquid mercury is suitable for your specific application. Contact us for a consultation.</div></div>
        </div>
        <div class="faq-item">
          <div class="faq-question">What purity level should I expect? <i class="fas fa-chevron-down"></i></div>
          <div class="faq-answer"><div class="faq-answer-inner">Our silver liquid mercury is certified at 99.99% purity, free from heavy metals, ensuring suitability for the most demanding precision tasks.</div></div>
        </div>
        <div class="faq-item">
          <div class="faq-question">Are there legal restrictions on buying mercury in Europe? <i class="fas fa-chevron-down"></i></div>
          <div class="faq-answer"><div class="faq-answer-inner">Mercury sales are regulated under EU REACH Regulation (EC 1907/2006) and the EU Mercury Regulation (EU 2017/852). We ensure full compliance with all applicable regulations and can guide you through the requirements for your region.</div></div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .sm-tech-specs { padding: 60px 0; }
  .sm-tech-header { margin-bottom: 40px; }
  .sm-tech-header h2 { margin-top: 8px; }
  .sm-tech-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 40px; align-items: start; }
  .sm-tech-table-wrap { overflow-x: auto; }
  .sm-tech-table { width: 100%; border-collapse: collapse; background: var(--surface); border-radius: 8px; overflow: hidden; }
  .sm-tech-table td { padding: 11px 18px; border-bottom: 1px solid var(--border-light); font-size: 0.88rem; }
  .sm-tech-table td:first-child { font-weight: 600; color: var(--heading); width: 42%; background: rgba(0,0,0,0.02); }
  .sm-tech-table td:last-child { color: var(--body-text); }
  .sm-tech-table tr:last-child td { border-bottom: none; }
  .sm-docs-col { background: var(--surface); border: 1px solid var(--border-light); border-radius: 12px; padding: 30px; }
  .sm-docs-col h4 { margin-bottom: 8px; }
  .sm-docs-col > p { color: var(--body-text); font-size: 0.88rem; margin-bottom: 20px; }
  .sm-doc-items { display: flex; flex-direction: column; gap: 14px; }
  .sm-doc-item { display: flex; align-items: center; gap: 12px; padding: 12px; background: var(--bg); border-radius: 8px; border: 1px solid var(--border-light); }
  .sm-doc-item i { font-size: 1.4rem; color: var(--primary); flex-shrink: 0; }
  .sm-doc-item div { flex: 1; }
  .sm-doc-item strong { display: block; font-size: 0.85rem; }
  .sm-doc-item span { font-size: 0.78rem; color: var(--body-text); }
  .sm-doc-item a { color: var(--primary); font-weight: 600; font-size: 0.82rem; text-decoration: none; white-space: nowrap; }
  .sm-doc-item a:hover { text-decoration: underline; }
  @media (max-width: 768px) {
    .sm-tech-grid { grid-template-columns: 1fr; }
  }
</style>
