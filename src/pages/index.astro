---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Premium Industrial Chemicals" activePage="home">

  <!-- ========== HERO ========== -->
  <section class="hero">
    <div class="hero-bg">
      <img src="/images/caluanie-muelear-oxidize-manufacturer-in-usa.webp" alt="" />
      <div class="hero-overlay"></div>
    </div>
    <div class="container hero-inner">
      <div class="hero-content">
        <div class="hero-badge">Essen, Germany &mdash; Trusted Since Day One</div>
        <h1>Industrial-Grade<br />Chemical Solutions</h1>
        <p class="hero-sub">Precision-manufactured specialty chemicals for metalworking, research, and advanced industrial processes. Quality assured, globally delivered.</p>
        <div class="hero-actions">
          <a href="/products" class="btn btn-accent">Explore Products <i class="fas fa-arrow-right"></i></a>
          <a href="/contact" class="btn btn-outline-white">Get a Quote <i class="fas fa-arrow-right"></i></a>
        </div>
      </div>
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-num">3</span>
          <span class="hero-stat-label">Core Products</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-num">99.99%</span>
          <span class="hero-stat-label">Purity Certified</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-num">Global</span>
          <span class="hero-stat-label">Shipping Network</span>
        </div>
      </div>
    </div>
    <a href="#products" class="hero-scroll" aria-label="Scroll down">
      <i class="fas fa-chevron-down"></i>
    </a>
  </section>

  <!-- ========== MARQUEE TRUST BAR ========== -->
  <section class="trust-bar">
    <div class="trust-bar-track">
      <div class="trust-bar-items">
        <span><i class="fas fa-flask"></i> Premium Purity</span>
        <span><i class="fas fa-shield-halved"></i> Safety Certified</span>
        <span><i class="fas fa-truck-fast"></i> Fast Global Shipping</span>
        <span><i class="fas fa-award"></i> Quality Assured</span>
        <span><i class="fas fa-headset"></i> Expert Support</span>
        <span><i class="fas fa-certificate"></i> Certificate of Analysis</span>
        <span><i class="fas fa-flask"></i> Premium Purity</span>
        <span><i class="fas fa-shield-halved"></i> Safety Certified</span>
        <span><i class="fas fa-truck-fast"></i> Fast Global Shipping</span>
        <span><i class="fas fa-award"></i> Quality Assured</span>
        <span><i class="fas fa-headset"></i> Expert Support</span>
        <span><i class="fas fa-certificate"></i> Certificate of Analysis</span>
      </div>
    </div>
  </section>

  <!-- ========== PRODUCTS SHOWCASE ========== -->
  <section class="hp-products" id="products">
    <div class="container">
      <div class="hp-section-header">
        <div>
          <div class="section-label">Our Products</div>
          <h2>Three Specialty Chemicals.<br />Endless Applications.</h2>
        </div>
        <a href="/products" class="btn btn-outline">View All Products <i class="fas fa-arrow-right"></i></a>
      </div>

      <div class="hp-products-grid">
        <!-- Card 1 -->
        <a href="/products/caluanie" class="hp-product-card">
          <div class="hp-product-img">
            <img src="/images/caluanie-muelear-oxidize-for-sale.jpg" alt="Caluanie Muelear Oxidize" />
            <div class="hp-product-num">01</div>
          </div>
          <div class="hp-product-body">
            <h3>Caluanie Muelear Oxidize</h3>
            <p>A highly effective oxidizing agent for metalworking, mineral processing, and industrial refining applications.</p>
            <span class="hp-product-link">Learn More <i class="fas fa-arrow-right"></i></span>
          </div>
        </a>

        <!-- Card 2 -->
        <a href="/products/red-mercury" class="hp-product-card">
          <div class="hp-product-img">
            <img src="/images/red-liquid-mercury-for-sale-usa.png" alt="Red Liquid Mercury" />
            <div class="hp-product-num">02</div>
          </div>
          <div class="hp-product-body">
            <h3>Red Liquid Mercury</h3>
            <p>A rare compound utilized in laboratory research, chemical synthesis, and specialized medical equipment manufacturing.</p>
            <span class="hp-product-link">Learn More <i class="fas fa-arrow-right"></i></span>
          </div>
        </a>

        <!-- Card 3 -->
        <a href="/products/silver-mercury" class="hp-product-card">
          <div class="hp-product-img">
            <img src="/images/silver-liquid-mercury-for-sale.png" alt="Silver Liquid Mercury" />
            <div class="hp-product-num">03</div>
          </div>
          <div class="hp-product-body">
            <h3>Silver Liquid Mercury</h3>
            <p>99.99% purity certified mercury for scientific instrumentation, electronics, and precious metal extraction.</p>
            <span class="hp-product-link">Learn More <i class="fas fa-arrow-right"></i></span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ========== ABOUT / SPLIT ========== -->
  <section class="hp-about">
    <div class="hp-about-image">
      <img src="/images/pexels-los-muertos-crew-10041264.jpg" alt="UE Chemicals Laboratory" />
    </div>
    <div class="hp-about-content">
      <div class="section-label">About UE Chemicals</div>
      <h2>Precision Chemistry, Trusted Worldwide</h2>
      <p>Based in Essen, Germany, UE Chemicals manufactures and supplies high-grade industrial chemicals that meet the strictest purity and safety standards. Our state-of-the-art facility and dedicated quality team ensure every batch exceeds expectations.</p>
      <div class="hp-about-features">
        <div class="hp-about-feat">
          <div class="hp-about-feat-icon"><i class="fas fa-microscope"></i></div>
          <div>
            <h6>Advanced Testing</h6>
            <p>Every product undergoes rigorous quality analysis before leaving our facility.</p>
          </div>
        </div>
        <div class="hp-about-feat">
          <div class="hp-about-feat-icon"><i class="fas fa-earth-americas"></i></div>
          <div>
            <h6>Global Reach</h6>
            <p>Reliable international shipping with full compliance and safety documentation.</p>
          </div>
        </div>
      </div>
      <a href="/about" class="btn btn-primary">Learn About Us <i class="fas fa-arrow-right"></i></a>
    </div>
  </section>

  <!-- ========== APPLICATIONS STRIP ========== -->
  <section class="hp-applications">
    <div class="container">
      <div class="text-center">
        <div class="section-label">Industry Applications</div>
        <h2>Powering Industries<br />Across the Globe</h2>
      </div>
      <div class="hp-app-grid">
        <div class="hp-app-card">
          <div class="hp-app-icon"><i class="fas fa-gears"></i></div>
          <h5>Metalworking &amp; Refining</h5>
          <p>Efficient metal processing and refining with our premium oxidizing agents.</p>
        </div>
        <div class="hp-app-card">
          <div class="hp-app-icon"><i class="fas fa-flask"></i></div>
          <h5>Chemical Manufacturing</h5>
          <p>Essential catalysts and processing agents for industrial chemical reactions.</p>
        </div>
        <div class="hp-app-card">
          <div class="hp-app-icon"><i class="fas fa-gem"></i></div>
          <h5>Mineral Extraction</h5>
          <p>Breaking down and separating valuable minerals from raw materials.</p>
        </div>
        <div class="hp-app-card">
          <div class="hp-app-icon"><i class="fas fa-microscope"></i></div>
          <h5>Scientific Research</h5>
          <p>High-purity compounds for controlled laboratory experiments.</p>
        </div>
        <div class="hp-app-card">
          <div class="hp-app-icon"><i class="fas fa-microchip"></i></div>
          <h5>Electronics &amp; Instruments</h5>
          <p>Precision materials for measurement devices and electronic components.</p>
        </div>
        <div class="hp-app-card">
          <div class="hp-app-icon"><i class="fas fa-coins"></i></div>
          <h5>Precious Metal Recovery</h5>
          <p>Gold and silver extraction using specialized mercury binding properties.</p>
        </div>
      </div>
      <div class="text-center" style="margin-top:50px;">
        <a href="/applications" class="btn btn-primary">See All Applications <i class="fas fa-arrow-right"></i></a>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="hp-why">
    <div class="container">
      <div class="hp-why-grid">
        <div class="hp-why-content">
          <div class="section-label">Why UE Chemicals</div>
          <h2>Built on Quality. Driven by Safety.</h2>
          <p>We combine advanced manufacturing with rigorous safety protocols to deliver chemicals you can trust. Every product ships with full documentation, including Certificates of Analysis and Safety Data Sheets.</p>
        </div>
        <div class="hp-why-cards">
          <div class="hp-why-card">
            <div class="hp-why-card-num">01</div>
            <div>
              <h5>Quality Assurance</h5>
              <p>Every batch undergoes multi-stage quality testing to guarantee consistent performance and purity.</p>
            </div>
          </div>
          <div class="hp-why-card">
            <div class="hp-why-card-num">02</div>
            <div>
              <h5>Full Compliance</h5>
              <p>All products meet local and international safety regulations for handling, storage, and transport.</p>
            </div>
          </div>
          <div class="hp-why-card">
            <div class="hp-why-card-num">03</div>
            <div>
              <h5>Expert Guidance</h5>
              <p>Our technical team provides consultation on product selection, handling procedures, and applications.</p>
            </div>
          </div>
          <div class="hp-why-card">
            <div class="hp-why-card-num">04</div>
            <div>
              <h5>Reliable Delivery</h5>
              <p>Partnered with leading freight companies for safe, timely delivery to any destination worldwide.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TESTIMONIALS ========== -->
  <section class="hp-testimonials">
    <div class="container">
      <div class="text-center" style="margin-bottom:50px;">
        <div class="section-label">Client Feedback</div>
        <h2>What Our Clients Say</h2>
      </div>
      <div class="hp-test-grid">
        <div class="hp-test-card">
          <div class="hp-test-stars">
            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
          </div>
          <p>"Excellent quality Caluanie Muelear Oxidize. The product arrived on time with full documentation. Their customer service team was very responsive and helpful throughout the ordering process."</p>
          <div class="hp-test-author">
            <div class="hp-test-avatar"><i class="fas fa-user"></i></div>
            <div>
              <strong>M. Krauss</strong>
              <span>Industrial Manufacturing, Germany</span>
            </div>
          </div>
        </div>
        <div class="hp-test-card">
          <div class="hp-test-stars">
            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
          </div>
          <p>"We've been sourcing Silver Liquid Mercury from UE Chemicals for our research laboratory. The 99.99% purity is consistent batch after batch, and the COA documentation is thorough."</p>
          <div class="hp-test-author">
            <div class="hp-test-avatar"><i class="fas fa-user"></i></div>
            <div>
              <strong>Dr. R. Oliveira</strong>
              <span>Research Laboratory, Brazil</span>
            </div>
          </div>
        </div>
        <div class="hp-test-card">
          <div class="hp-test-stars">
            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
          </div>
          <p>"Fast shipping to South America with complete customs documentation. The packaging was secure and professional. Will definitely order again for our gold extraction operations."</p>
          <div class="hp-test-author">
            <div class="hp-test-avatar"><i class="fas fa-user"></i></div>
            <div>
              <strong>J. Martinez</strong>
              <span>Mining Operations, Colombia</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== CTA ========== -->
  <section class="hp-cta">
    <div class="container">
      <div class="hp-cta-inner">
        <div class="hp-cta-content">
          <h2>Ready to Get Started?</h2>
          <p>Contact our team for personalized quotes, product consultations, or technical support. We're here to power your operations.</p>
        </div>
        <div class="hp-cta-actions">
          <a href="/contact" class="btn btn-white">Contact Us <i class="fas fa-arrow-right"></i></a>
          <a href="/ordering" class="btn btn-outline-white">How to Order <i class="fas fa-arrow-right"></i></a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ========================================
     HOMEPAGE-SPECIFIC STYLES
     ======================================== */

  /* Hero */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(25,24,23,0.92) 0%, rgba(25,24,23,0.7) 60%, rgba(252,82,32,0.15) 100%);
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    padding-top: 140px;
    padding-bottom: 100px;
  }
  .hero-content { max-width: 700px; }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 20px;
    border: 1px solid rgba(255,255,255,0.2);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: rgba(255,255,255,0.8);
    margin-bottom: 24px;
  }
  .hero h1 {
    color: var(--white);
    font-size: clamp(42px, 6vw, 80px);
    line-height: 1.05;
    margin-bottom: 24px;
    letter-spacing: -1px;
  }
  .hero-sub {
    color: rgba(255,255,255,0.7);
    font-size: 18px;
    line-height: 1.7;
    max-width: 560px;
    margin-bottom: 40px;
  }
  .hero-actions { display: flex; gap: 16px; flex-wrap: wrap; }
  .btn-outline-white {
    background: transparent;
    color: var(--white);
    border: 2px solid rgba(255,255,255,0.3);
  }
  .btn-outline-white:hover {
    background: var(--white);
    color: var(--near-black);
    border-color: var(--white);
  }

  /* Hero Stats */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 40px;
    margin-top: 80px;
    padding-top: 40px;
    border-top: 1px solid rgba(255,255,255,0.12);
  }
  .hero-stat-num {
    display: block;
    font-size: 28px;
    font-weight: 800;
    color: var(--white);
    letter-spacing: -0.5px;
  }
  .hero-stat-label {
    display: block;
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: 4px;
  }
  .hero-stat-divider {
    width: 1px;
    height: 50px;
    background: rgba(255,255,255,0.12);
  }

  /* Hero Scroll */
  .hero-scroll {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    width: 44px;
    height: 44px;
    border: 1px solid rgba(255,255,255,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.5);
    font-size: 14px;
    z-index: 1;
    animation: heroFloat 2s ease-in-out infinite;
  }
  .hero-scroll:hover { border-color: var(--accent); color: var(--accent); }
  @keyframes heroFloat {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

  /* Trust Bar Marquee */
  .trust-bar {
    background: var(--near-black);
    padding: 16px 0;
    overflow: hidden;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .trust-bar-track { overflow: hidden; }
  .trust-bar-items {
    display: flex;
    gap: 60px;
    animation: marquee 25s linear infinite;
    white-space: nowrap;
    width: max-content;
  }
  .trust-bar-items span {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: rgba(255,255,255,0.4);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }
  .trust-bar-items span i { color: var(--accent); font-size: 14px; }
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Products Section */
  .hp-products { padding: 120px 0; background: var(--white); }
  .hp-section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 30px;
    margin-bottom: 60px;
  }
  .hp-section-header h2 {
    font-size: clamp(28px, 3.5vw, 50px);
    line-height: 1.15;
  }

  .hp-products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }
  .hp-product-card {
    display: block;
    border-left: 1px solid var(--border);
    overflow: hidden;
    transition: var(--transition);
    color: var(--body-text);
  }
  .hp-product-card:last-child { border-right: 1px solid var(--border); }
  .hp-product-card:hover { color: var(--body-text); }
  .hp-product-img {
    position: relative;
    height: 320px;
    overflow: hidden;
  }
  .hp-product-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .hp-product-card:hover .hp-product-img img { transform: scale(1.08); }
  .hp-product-num {
    position: absolute;
    top: 20px;
    left: 20px;
    font-size: 13px;
    font-weight: 800;
    color: var(--white);
    background: var(--near-black);
    padding: 6px 14px;
    letter-spacing: 1px;
  }
  .hp-product-body { padding: 30px; }
  .hp-product-body h3 {
    font-size: 22px;
    margin-bottom: 12px;
    transition: color 0.3s;
  }
  .hp-product-card:hover .hp-product-body h3 { color: var(--accent); }
  .hp-product-body p { font-size: 15px; margin-bottom: 20px; }
  .hp-product-link {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--accent);
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .hp-product-link i { font-size: 11px; transition: transform 0.3s; }
  .hp-product-card:hover .hp-product-link i { transform: translateX(6px); }

  /* About Split */
  .hp-about {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 600px;
  }
  .hp-about-image { overflow: hidden; }
  .hp-about-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hp-about-content {
    padding: 80px 60px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--light-bg);
  }
  .hp-about-content h2 {
    font-size: clamp(24px, 3vw, 40px);
    margin-bottom: 20px;
    line-height: 1.15;
  }
  .hp-about-content > p { max-width: 480px; }
  .hp-about-features { margin: 30px 0 35px; display: flex; flex-direction: column; gap: 24px; }
  .hp-about-feat { display: flex; gap: 16px; align-items: flex-start; }
  .hp-about-feat-icon {
    width: 48px;
    height: 48px;
    background: var(--near-black);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--white);
    flex-shrink: 0;
    font-size: 18px;
  }
  .hp-about-feat h6 { font-size: 15px; margin-bottom: 4px; }
  .hp-about-feat p { font-size: 14px; margin: 0; color: var(--body-text); }

  /* Applications */
  .hp-applications {
    padding: 120px 0;
    background: var(--white);
    border-top: 1px solid var(--border);
  }
  .hp-applications h2 {
    font-size: clamp(28px, 3.5vw, 50px);
    margin-bottom: 60px;
    line-height: 1.15;
  }
  .hp-app-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }
  .hp-app-card {
    padding: 50px 30px;
    border-left: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    transition: var(--transition);
  }
  .hp-app-card:nth-child(3n) { border-right: 1px solid var(--border); }
  .hp-app-card:nth-child(-n+3) { border-top: 1px solid var(--border); }
  .hp-app-card:hover { background: var(--light-bg); }
  .hp-app-icon {
    width: 52px;
    height: 52px;
    background: rgba(252,82,32,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    font-size: 20px;
    margin-bottom: 20px;
  }
  .hp-app-card h5 { font-size: 17px; margin-bottom: 10px; text-transform: uppercase; }
  .hp-app-card p { font-size: 14px; margin: 0; }

  /* Why Section */
  .hp-why {
    padding: 120px 0;
    background: var(--near-black);
  }
  .hp-why-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }
  .hp-why-content .section-label { color: rgba(255,255,255,0.6); }
  .hp-why-content .section-label::before { background: var(--accent); }
  .hp-why-content h2 {
    color: var(--white);
    font-size: clamp(24px, 3vw, 42px);
    margin-bottom: 20px;
    line-height: 1.15;
  }
  .hp-why-content p { color: rgba(255,255,255,0.5); max-width: 440px; }
  .hp-why-cards { display: flex; flex-direction: column; gap: 0; }
  .hp-why-card {
    display: flex;
    gap: 24px;
    padding: 30px 0;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    align-items: flex-start;
  }
  .hp-why-card:first-child { padding-top: 0; }
  .hp-why-card-num {
    font-size: 14px;
    font-weight: 800;
    color: var(--accent);
    letter-spacing: 1px;
    flex-shrink: 0;
    padding-top: 2px;
  }
  .hp-why-card h5 {
    color: var(--white);
    font-size: 16px;
    margin-bottom: 6px;
    text-transform: uppercase;
  }
