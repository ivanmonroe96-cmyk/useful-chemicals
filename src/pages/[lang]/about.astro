---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations, t, localizedPath, getLangStaticPaths } from '../../i18n/index';
import { defaultLang } from '../../i18n/languages';

export const getStaticPaths = getLangStaticPaths;
const lang = Astro.params.lang ?? defaultLang;
const tr = getTranslations(lang);
const lp = (path: string) => localizedPath(path, lang);

const aboutSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": t(tr, "about.meta_title"),
  "description": t(tr, "about.meta_desc"),
  "mainEntity": {
    "@type": "Organization",
    "name": "UE Chemicals",
    "description": t(tr, 'site.organization_description'),
    "foundingLocation": { "@type": "Place", "name": "Bangkok, Thailand" },
    "address": { "@type": "PostalAddress", "addressLocality": "Bangkok", "postalCode": "10110", "addressCountry": "TH" },
    "email": "info@useful-chemicals.com",
    "telephone": "+66-951690848",
    "knowsAbout": ["Caluanie Muelear Oxidize", "Red Liquid Mercury", "Silver Liquid Mercury", "Industrial Chemical Supply", "Chemical Quality Assurance"],
    "hasCredential": [
      { "@type": "EducationalOccupationalCredential", "credentialCategory": "ISO 9001:2015" },
      { "@type": "EducationalOccupationalCredential", "credentialCategory": "ISO 14001:2015" }
    ],
    "areaServed": { "@type": "Place", "name": "Worldwide" },
    "numberOfEmployees": { "@type": "QuantitativeValue", "minValue": 10 }
  },
  "review": [
    {
      "@type": "Review",
      "author": { "@type": "Person", "name": t(tr, "about.testimonial1_author") },
      "reviewBody": t(tr, "about.testimonial1_text"),
      "reviewRating": { "@type": "Rating", "ratingValue": "5" }
    },
    {
      "@type": "Review",
      "author": { "@type": "Person", "name": t(tr, "about.testimonial2_author") },
      "reviewBody": t(tr, "about.testimonial2_text"),
      "reviewRating": { "@type": "Rating", "ratingValue": "5" }
    },
    {
      "@type": "Review",
      "author": { "@type": "Person", "name": t(tr, "about.testimonial3_author") },
      "reviewBody": t(tr, "about.testimonial3_text"),
      "reviewRating": { "@type": "Rating", "ratingValue": "5" }
    },
    {
      "@type": "Review",
      "author": { "@type": "Person", "name": t(tr, "about.testimonial4_author") },
      "reviewBody": t(tr, "about.testimonial4_text"),
      "reviewRating": { "@type": "Rating", "ratingValue": "5" }
    }
  ]
};
---


<BaseLayout lang={lang} title={t(tr, "about.meta_title")} description={t(tr, "about.meta_desc")} activePage="about" jsonLd={aboutSchema}>

  <!-- ========== HERO ========== -->
  <section class="ab-hero">
    <div class="ab-hero-bg">
      <img src="/images/about/bentech-plant2-solarpanel-6-1.jpg" alt="UE Chemicals BTC Plant 2 — aerial view of manufacturing complex with solar energy installation" />
      <div class="ab-hero-overlay"></div>
    </div>
    <div class="container ab-hero-inner">
      <div class="ab-hero-content">
        <div class="ab-hero-badge"><i class="fas fa-shield-halved"></i> {t(tr, "about.hero_badge")}</div>
        <h1>{t(tr, "about.hero_title")}</h1>
        <p class="ab-hero-sub">{t(tr, "about.hero_sub")}</p>
        <div class="ab-hero-actions">
          <a href={lp("/products")} class="btn btn-accent">{t(tr, "about.hero_cta_products")} <i class="fas fa-arrow-right"></i></a>
          <a href={lp("/contact")} class="btn btn-outline-white">{t(tr, "about.hero_cta_contact")} <i class="fas fa-arrow-right"></i></a>
        </div>
      </div>
      <div class="ab-hero-stats">
        <div class="ab-hero-stat">
          <span class="ab-hero-stat-num">{t(tr, "about.hero_stat1_num")}</span>
          <span class="ab-hero-stat-label">{t(tr, "about.hero_stat1_label")}</span>
        </div>
        <div class="ab-hero-stat-divider"></div>
        <div class="ab-hero-stat">
          <span class="ab-hero-stat-num">{t(tr, "about.hero_stat2_num")}</span>
          <span class="ab-hero-stat-label">{t(tr, "about.hero_stat2_label")}</span>
        </div>
        <div class="ab-hero-stat-divider"></div>
        <div class="ab-hero-stat">
          <span class="ab-hero-stat-num">{t(tr, "about.hero_stat3_num")}</span>
          <span class="ab-hero-stat-label">{t(tr, "about.hero_stat3_label")}</span>
        </div>
        <div class="ab-hero-stat-divider"></div>
        <div class="ab-hero-stat">
          <span class="ab-hero-stat-num">{t(tr, "about.hero_stat4_num")}</span>
          <span class="ab-hero-stat-label">{t(tr, "about.hero_stat4_label")}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== EMPATHY / CONNECTION ========== -->
  <section class="ab-empathy">
    <div class="container">
      <div class="ab-empathy-inner">
        <div class="ab-empathy-accent"></div>
        <div class="ab-empathy-content">
          <div class="section-label">{t(tr, "about.empathy_label")}</div>
          <h2>{t(tr, "about.empathy_title")}</h2>
          <p>{t(tr, "about.empathy_p1")}</p>
          <p>{t(tr, "about.empathy_p2")}</p>
          <p class="ab-empathy-highlight">{t(tr, "about.empathy_p3")}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHO WE ARE — IDENTITY & MISSION ========== -->
  <section class="ab-identity">
    <div class="ab-identity-image">
      <img src="/images/about/BTC-CHONBURI-PLANT-2-8.1.jpg" alt="UE Chemicals laboratory — professional quality control and precision chemical analysis" loading="lazy" />
    </div>
    <div class="ab-identity-content">
      <div class="section-label">{t(tr, "about.identity_label")}</div>
      <h2>{t(tr, "about.identity_title")}</h2>
      <p>{t(tr, "about.identity_p1")}</p>
      <p>{t(tr, "about.identity_p2")}</p>
      <p>{t(tr, "about.identity_p3")}</p>
      <div class="ab-identity-features">
        <div class="ab-identity-feat">
          <div class="ab-identity-feat-icon"><i class="fas fa-industry"></i></div>
          <div>
            <h6>{t(tr, "about.identity_feat1_title")}</h6>
            <p>{t(tr, "about.identity_feat1_desc")}</p>
          </div>
        </div>
        <div class="ab-identity-feat">
          <div class="ab-identity-feat-icon"><i class="fas fa-heart"></i></div>
          <div>
            <h6>{t(tr, "about.identity_feat2_title")}</h6>
            <p>{t(tr, "about.identity_feat2_desc")}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== EXPERTISE ========== -->
  <section class="ab-expertise">
    <div class="container">
      <div class="ab-expertise-header">
        <div class="section-label">{t(tr, "about.expertise_label")}</div>
        <h2>{t(tr, "about.expertise_title")}</h2>
        <p class="ab-expertise-intro">{t(tr, "about.expertise_p1")}</p>
      </div>
      <div class="ab-expertise-grid">
        <div class="ab-expertise-card">
          <div class="ab-expertise-icon"><img src="/images/certs/iso-9001.svg" alt="ISO 9001:2015" loading="lazy" /></div>
          <h5>{t(tr, "about.expertise_item1_title")}</h5>
          <p>{t(tr, "about.expertise_item1_desc")}</p>
        </div>
        <div class="ab-expertise-card">
          <div class="ab-expertise-icon"><img src="/images/certs/iso-14001.svg" alt="ISO 14001:2015" loading="lazy" /></div>
          <h5>{t(tr, "about.expertise_item2_title")}</h5>
          <p>{t(tr, "about.expertise_item2_desc")}</p>
        </div>
        <div class="ab-expertise-card">
          <div class="ab-expertise-icon"><img src="/images/certs/reach.svg" alt="REACH & GHS Compliance" loading="lazy" /></div>
          <h5>{t(tr, "about.expertise_item3_title")}</h5>
          <p>{t(tr, "about.expertise_item3_desc")}</p>
        </div>
        <div class="ab-expertise-card">
          <div class="ab-expertise-icon"><i class="fas fa-flask-vial"></i></div>
          <h5>{t(tr, "about.expertise_item4_title")}</h5>
          <p>{t(tr, "about.expertise_item4_desc")}</p>
        </div>
        <div class="ab-expertise-card">
          <div class="ab-expertise-icon"><i class="fas fa-list-check"></i></div>
          <h5>{t(tr, "about.expertise_item5_title")}</h5>
          <p>{t(tr, "about.expertise_item5_desc")}</p>
        </div>
        <div class="ab-expertise-card">
          <div class="ab-expertise-icon"><i class="fas fa-truck"></i></div>
          <h5>{t(tr, "about.expertise_item6_title")}</h5>
          <p>{t(tr, "about.expertise_item6_desc")}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PROOF OF DELIVERY ========== -->
  <section class="ab-delivery">
    <div class="container">
      <div class="ab-delivery-grid">
        <div class="ab-delivery-content">
          <div class="section-label">{t(tr, "about.delivery_label")}</div>
          <h2>{t(tr, "about.delivery_title")}</h2>
          <p>{t(tr, "about.delivery_p1")}</p>
          <p>{t(tr, "about.delivery_p2")}</p>
        </div>
        <div class="ab-delivery-cards">
          <div class="ab-delivery-card">
            <div class="ab-delivery-card-icon"><i class="fas fa-location-dot"></i></div>
            <div>
              <h5>{t(tr, "about.delivery_item1_title")}</h5>
              <p>{t(tr, "about.delivery_item1_desc")}</p>
            </div>
          </div>
          <div class="ab-delivery-card">
            <div class="ab-delivery-card-icon"><i class="fas fa-box"></i></div>
            <div>
              <h5>{t(tr, "about.delivery_item2_title")}</h5>
              <p>{t(tr, "about.delivery_item2_desc")}</p>
            </div>
          </div>
          <div class="ab-delivery-card">
            <div class="ab-delivery-card-icon"><i class="fas fa-truck-fast"></i></div>
            <div>
              <h5>{t(tr, "about.delivery_item3_title")}</h5>
              <p>{t(tr, "about.delivery_item3_desc")}</p>
            </div>
          </div>
          <div class="ab-delivery-card">
            <div class="ab-delivery-card-icon"><i class="fas fa-file-lines"></i></div>
            <div>
              <h5>{t(tr, "about.delivery_item4_title")}</h5>
              <p>{t(tr, "about.delivery_item4_desc")}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== QUALITY ASSURANCE PROCESS ========== -->
  <section class="ab-quality">
    <div class="container">
      <div class="ab-quality-header">
        <div class="section-label">{t(tr, "about.quality_label")}</div>
        <h2>{t(tr, "about.quality_title")}</h2>
        <p>{t(tr, "about.quality_p1")}</p>
      </div>
      <div class="ab-quality-steps">
        <div class="ab-quality-step">
          <div class="ab-quality-step-num">01</div>
          <div class="ab-quality-step-body">
            <h5>{t(tr, "about.quality_step1_title")}</h5>
            <p>{t(tr, "about.quality_step1_desc")}</p>
          </div>
        </div>
        <div class="ab-quality-step">
          <div class="ab-quality-step-num">02</div>
          <div class="ab-quality-step-body">
            <h5>{t(tr, "about.quality_step2_title")}</h5>
            <p>{t(tr, "about.quality_step2_desc")}</p>
          </div>
        </div>
        <div class="ab-quality-step">
          <div class="ab-quality-step-num">03</div>
          <div class="ab-quality-step-body">
            <h5>{t(tr, "about.quality_step3_title")}</h5>
            <p>{t(tr, "about.quality_step3_desc")}</p>
          </div>
        </div>
        <div class="ab-quality-step">
          <div class="ab-quality-step-num">04</div>
          <div class="ab-quality-step-body">
            <h5>{t(tr, "about.quality_step4_title")}</h5>
            <p>{t(tr, "about.quality_step4_desc")}</p>
          </div>
        </div>
        <div class="ab-quality-step">
          <div class="ab-quality-step-num">05</div>
          <div class="ab-quality-step-body">
            <h5>{t(tr, "about.quality_step5_title")}</h5>
            <p>{t(tr, "about.quality_step5_desc")}</p>
          </div>
        </div>
      </div>
      <div class="ab-quality-coa">
        <i class="fas fa-certificate"></i>
        <p>{t(tr, "about.quality_coa")}</p>
      </div>
    </div>
  </section>

  <!-- ========== CUSTOMER FOCUS ========== -->
  <section class="ab-customer">
    <div class="ab-customer-image">
      <img src="/images/about/BTC-CHONBURI-PLANT-2-5.6-scaled.jpg" alt="UE Chemicals customer service and support team" loading="lazy" />
    </div>
    <div class="ab-customer-content">
      <div class="section-label">{t(tr, "about.customer_label")}</div>
      <h2>{t(tr, "about.customer_title")}</h2>
      <p>{t(tr, "about.customer_p1")}</p>
      <div class="ab-customer-items">
        <div class="ab-customer-item">
          <div class="ab-customer-item-icon"><i class="fas fa-clock"></i></div>
          <div>
            <h6>{t(tr, "about.customer_item1_title")}</h6>
            <p>{t(tr, "about.customer_item1_desc")}</p>
          </div>
        </div>
        <div class="ab-customer-item">
          <div class="ab-customer-item-icon"><i class="fas fa-user-tie"></i></div>
          <div>
            <h6>{t(tr, "about.customer_item2_title")}</h6>
            <p>{t(tr, "about.customer_item2_desc")}</p>
          </div>
        </div>
        <div class="ab-customer-item">
          <div class="ab-customer-item-icon"><i class="fas fa-sliders"></i></div>
          <div>
            <h6>{t(tr, "about.customer_item3_title")}</h6>
            <p>{t(tr, "about.customer_item3_desc")}</p>
          </div>
        </div>
        <div class="ab-customer-item">
          <div class="ab-customer-item-icon"><i class="fas fa-comments"></i></div>
          <div>
            <h6>{t(tr, "about.customer_item4_title")}</h6>
            <p>{t(tr, "about.customer_item4_desc")}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TESTIMONIALS ========== -->
  <section class="ab-testimonials">
    <div class="container">
      <div class="ab-testimonials-header">
        <div class="section-label">{t(tr, "about.testimonials_label")}</div>
        <h2>{t(tr, "about.testimonials_title")}</h2>
      </div>
      <div class="ab-testimonials-grid">
        <div class="ab-testimonial-card">
          <div class="ab-testimonial-stars">
            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
          </div>
          <blockquote>{t(tr, "about.testimonial1_text")}</blockquote>
          <div class="ab-testimonial-author">
            <div class="ab-testimonial-avatar"><i class="fas fa-user"></i></div>
            <div>
              <strong>{t(tr, "about.testimonial1_author")}</strong>
              <span>{t(tr, "about.testimonial1_location")}</span>
            </div>
          </div>
        </div>
        <div class="ab-testimonial-card">
          <div class="ab-testimonial-stars">
            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
          </div>
          <blockquote>{t(tr, "about.testimonial2_text")}</blockquote>
          <div class="ab-testimonial-author">
            <div class="ab-testimonial-avatar"><i class="fas fa-user"></i></div>
            <div>
              <strong>{t(tr, "about.testimonial2_author")}</strong>
              <span>{t(tr, "about.testimonial2_location")}</span>
            </div>
          </div>
        </div>
        <div class="ab-testimonial-card">
          <div class="ab-testimonial-stars">
            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
          </div>
          <blockquote>{t(tr, "about.testimonial3_text")}</blockquote>
          <div class="ab-testimonial-author">
            <div class="ab-testimonial-avatar"><i class="fas fa-user"></i></div>
            <div>
              <strong>{t(tr, "about.testimonial3_author")}</strong>
              <span>{t(tr, "about.testimonial3_location")}</span>
            </div>
          </div>
        </div>
        <div class="ab-testimonial-card">
          <div class="ab-testimonial-stars">
            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
          </div>
          <blockquote>{t(tr, "about.testimonial4_text")}</blockquote>
          <div class="ab-testimonial-author">
            <div class="ab-testimonial-avatar"><i class="fas fa-user"></i></div>
            <div>
              <strong>{t(tr, "about.testimonial4_author")}</strong>
              <span>{t(tr, "about.testimonial4_location")}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TRANSPARENCY ========== -->
  <section class="ab-transparency">
    <div class="container">
      <div class="ab-transparency-inner">
        <div class="ab-transparency-content">
          <div class="section-label">{t(tr, "about.transparency_label")}</div>
          <h2>{t(tr, "about.transparency_title")}</h2>
          <p>{t(tr, "about.transparency_p1")}</p>
        </div>
        <ul class="ab-transparency-list">
          <li><i class="fas fa-check"></i> <span>{t(tr, "about.transparency_item1")}</span></li>
          <li><i class="fas fa-check"></i> <span>{t(tr, "about.transparency_item2")}</span></li>
          <li><i class="fas fa-check"></i> <span>{t(tr, "about.transparency_item3")}</span></li>
          <li><i class="fas fa-check"></i> <span>{t(tr, "about.transparency_item4")}</span></li>
          <li><i class="fas fa-check"></i> <span>{t(tr, "about.transparency_item5")}</span></li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ========== CORE PRODUCTS ========== -->
  <section class="ab-products">
    <div class="container">
      <div class="ab-section-header">
        <div>
          <div class="section-label">{t(tr, "about.products_label")}</div>
          <h2>{t(tr, "about.products_title")}</h2>
        </div>
        <a href={lp("/products")} class="btn btn-outline">{t(tr, "common.view_all_products")} <i class="fas fa-arrow-right"></i></a>
      </div>
      <div class="ab-products-grid">
        <a href={lp("/products/caluanie")} class="ab-prod-card">
          <div class="ab-prod-img">
            <img loading="lazy" src="/images/caluanie-muelear-oxidize-for-sale.jpg" alt="Buy Caluanie Muelear Oxidize — premium quality for sale" />
            <div class="ab-prod-num">01</div>
          </div>
          <div class="ab-prod-body">
            <h3>{t(tr, "about.prod1_name")}</h3>
            <p>{t(tr, "about.prod1_desc")}</p>
            <span class="ab-prod-link">{t(tr, "common.learn_more")} <i class="fas fa-arrow-right"></i></span>
          </div>
        </a>
        <a href={lp("/products/red-mercury")} class="ab-prod-card">
          <div class="ab-prod-img">
            <img loading="lazy" src="/images/red-liquid-mercury-for-sale-usa.png" alt="Red Liquid Mercury for sale — laboratory grade" />
            <div class="ab-prod-num">02</div>
          </div>
          <div class="ab-prod-body">
            <h3>{t(tr, "about.prod2_name")}</h3>
            <p>{t(tr, "about.prod2_desc")}</p>
            <span class="ab-prod-link">{t(tr, "common.learn_more")} <i class="fas fa-arrow-right"></i></span>
          </div>
        </a>
        <a href={lp("/products/silver-mercury")} class="ab-prod-card">
          <div class="ab-prod-img">
            <img loading="lazy" src="/images/silver-liquid-mercury-for-sale.png" alt="Silver Liquid Mercury 99.99% purity for sale" />
            <div class="ab-prod-num">03</div>
          </div>
          <div class="ab-prod-body">
            <h3>{t(tr, "about.prod3_name")}</h3>
            <p>{t(tr, "about.prod3_desc")}</p>
            <span class="ab-prod-link">{t(tr, "common.learn_more")} <i class="fas fa-arrow-right"></i></span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ========== FACILITY ========== -->
  <section class="ab-facility">
    <div class="ab-facility-content">
      <div class="section-label">{t(tr, "about.facility_label")}</div>
      <h2>{t(tr, "about.facility_title")}</h2>
      <p>{t(tr, "about.facility_p1")}</p>
      <p>{t(tr, "about.facility_p2")}</p>
      <a href={lp("/certificates")} class="btn btn-primary">{t(tr, "common.certificates")} <i class="fas fa-arrow-right"></i></a>
    </div>
    <div class="ab-facility-image">
      <img loading="lazy" src="/images/about/BTC-P2-1.jpg" alt="UE Chemicals manufacturing facility in Bangkok, Thailand" />
    </div>
  </section>

  <!-- ========== FACILITY GALLERY ========== -->
  <section class="ab-gallery">
    <div class="ab-gallery-grid">
      <div class="ab-gallery-item ab-gallery-featured">
        <img loading="lazy" src="/images/about/bentech-plant2-solarpanel-4-1.jpg" alt="UE Chemicals BTC Plant 2 — aerial overview of full manufacturing complex" />
      </div>
      <div class="ab-gallery-item">
        <img loading="lazy" src="/images/about/bentech-plant2-solarpanel-2-1.jpg" alt="UE Chemicals facility solar panel installation — renewable energy operations" />
      </div>
      <div class="ab-gallery-item">
        <img loading="lazy" src="/images/about/Storage-Rack-2_0.jpg" alt="UE Chemicals chemical storage warehouse — safety-compliant organized inventory" />
      </div>
      <div class="ab-gallery-item">
        <img loading="lazy" src="/images/about/Whisk_09152e171d89c6285db4abb298799bacdr.png" alt="UE Chemicals industrial chemical processing and formulation equipment" />
      </div>
      <div class="ab-gallery-item">
