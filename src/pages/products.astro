---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTranslations, t, localizedPath } from '../i18n/index';
import { defaultLang } from '../i18n/languages';

const lang = defaultLang;
const tr = getTranslations(lang);
const lp = (path: string) => localizedPath(path, lang);
const products = tr.products;

const productListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": products.hero_title,
  "description": products.meta_desc,
  "numberOfItems": 3,
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": products.caluanie_title, "url": "https://useful-chemicals.com/products/caluanie" },
    { "@type": "ListItem", "position": 2, "name": products.red_title, "url": "https://useful-chemicals.com/products/red-mercury" },
    { "@type": "ListItem", "position": 3, "name": products.silver_title, "url": "https://useful-chemicals.com/products/silver-mercury" }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": tr.nav.home, "item": "https://useful-chemicals.com/" },
    { "@type": "ListItem", "position": 2, "name": tr.nav.products, "item": "https://useful-chemicals.com/products" }
  ]
};
---


<BaseLayout lang={lang} title={t(tr, "products.meta_title")} description={t(tr, "products.meta_desc")} activePage="products" jsonLd={[productListSchema, breadcrumbSchema]}>

  <!-- ========== HERO ========== -->
  <section class="pr-hero">
    <div class="pr-hero-bg">
      <img src="/images/industrial-worker-holding-plastic-cans-with-chemicals-production-plant.jpg" alt={t(tr, "products.hero_title")} />
      <div class="pr-hero-overlay"></div>
    </div>
    <div class="container pr-hero-inner">
      <div class="pr-hero-content">
        <div class="pr-hero-badge"><i class="fas fa-flask"></i> {t(tr, "products.hero_badge")}</div>
        <h1>{t(tr, "products.hero_title")}</h1>
        <p class="pr-hero-sub">{t(tr, "products.hero_sub")}</p>
        <div class="pr-hero-actions">
          <a href={lp("/contact")} class="btn btn-accent">{t(tr, "common.get_quote")} <i class="fas fa-arrow-right"></i></a>
          <a href={lp("/applications")} class="btn btn-outline-white">{t(tr, "common.view_applications")} <i class="fas fa-arrow-right"></i></a>
        </div>
      </div>
      <div class="pr-hero-stats">
        <div class="pr-hero-stat">
          <span class="pr-hero-stat-num">3</span>
          <span class="pr-hero-stat-label">{t(tr, "products.stat1_label")}</span>
        </div>
        <div class="pr-hero-stat-divider"></div>
        <div class="pr-hero-stat">
          <span class="pr-hero-stat-num">99.99%</span>
          <span class="pr-hero-stat-label">{t(tr, "products.stat2_label")}</span>
        </div>
        <div class="pr-hero-stat-divider"></div>
        <div class="pr-hero-stat">
          <span class="pr-hero-stat-num">{t(tr, "products.stat3_num")}</span>
          <span class="pr-hero-stat-label">{t(tr, "products.stat3_label")}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE ========== -->
  <section class="pr-features">
    <div class="container">
      <div class="pr-features-grid">
        <div class="pr-feat">
          <div class="pr-feat-icon"><i class="fas fa-microscope"></i></div>
          <h5>{t(tr, "products.feat1_title")}</h5>
          <p>{t(tr, "products.feat1_desc")}</p>
        </div>
        <div class="pr-feat">
          <div class="pr-feat-icon"><i class="fas fa-shield-halved"></i></div>
          <h5>{t(tr, "products.feat2_title")}</h5>
          <p>{t(tr, "products.feat2_desc")}</p>
        </div>
        <div class="pr-feat">
          <div class="pr-feat-icon"><i class="fas fa-headset"></i></div>
          <h5>{t(tr, "products.feat3_title")}</h5>
          <p>{t(tr, "products.feat3_desc")}</p>
        </div>
        <div class="pr-feat">
          <div class="pr-feat-icon"><i class="fas fa-truck-fast"></i></div>
          <h5>{t(tr, "products.feat4_title")}</h5>
          <p>{t(tr, "products.feat4_desc")}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRODUCT SHOWCASE ========== -->
  <section class="pr-showcase">
    <!-- Caluanie -->
    <div class="pr-block">
      <div class="pr-block-image">
        <img src="/images/caluanie-muelear-oxidize-for-sale.jpg" alt={t(tr, "products.caluanie_title")} />
        <div class="pr-block-num">01</div>
      </div>
      <div class="pr-block-content">
        <div class="pr-block-tag">{t(tr, "products.caluanie_tag")}</div>
        <h2>{t(tr, "products.caluanie_title")}</h2>
        <p>{t(tr, "products.caluanie_desc")}</p>
        <div class="pr-block-specs">
          <div class="pr-block-spec">
            <span class="pr-block-spec-label">{t(tr, "products.caluanie_spec1_label")}</span>
            <span>{t(tr, "products.caluanie_spec1")}</span>
          </div>
          <div class="pr-block-spec">
            <span class="pr-block-spec-label">{t(tr, "products.caluanie_spec2_label")}</span>
            <span>{t(tr, "products.caluanie_spec2")}</span>
          </div>
          <div class="pr-block-spec">
            <span class="pr-block-spec-label">{t(tr, "products.caluanie_spec3_label")}</span>
            <span>{t(tr, "products.caluanie_spec3")}</span>
          </div>
        </div>
        <a href={lp("/products/caluanie")} class="btn btn-primary">{t(tr, "common.view_full_details")} <i class="fas fa-arrow-right"></i></a>
      </div>
    </div>

    <!-- Red Mercury -->
    <div class="pr-block pr-block--reverse">
      <div class="pr-block-image">
        <img src="/images/red-liquid-mercury-for-sale-usa.png" alt={t(tr, "products.red_title")} />
        <div class="pr-block-num">02</div>
      </div>
      <div class="pr-block-content">
        <div class="pr-block-tag">{t(tr, "products.red_tag")}</div>
        <h2>{t(tr, "products.red_title")}</h2>
        <p>{t(tr, "products.red_desc")}</p>
        <div class="pr-block-specs">
          <div class="pr-block-spec">
            <span class="pr-block-spec-label">{t(tr, "products.red_spec1_label")}</span>
            <span>{t(tr, "products.red_spec1")}</span>
          </div>
          <div class="pr-block-spec">
            <span class="pr-block-spec-label">{t(tr, "products.red_spec2_label")}</span>
            <span>{t(tr, "products.red_spec2")}</span>
          </div>
          <div class="pr-block-spec">
            <span class="pr-block-spec-label">{t(tr, "products.red_spec3_label")}</span>
            <span>{t(tr, "products.red_spec3")}</span>
          </div>
        </div>
        <a href={lp("/products/red-mercury")} class="btn btn-primary">{t(tr, "common.view_full_details")} <i class="fas fa-arrow-right"></i></a>
      </div>
    </div>

    <!-- Silver Mercury -->
    <div class="pr-block">
      <div class="pr-block-image">
        <img src="/images/silver-liquid-mercury-for-sale.png" alt={t(tr, "products.silver_title")} />
        <div class="pr-block-num">03</div>
      </div>
      <div class="pr-block-content">
        <div class="pr-block-tag">{t(tr, "products.silver_tag")}</div>
        <h2>{t(tr, "products.silver_title")}</h2>
        <p>{t(tr, "products.silver_desc")}</p>
        <div class="pr-block-specs">
          <div class="pr-block-spec">
            <span class="pr-block-spec-label">{t(tr, "products.silver_spec1_label")}</span>
            <span>{t(tr, "products.silver_spec1")}</span>
          </div>
          <div class="pr-block-spec">
            <span class="pr-block-spec-label">{t(tr, "products.silver_spec2_label")}</span>
            <span>{t(tr, "products.silver_spec2")}</span>
          </div>
          <div class="pr-block-spec">
            <span class="pr-block-spec-label">{t(tr, "products.silver_spec3_label")}</span>
            <span>{t(tr, "products.silver_spec3")}</span>
          </div>
        </div>
        <a href={lp("/products/silver-mercury")} class="btn btn-primary">{t(tr, "common.view_full_details")} <i class="fas fa-arrow-right"></i></a>
      </div>
    </div>
  </section>

  <!-- ========== CTA ========== -->
  <section class="pr-cta">
    <div class="container">
      <div class="pr-cta-inner">
        <div class="pr-cta-content">
          <h2>{t(tr, "products.cta_title")}</h2>
          <p>{t(tr, "products.cta_desc")}</p>
        </div>
        <div class="pr-cta-actions">
          <a href={lp("/contact")} class="btn btn-white">{t(tr, "common.get_quote")} <i class="fas fa-arrow-right"></i></a>
          <a href={lp("/applications")} class="btn btn-outline-white">{t(tr, "common.view_applications")} <i class="fas fa-arrow-right"></i></a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .pr-hero { position: relative; min-height: 85vh; display: flex; align-items: center; overflow: hidden; }
  .pr-hero-bg { position: absolute; inset: 0; z-index: 0; }
  .pr-hero-bg img { width: 100%; height: 100%; object-fit: cover; }
  .pr-hero-overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(25,24,23,0.93) 0%, rgba(25,24,23,0.75) 50%, rgba(252,82,32,0.12) 100%); }
  .pr-hero-inner { position: relative; z-index: 1; padding-top: 140px; padding-bottom: 100px; }
  .pr-hero-content { max-width: 680px; }
  .pr-hero-badge { display: inline-flex; align-items: center; gap: 10px; padding: 8px 20px; border: 1px solid rgba(255,255,255,0.2); font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: rgba(255,255,255,0.8); margin-bottom: 24px; }
  .pr-hero-badge i { color: var(--accent); font-size: 13px; }
  .pr-hero h1 { color: var(--white); font-size: clamp(38px, 5.5vw, 72px); line-height: 1.05; margin-bottom: 24px; letter-spacing: -1px; }
  .pr-hero-sub { color: rgba(255,255,255,0.65); font-size: 18px; line-height: 1.7; max-width: 540px; margin-bottom: 40px; }
  .pr-hero-actions { display: flex; gap: 16px; flex-wrap: wrap; }
  .btn-outline-white { background: transparent; color: var(--white); border: 2px solid rgba(255,255,255,0.3); }
  .btn-outline-white:hover { background: var(--white); color: var(--near-black); border-color: var(--white); }
  .pr-hero-stats { display: flex; align-items: center; gap: 40px; margin-top: 80px; padding-top: 40px; border-top: 1px solid rgba(255,255,255,0.12); }
  .pr-hero-stat-num { display: block; font-size: 28px; font-weight: 800; color: var(--white); }
  .pr-hero-stat-label { display: block; font-size: 13px; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 1px; margin-top: 4px; }
  .pr-hero-stat-divider { width: 1px; height: 50px; background: rgba(255,255,255,0.12); }

  /* Features */
  .pr-features { padding: 0; background: var(--white); border-bottom: 1px solid var(--border); }
  .pr-features-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; }
  .pr-feat { padding: 50px 30px; border-left: 1px solid var(--border); text-align: center; transition: var(--transition); }
  .pr-feat:last-child { border-right: 1px solid var(--border); }
  .pr-feat:hover { background: var(--light-bg); }
  .pr-feat-icon { width: 56px; height: 56px; margin: 0 auto 20px; background: var(--near-black); display: flex; align-items: center; justify-content: center; color: var(--white); font-size: 20px; }
  .pr-feat h5 { font-size: 15px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
  .pr-feat p { font-size: 14px; color: var(--body-text); margin: 0; line-height: 1.5; }

  /* Product Showcase */
  .pr-showcase { background: var(--white); }
  .pr-block { display: grid; grid-template-columns: 1fr 1fr; min-height: 580px; border-bottom: 1px solid var(--border); }
  .pr-block-image { position: relative; overflow: hidden; }
  .pr-block-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
  .pr-block:hover .pr-block-image img { transform: scale(1.04); }
  .pr-block-num { position: absolute; top: 30px; left: 30px; font-size: 60px; font-weight: 800; color: var(--white); line-height: 1; opacity: 0.15; letter-spacing: -2px; }
  .pr-block-content { padding: 70px 60px; display: flex; flex-direction: column; justify-content: center; background: var(--light-bg); }
  .pr-block--reverse { direction: rtl; }
  .pr-block--reverse > * { direction: ltr; }
  .pr-block--reverse .pr-block-content { background: var(--white); }
  .pr-block--reverse .pr-block-num { left: auto; right: 30px; }
  .pr-block-tag { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: var(--accent); margin-bottom: 12px; }
  .pr-block-content h2 { font-size: clamp(24px, 3vw, 38px); line-height: 1.15; margin-bottom: 16px; }
  .pr-block-content > p { font-size: 16px; color: var(--body-text); line-height: 1.7; margin-bottom: 24px; max-width: 480px; }
  .pr-block-specs { margin-bottom: 30px; }
  .pr-block-spec { display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid var(--border); font-size: 14px; color: var(--body-text); }
  .pr-block--reverse .pr-block-spec { border-bottom-color: var(--border); }
  .pr-block-spec-label { font-weight: 700; text-transform: uppercase; font-size: 12px; letter-spacing: 1px; color: var(--near-black); }

  /* CTA */
  .pr-cta { padding: 100px 0; background: var(--accent); }
  .pr-cta-inner { display: flex; justify-content: space-between; align-items: center; gap: 40px; }
  .pr-cta-content h2 { color: var(--white); font-size: clamp(28px, 3.5vw, 46px); margin-bottom: 12px; }
  .pr-cta-content p { color: rgba(255,255,255,0.85); max-width: 500px; margin: 0; }
  .pr-cta-actions { display: flex; gap: 16px; flex-shrink: 0; flex-wrap: wrap; }
  .pr-cta .btn-white { border-color: var(--white); }
  .pr-cta .btn-white:hover { background: var(--near-black); color: var(--white); border-color: var(--near-black); }
  .pr-cta .btn-outline-white { border-color: rgba(255,255,255,0.4); }
  .pr-cta .btn-outline-white:hover { background: var(--white); color: var(--accent); border-color: var(--white); }

  @media (max-width: 1024px) {
    .pr-features-grid { grid-template-columns: 1fr 1fr; }
    .pr-feat { border-bottom: 1px solid var(--border); }
    .pr-feat:nth-child(2) { border-right: 1px solid var(--border); }
    .pr-block { grid-template-columns: 1fr; }
    .pr-block--reverse { direction: ltr; }
    .pr-block-image { height: 350px; }
    .pr-block-content { padding: 50px 24px; }
    .pr-cta-inner { flex-direction: column; text-align: center; }
    .pr-cta-actions { justify-content: center; }
  }
  @media (max-width: 768px) {
    .pr-hero { min-height: 75vh; }
    .pr-hero h1 { font-size: clamp(30px, 8vw, 50px); }
    .pr-hero-stats { flex-direction: column; gap: 20px; align-items: flex-start; }
    .pr-hero-stat-divider { width: 100%; height: 1px; }
    .pr-features-grid { grid-template-columns: 1fr; }
    .pr-feat { border-left: 1px solid var(--border); border-right: 1px solid var(--border); }
    .pr-block-image { height: 280px; }
    .pr-cta { padding: 60px 0; }
  }

  @media (max-width: 480px) {
    .pr-feat { padding: 36px 20px; }
    .pr-block-content { padding: 40px 20px; }
    .pr-block-spec { flex-direction: column; align-items: flex-start; gap: 4px; }
    .pr-cta-actions { flex-direction: column; align-items: stretch; }
    .pr-cta-actions .btn { width: 100%; justify-content: center; }
  }
</style>
