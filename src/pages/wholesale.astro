---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Wholesale Chemical Supply in Germany" description="Wholesale industrial chemicals from UE Chemicals, Essen, Germany. Bulk Caluanie Muelear Oxidize, Red Mercury & Silver Mercury. Competitive pricing, global shipping." activePage="wholesale">

  <!-- ========== HERO ========== -->
  <section class="wh-hero">
    <div class="wh-hero-bg">
      <img src="/images/industrial-worker-holding-plastic-cans-with-chemicals-production-plant.jpg" alt="Wholesale industrial chemicals from UE Chemicals Germany" />
      <div class="wh-hero-overlay"></div>
    </div>
    <div class="container wh-hero-inner">
      <div class="wh-hero-content">
        <div class="wh-hero-badge"><i class="fas fa-boxes-stacked"></i> Wholesale Program</div>
        <h1>Wholesale Industrial<br />Chemical Supply</h1>
        <p class="wh-hero-sub">Competitive bulk pricing for Caluanie Muelear Oxidize, Red Liquid Mercury, and Silver Liquid Mercury. Direct from our facility in Essen, Germany.</p>
        <div class="wh-hero-actions">
          <a href="/contact" class="btn btn-accent">Request Wholesale Quote <i class="fas fa-arrow-right"></i></a>
          <a href="/products" class="btn btn-outline-white">View Products <i class="fas fa-arrow-right"></i></a>
        </div>
      </div>
      <div class="wh-hero-highlights">
        <div class="wh-highlight"><i class="fas fa-percent"></i><span>Volume Discounts</span></div>
        <div class="wh-highlight"><i class="fas fa-truck-fast"></i><span>Priority Shipping</span></div>
        <div class="wh-highlight"><i class="fas fa-headset"></i><span>Dedicated Manager</span></div>
        <div class="wh-highlight"><i class="fas fa-earth-europe"></i><span>Global Delivery</span></div>
      </div>
    </div>
  </section>

  <!-- ========== BENEFITS ========== -->
  <section class="wh-benefits">
    <div class="container">
      <div class="wh-section-header">
        <div class="section-label">Why Order Wholesale</div>
        <h2>Benefits of Bulk Purchasing</h2>
        <p>Whether you're a distributor, manufacturer, or large-scale operation, our wholesale program saves you money while guaranteeing consistent supply.</p>
      </div>
      <div class="wh-benefits-grid">
        <div class="wh-benefit-card">
          <div class="wh-benefit-num">01</div>
          <div class="wh-benefit-icon"><i class="fas fa-percent"></i></div>
          <h4>Volume Discounts</h4>
          <p>Significant price reductions on bulk orders. The more you order, the more you save. Custom quotes for repeat buyers.</p>
        </div>
        <div class="wh-benefit-card">
          <div class="wh-benefit-num">02</div>
          <div class="wh-benefit-icon"><i class="fas fa-handshake"></i></div>
          <h4>Dedicated Account Manager</h4>
          <p>Personal account manager for priority support, order tracking, and streamlined reordering.</p>
        </div>
        <div class="wh-benefit-card">
          <div class="wh-benefit-num">03</div>
          <div class="wh-benefit-icon"><i class="fas fa-truck-fast"></i></div>
          <h4>Priority Shipping</h4>
          <p>Priority processing and expedited shipping. Scheduled recurring deliveries for production continuity.</p>
        </div>
        <div class="wh-benefit-card">
          <div class="wh-benefit-num">04</div>
          <div class="wh-benefit-icon"><i class="fas fa-file-certificate"></i></div>
          <h4>Full Documentation</h4>
          <p>Every order includes COA, SDS, TDS, and customs documentation for regulatory compliance.</p>
        </div>
        <div class="wh-benefit-card">
          <div class="wh-benefit-num">05</div>
          <div class="wh-benefit-icon"><i class="fas fa-boxes-stacked"></i></div>
          <h4>Flexible Pack Sizes</h4>
          <p>Customized quantities from small bulk to full container loads. Steel flasks and custom packaging.</p>
        </div>
        <div class="wh-benefit-card">
          <div class="wh-benefit-num">06</div>
          <div class="wh-benefit-icon"><i class="fas fa-earth-europe"></i></div>
          <h4>Worldwide Delivery</h4>
          <p>Licensed hazmat carriers for safe international delivery. EU, Americas, Asia, Africa. Full ADR/IMDG compliance.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRODUCTS ========== -->
  <section class="wh-products">
    <div class="container">
      <div class="wh-section-header">
        <div class="section-label">Wholesale Products</div>
        <h2>Available for Bulk Purchase</h2>
      </div>
      <div class="wh-products-grid">
        <div class="wh-product-card">
          <div class="wh-product-accent"></div>
          <div class="wh-product-inner">
            <div class="wh-product-head">
              <h3>Caluanie Muelear Oxidize</h3>
              <span class="wh-product-badge">Liquid Oxidizer</span>
            </div>
            <ul class="wh-product-specs">
              <li><span class="wh-spec-label">Application</span><span>Metalworking, Refining, Crushing</span></li>
              <li><span class="wh-spec-label">Density</span><span>1.86 g/cm³</span></li>
              <li><span class="wh-spec-label">Pack Sizes</span><span>1L, 5L, 10L, 20L, 50L, 100L</span></li>
              <li><span class="wh-spec-label">MOQ</span><span>5 Liters</span></li>
              <li class="wh-spec-stock"><i class="fas fa-circle-check"></i> In Stock — Year-Round Supply</li>
            </ul>
            <a href="/products/caluanie" class="wh-product-btn">View Details <i class="fas fa-arrow-right"></i></a>
          </div>
        </div>
        <div class="wh-product-card">
          <div class="wh-product-accent wh-accent-red"></div>
          <div class="wh-product-inner">
            <div class="wh-product-head">
              <h3>Red Liquid Mercury</h3>
              <span class="wh-product-badge wh-badge-red">Sb₂O₇Hg₂</span>
            </div>
            <ul class="wh-product-specs">
              <li><span class="wh-spec-label">Purity</span><span>99.999% (5N Grade)</span></li>
              <li><span class="wh-spec-label">Density</span><span>20.2 g/cm³</span></li>
              <li><span class="wh-spec-label">Formula</span><span>Sb₂O₇Hg₂</span></li>
              <li><span class="wh-spec-label">Pack Sizes</span><span>1 kg, 5 kg, 17.5 kg, 34.5 kg</span></li>
              <li class="wh-spec-stock"><i class="fas fa-circle-check"></i> In Stock</li>
            </ul>
            <a href="/products/red-mercury" class="wh-product-btn">View Details <i class="fas fa-arrow-right"></i></a>
          </div>
        </div>
        <div class="wh-product-card">
          <div class="wh-product-accent wh-accent-silver"></div>
          <div class="wh-product-inner">
            <div class="wh-product-head">
              <h3>Silver Liquid Mercury</h3>
              <span class="wh-product-badge wh-badge-silver">CAS 7439-97-6</span>
            </div>
            <ul class="wh-product-specs">
              <li><span class="wh-spec-label">Purity</span><span>99.99% (4N Grade)</span></li>
              <li><span class="wh-spec-label">Density</span><span>13.534 g/cm³</span></li>
              <li><span class="wh-spec-label">Pack Sizes</span><span>34.5 kg Flask, 76 lb, 2204 lb</span></li>
              <li><span class="wh-spec-label">MOQ</span><span>1 × 34.5 kg Flask</span></li>
              <li class="wh-spec-stock"><i class="fas fa-circle-check"></i> In Stock — Continuous Production</li>
            </ul>
            <a href="/products/silver-mercury" class="wh-product-btn">View Details <i class="fas fa-arrow-right"></i></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PROCESS ========== -->
  <section class="wh-process">
    <div class="container">
      <div class="wh-section-header">
        <div class="section-label">Simple Process</div>
        <h2>How Wholesale Ordering Works</h2>
      </div>
      <div class="wh-process-track">
        <div class="wh-process-line"></div>
        <div class="wh-process-steps">
          <div class="wh-process-step">
            <div class="wh-step-dot"><span>1</span></div>
            <div class="wh-step-content">
              <h4>Submit Your Inquiry</h4>
              <p>Contact us with product, quantity, and destination. Our wholesale team responds within 24 hours.</p>
            </div>
          </div>
          <div class="wh-process-step">
            <div class="wh-step-dot"><span>2</span></div>
            <div class="wh-step-content">
              <h4>Receive Proforma Invoice</h4>
              <p>Detailed invoice with wholesale pricing, shipping costs, payment instructions, and delivery timeline.</p>
            </div>
          </div>
          <div class="wh-process-step">
            <div class="wh-step-dot"><span>3</span></div>
            <div class="wh-step-content">
              <h4>Confirm &amp; Pay</h4>
              <p>Review and confirm. We accept bank wire transfers and cryptocurrency. Processing takes 1–5 business days.</p>
            </div>
          </div>
          <div class="wh-process-step">
            <div class="wh-step-dot"><span>4</span></div>
            <div class="wh-step-content">
              <h4>Receive Your Order</h4>
              <p>Ships with full documentation (COA, SDS, TDS) and tracking. EU 3–7 days, worldwide 7–21 days.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== INDUSTRIES ========== -->
  <section class="wh-industries">
    <div class="container">
      <div class="wh-section-header">
        <div class="section-label">Who We Serve</div>
        <h2>Industries We Supply</h2>
      </div>
      <div class="wh-industries-grid">
        <div class="wh-industry-card">
          <div class="wh-industry-icon"><i class="fas fa-gears"></i></div>
          <h4>Metal Processing</h4>
          <p>Plants &amp; foundries</p>
        </div>
        <div class="wh-industry-card">
          <div class="wh-industry-icon"><i class="fas fa-gem"></i></div>
          <h4>Mining &amp; Extraction</h4>
          <p>Operations worldwide</p>
        </div>
        <div class="wh-industry-card">
          <div class="wh-industry-icon"><i class="fas fa-flask"></i></div>
          <h4>Chemical Mfg.</h4>
          <p>Manufacturers &amp; formulators</p>
        </div>
        <div class="wh-industry-card">
          <div class="wh-industry-icon"><i class="fas fa-microscope"></i></div>
          <h4>Research Labs</h4>
          <p>Universities &amp; institutes</p>
        </div>
        <div class="wh-industry-card">
          <div class="wh-industry-icon"><i class="fas fa-building"></i></div>
          <h4>Industrial Distributors</h4>
          <p>Bulk resellers</p>
        </div>
        <div class="wh-industry-card">
          <div class="wh-industry-icon"><i class="fas fa-tooth"></i></div>
          <h4>Dental &amp; Medical</h4>
          <p>Suppliers &amp; clinics</p>
        </div>
        <div class="wh-industry-card">
          <div class="wh-industry-icon"><i class="fas fa-microchip"></i></div>
          <h4>Electronics</h4>
          <p>Semiconductor &amp; PCB mfg.</p>
        </div>
        <div class="wh-industry-card">
          <div class="wh-industry-icon"><i class="fas fa-gauge-high"></i></div>
          <h4>Instruments</h4>
          <p>Thermometers &amp; barometers</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== CTA ========== -->
  <section class="wh-cta">
    <div class="container">
      <div class="wh-cta-inner">
        <div class="wh-cta-icon"><i class="fas fa-boxes-stacked"></i></div>
        <h2>Start Your Wholesale Order Today</h2>
        <p>Contact our wholesale team for competitive bulk pricing, volume discounts, and dedicated support. Custom quote within 24 hours.</p>
        <div class="wh-cta-actions">
          <a href="/contact" class="btn btn-white">Request Wholesale Quote <i class="fas fa-arrow-right"></i></a>
          <a href="mailto:info@useful-chemicals.com" class="btn btn-outline-white">Email Us Directly <i class="fas fa-envelope"></i></a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ===== Hero ===== */
  .wh-hero { position: relative; min-height: 60vh; display: flex; align-items: center; }
  .wh-hero-bg { position: absolute; inset: 0; z-index: 0; }
  .wh-hero-bg img { width: 100%; height: 100%; object-fit: cover; }
  .wh-hero-overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(10,15,30,.92), rgba(10,15,30,.68)); }
  .wh-hero-inner { position: relative; z-index: 1; padding: 110px 0 70px; }
  .wh-hero-content { max-width: 680px; margin-bottom: 40px; }
  .wh-hero-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.12); backdrop-filter: blur(8px); padding: 8px 18px; border-radius: 100px; font-size: .85rem; color: var(--accent); margin-bottom: 20px; }
  .wh-hero h1 { font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 800; color: #fff; line-height: 1.15; margin-bottom: 18px; }
  .wh-hero-sub { color: rgba(255,255,255,.75); font-size: 1.1rem; line-height: 1.7; margin-bottom: 30px; }
  .wh-hero-actions { display: flex; gap: 14px; flex-wrap: wrap; }
  .wh-hero-highlights { display: flex; gap: 12px; flex-wrap: wrap; }
  .wh-highlight { display: flex; align-items: center; gap: 8px; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); padding: 10px 18px; border-radius: 10px; color: rgba(255,255,255,.85); font-size: .88rem; font-weight: 500; backdrop-filter: blur(4px); }
  .wh-highlight i { color: var(--accent); font-size: .95rem; }

  /* ===== Section Header ===== */
  .wh-section-header { text-align: center; margin-bottom: 56px; }
  .wh-section-header h2 { font-size: 2rem; font-weight: 800; margin-bottom: 12px; }
  .wh-section-header p { max-width: 660px; margin: 0 auto; color: var(--body-text); line-height: 1.7; }

  /* ===== Benefits ===== */
  .wh-benefits { padding: 100px 0; }
  .wh-benefits-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
  .wh-benefit-card { background: #fff; border: 1px solid var(--border); border-radius: 16px; padding: 32px 28px; transition: all .3s; position: relative; overflow: hidden; }
  .wh-benefit-card:hover { border-color: var(--accent); transform: translateY(-4px); box-shadow: 0 16px 48px rgba(0,0,0,.08); }
  .wh-benefit-num { position: absolute; top: 16px; right: 20px; font-size: 2.5rem; font-weight: 900; color: rgba(252,82,32,.06); line-height: 1; }
  .wh-benefit-icon { width: 48px; height: 48px; border-radius: 12px; background: rgba(252,82,32,.08); display: flex; align-items: center; justify-content: center; font-size: 1.2rem; color: var(--accent); margin-bottom: 18px; }
  .wh-benefit-card h4 { font-size: 1.12rem; font-weight: 700; margin-bottom: 10px; }
  .wh-benefit-card p { color: var(--body-text); line-height: 1.7; font-size: .92rem; }

  /* ===== Products ===== */
  .wh-products { padding: 100px 0; background: var(--light-bg); }
  .wh-products-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
  .wh-product-card { background: #fff; border: 1px solid var(--border); border-radius: 16px; overflow: hidden; display: flex; flex-direction: column; transition: all .3s; }
  .wh-product-card:hover { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(0,0,0,.08); }
  .wh-product-accent { height: 4px; background: linear-gradient(90deg, var(--accent), #e04518); }
  .wh-product-accent.wh-accent-red { background: linear-gradient(90deg, #ef4444, #dc2626); }
  .wh-product-accent.wh-accent-silver { background: linear-gradient(90deg, #94a3b8, #64748b); }
  .wh-product-inner { padding: 32px 28px; display: flex; flex-direction: column; flex: 1; }
  .wh-product-head { margin-bottom: 22px; }
  .wh-product-head h3 { font-size: 1.25rem; font-weight: 700; margin-bottom: 10px; }
  .wh-product-badge { display: inline-block; background: rgba(252,82,32,.08); color: var(--accent); padding: 4px 14px; border-radius: 100px; font-size: .78rem; font-weight: 700; }
  .wh-product-badge.wh-badge-red { background: rgba(239,68,68,.08); color: #ef4444; }
  .wh-product-badge.wh-badge-silver { background: rgba(100,116,139,.1); color: #64748b; }
  .wh-product-specs { list-style: none; padding: 0; margin: 0 0 24px; flex: 1; }
  .wh-product-specs li { display: flex; justify-content: space-between; padding: 11px 0; border-bottom: 1px solid var(--border); font-size: .9rem; color: var(--body-text); }
  .wh-product-specs li:last-child { border-bottom: none; }
  .wh-spec-label { font-weight: 600; color: var(--dark); }
  .wh-spec-stock { color: #16a34a !important; font-weight: 600; font-size: .88rem !important; display: flex !important; align-items: center; gap: 8px; }
  .wh-spec-stock i { font-size: .9rem; }
  .wh-product-btn { display: flex; align-items: center; justify-content: center; gap: 8px; padding: 14px; border: 2px solid var(--border); border-radius: 10px; font-weight: 700; font-size: .92rem; color: var(--dark); transition: all .3s; }
  .wh-product-btn:hover { border-color: var(--accent); color: var(--accent); background: rgba(252,82,32,.04); }

  /* ===== Process ===== */
  .wh-process { padding: 100px 0; }
  .wh-process-track { position: relative; max-width: 800px; margin: 0 auto; }
  .wh-process-line { position: absolute; left: 24px; top: 0; bottom: 0; width: 2px; background: var(--border); }
  .wh-process-steps { display: flex; flex-direction: column; gap: 0; }
  .wh-process-step { display: flex; gap: 28px; padding: 24px 0; position: relative; }
  .wh-step-dot { flex-shrink: 0; width: 48px; height: 48px; border-radius: 50%; background: linear-gradient(135deg, var(--accent), #e04518); display: flex; align-items: center; justify-content: center; position: relative; z-index: 1; box-shadow: 0 4px 16px rgba(252,82,32,.25); }
  .wh-step-dot span { color: #fff; font-weight: 800; font-size: .95rem; }
  .wh-step-content { flex: 1; padding-top: 4px; }
  .wh-step-content h4 { font-size: 1.1rem; font-weight: 700; margin-bottom: 8px; }
  .wh-step-content p { color: var(--body-text); line-height: 1.7; font-size: .92rem; }

  /* ===== Industries ===== */
  .wh-industries { padding: 100px 0; background: var(--light-bg); }
  .wh-industries-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  .wh-industry-card { background: #fff; border: 1px solid var(--border); border-radius: 14px; padding: 28px 22px; text-align: center; transition: all .3s; }
  .wh-industry-card:hover { border-color: var(--accent); transform: translateY(-3px); box-shadow: 0 10px 30px rgba(0,0,0,.06); }
  .wh-industry-icon { width: 48px; height: 48px; margin: 0 auto 14px; border-radius: 12px; background: rgba(252,82,32,.08); display: flex; align-items: center; justify-content: center; font-size: 1.2rem; color: var(--accent); }
  .wh-industry-card h4 { font-size: .98rem; font-weight: 700; margin-bottom: 4px; }
  .wh-industry-card p { font-size: .82rem; color: var(--body-text); }

  /* ===== CTA ===== */
  .wh-cta { padding: 100px 0; }
  .wh-cta-inner { background: linear-gradient(135deg, var(--near-black), var(--dark)); padding: 64px; border-radius: 24px; text-align: center; position: relative; overflow: hidden; }
  .wh-cta-inner::before { content: ''; position: absolute; top: -60px; right: -60px; width: 200px; height: 200px; border-radius: 50%; background: rgba(252,82,32,.12); }
  .wh-cta-inner::after { content: ''; position: absolute; bottom: -80px; left: -40px; width: 240px; height: 240px; border-radius: 50%; background: rgba(252,82,32,.08); }
  .wh-cta-icon { width: 60px; height: 60px; margin: 0 auto 20px; background: rgba(252,82,32,.15); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; color: var(--accent); position: relative; z-index: 1; }
  .wh-cta-inner h2 { color: #fff; font-size: clamp(1.5rem, 3vw, 2rem); margin-bottom: 14px; position: relative; z-index: 1; }
  .wh-cta-inner p { color: rgba(255,255,255,.7); max-width: 580px; margin: 0 auto 30px; line-height: 1.7; position: relative; z-index: 1; }
  .wh-cta-actions { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; position: relative; z-index: 1; }

  /* ===== Responsive ===== */
  @media (max-width: 992px) {
    .wh-benefits-grid, .wh-products-grid { grid-template-columns: repeat(2, 1fr); }
    .wh-industries-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .wh-benefits-grid, .wh-products-grid { grid-template-columns: 1fr; }
    .wh-industries-grid { grid-template-columns: repeat(2, 1fr); }
    .wh-cta-inner { padding: 40px 24px; }
    .wh-hero-highlights { flex-direction: column; }
    .wh-process-line { left: 16px; }
    .wh-step-dot { width: 40px; height: 40px; }
  }
</style>
