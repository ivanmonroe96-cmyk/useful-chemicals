---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Wholesale Chemical Supply in Germany" description="Wholesale industrial chemicals from UE Chemicals, Essen, Germany. Bulk Caluanie Muelear Oxidize, Red Mercury & Silver Mercury. Competitive pricing, global shipping." activePage="wholesale">

  <!-- ========== HERO ========== -->
  <section class="ws-hero">
    <div class="ws-hero-bg">
      <img src="/images/industrial-worker-holding-plastic-cans-with-chemicals-production-plant.jpg" alt="Wholesale industrial chemicals from UE Chemicals Germany" />
      <div class="ws-hero-overlay"></div>
    </div>
    <div class="container ws-hero-inner">
      <div class="ws-hero-content">
        <div class="ws-hero-badge"><i class="fas fa-boxes-stacked"></i> Wholesale Program</div>
        <h1>Wholesale Industrial<br />Chemical Supply</h1>
        <p class="ws-hero-sub">Competitive bulk pricing for Caluanie Muelear Oxidize, Red Liquid Mercury, and Silver Liquid Mercury. Direct from our facility in Essen, Germany.</p>
        <div class="ws-hero-actions">
          <a href="/contact" class="btn btn-accent">Request Wholesale Quote <i class="fas fa-arrow-right"></i></a>
          <a href="/products" class="btn btn-outline-white">View Products <i class="fas fa-arrow-right"></i></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY WHOLESALE ========== -->
  <section class="ws-benefits">
    <div class="container">
      <div class="text-center" style="margin-bottom: 50px;">
        <div class="section-label">Why Order Wholesale</div>
        <h2 class="section-title">Benefits of Bulk Purchasing</h2>
        <p style="max-width: 700px; margin: 0 auto; color: var(--text-secondary);">Whether you're a distributor, manufacturer, or large-scale operation, our wholesale program is designed to save you money while guaranteeing consistent supply.</p>
      </div>
      <div class="ws-benefits-grid">
        <div class="ws-benefit-card">
          <div class="ws-benefit-icon"><i class="fas fa-percent"></i></div>
          <h4>Volume Discounts</h4>
          <p>Significant price reductions on bulk orders. The more you order, the more you save. Custom quotes available for repeat buyers.</p>
        </div>
        <div class="ws-benefit-card">
          <div class="ws-benefit-icon"><i class="fas fa-handshake"></i></div>
          <h4>Dedicated Account Manager</h4>
          <p>Each wholesale client receives a personal account manager for priority support, order tracking, and streamlined reordering.</p>
        </div>
        <div class="ws-benefit-card">
          <div class="ws-benefit-icon"><i class="fas fa-truck-fast"></i></div>
          <h4>Priority Shipping</h4>
          <p>Wholesale orders receive priority processing and expedited shipping. Scheduled recurring deliveries available for production continuity.</p>
        </div>
        <div class="ws-benefit-card">
          <div class="ws-benefit-icon"><i class="fas fa-file-certificate"></i></div>
          <h4>Full Documentation</h4>
          <p>Every order includes Certificate of Analysis (COA), Safety Data Sheet (SDS), Technical Data Sheet (TDS), and customs documentation.</p>
        </div>
        <div class="ws-benefit-card">
          <div class="ws-benefit-icon"><i class="fas fa-boxes-stacked"></i></div>
          <h4>Flexible Pack Sizes</h4>
          <p>Available in customized quantities from small bulk orders to full container loads. Standard steel flasks and custom packaging options.</p>
        </div>
        <div class="ws-benefit-card">
          <div class="ws-benefit-icon"><i class="fas fa-earth-europe"></i></div>
          <h4>Worldwide Delivery</h4>
          <p>Licensed hazmat carriers for safe international delivery. EU, Americas, Asia, Africa, and Oceania. Full ADR and IMDG compliance.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== AVAILABLE PRODUCTS ========== -->
  <section class="ws-products">
    <div class="container">
      <div class="text-center" style="margin-bottom: 50px;">
        <div class="section-label">Wholesale Products</div>
        <h2 class="section-title">Available for Bulk Purchase</h2>
      </div>
      <div class="ws-products-grid">
        <div class="ws-product-card">
          <div class="ws-product-header">
            <h3>Caluanie Muelear Oxidize</h3>
            <span class="ws-product-badge">Liquid Oxidizer</span>
          </div>
          <ul class="ws-product-specs">
            <li><strong>Application:</strong> Metalworking, Refining, Crushing</li>
            <li><strong>Density:</strong> 1.86 g/cm³</li>
            <li><strong>Pack Sizes:</strong> 1L, 5L, 10L, 20L, 50L, 100L</li>
            <li><strong>MOQ:</strong> 5 Liters</li>
            <li><strong>Availability:</strong> In Stock — Year-Round Supply</li>
          </ul>
          <a href="/products/caluanie" class="btn btn-outline" style="width: 100%; text-align: center;">View Product <i class="fas fa-arrow-right"></i></a>
        </div>
        <div class="ws-product-card">
          <div class="ws-product-header">
            <h3>Red Liquid Mercury</h3>
            <span class="ws-product-badge">Sb₂O₇Hg₂</span>
          </div>
          <ul class="ws-product-specs">
            <li><strong>Purity:</strong> 99.999% (5N Grade)</li>
            <li><strong>Density:</strong> 20.2 g/cm³</li>
            <li><strong>Formula:</strong> Sb₂O₇Hg₂ (Antimony Mercury Oxide)</li>
            <li><strong>Pack Sizes:</strong> 1 kg, 5 kg, 17.5 kg, 34.5 kg</li>
            <li><strong>Availability:</strong> In Stock</li>
          </ul>
          <a href="/products/red-mercury" class="btn btn-outline" style="width: 100%; text-align: center;">View Product <i class="fas fa-arrow-right"></i></a>
        </div>
        <div class="ws-product-card">
          <div class="ws-product-header">
            <h3>Silver Liquid Mercury</h3>
            <span class="ws-product-badge">CAS 7439-97-6</span>
          </div>
          <ul class="ws-product-specs">
            <li><strong>Purity:</strong> 99.99% (4N Grade)</li>
            <li><strong>Density:</strong> 13.534 g/cm³</li>
            <li><strong>Pack Sizes:</strong> 34.5 kg Steel Flask, 76 lb, 2204 lb</li>
            <li><strong>MOQ:</strong> 1 × 34.5 kg Flask</li>
            <li><strong>Availability:</strong> In Stock — Continuous Production</li>
          </ul>
          <a href="/products/silver-mercury" class="btn btn-outline" style="width: 100%; text-align: center;">View Product <i class="fas fa-arrow-right"></i></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== HOW IT WORKS ========== -->
  <section class="ws-process">
    <div class="container">
      <div class="text-center" style="margin-bottom: 50px;">
        <div class="section-label">Simple Process</div>
        <h2 class="section-title">How Wholesale Ordering Works</h2>
      </div>
      <div class="ws-process-grid">
        <div class="ws-process-step">
          <div class="ws-process-num">01</div>
          <h4>Submit Your Inquiry</h4>
          <p>Contact us with the product name, desired quantity, and shipping destination. Our wholesale team responds within 24 hours.</p>
        </div>
        <div class="ws-process-step">
          <div class="ws-process-num">02</div>
          <h4>Receive Proforma Invoice</h4>
          <p>We'll send a detailed Proforma Invoice with wholesale pricing, shipping costs, payment instructions, and estimated delivery timeline.</p>
        </div>
        <div class="ws-process-step">
          <div class="ws-process-num">03</div>
          <h4>Confirm & Pay</h4>
          <p>Review the invoice and confirm your order. We accept bank wire transfers and cryptocurrency payments. Payment processing takes 1–5 business days.</p>
        </div>
        <div class="ws-process-step">
          <div class="ws-process-num">04</div>
          <h4>Receive Your Order</h4>
          <p>Your order ships with full documentation (COA, SDS, TDS). Tracking provided. Delivery times: EU 3–7 days, worldwide 7–21 days.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== INDUSTRIES ========== -->
  <section class="ws-industries">
    <div class="container">
      <div class="text-center" style="margin-bottom: 50px;">
        <div class="section-label">Who We Serve</div>
        <h2 class="section-title">Industries We Supply</h2>
      </div>
      <div class="ws-industries-grid">
        <div class="ws-industry-item"><i class="fas fa-gears"></i><span>Metal Processing Plants</span></div>
        <div class="ws-industry-item"><i class="fas fa-gem"></i><span>Mining & Extraction Operations</span></div>
        <div class="ws-industry-item"><i class="fas fa-flask"></i><span>Chemical Manufacturers</span></div>
        <div class="ws-industry-item"><i class="fas fa-microscope"></i><span>Research Laboratories</span></div>
        <div class="ws-industry-item"><i class="fas fa-building"></i><span>Industrial Distributors</span></div>
        <div class="ws-industry-item"><i class="fas fa-tooth"></i><span>Dental & Medical Suppliers</span></div>
        <div class="ws-industry-item"><i class="fas fa-microchip"></i><span>Electronics Manufacturers</span></div>
        <div class="ws-industry-item"><i class="fas fa-gauge-high"></i><span>Instrument Manufacturers</span></div>
      </div>
    </div>
  </section>

  <!-- ========== CTA ========== -->
  <section class="ws-cta">
    <div class="container">
      <div class="ws-cta-inner">
        <h2>Start Your Wholesale Order Today</h2>
        <p>Contact our wholesale team for competitive bulk pricing, volume discounts, and dedicated support. Tell us what you need and we'll provide a custom quote within 24 hours.</p>
        <div class="ws-cta-actions">
          <a href="/contact" class="btn btn-white">Request Wholesale Quote <i class="fas fa-arrow-right"></i></a>
          <a href="mailto:info@useful-chemicals.com" class="btn btn-outline-white">Email Us Directly <i class="fas fa-envelope"></i></a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ===== Wholesale Hero ===== */
  .ws-hero { position: relative; min-height: 55vh; display: flex; align-items: center; }
  .ws-hero-bg { position: absolute; inset: 0; z-index: 0; }
  .ws-hero-bg img { width: 100%; height: 100%; object-fit: cover; }
  .ws-hero-overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(10,15,30,.88), rgba(10,15,30,.65)); }
  .ws-hero-inner { position: relative; z-index: 1; padding: 100px 0 60px; }
  .ws-hero-content { max-width: 680px; }
  .ws-hero-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.12); backdrop-filter: blur(8px); padding: 8px 18px; border-radius: 100px; font-size: .85rem; color: var(--accent); margin-bottom: 20px; }
  .ws-hero h1 { font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 800; color: #fff; line-height: 1.15; margin-bottom: 18px; }
  .ws-hero-sub { color: rgba(255,255,255,.75); font-size: 1.1rem; line-height: 1.7; margin-bottom: 30px; }
  .ws-hero-actions { display: flex; gap: 14px; flex-wrap: wrap; }

  /* ===== Benefits ===== */
  .ws-benefits { padding: 90px 0; background: var(--bg); }
  .ws-benefits-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; }
  .ws-benefit-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 16px; padding: 36px 30px; transition: all .3s; }
  .ws-benefit-card:hover { border-color: var(--accent); transform: translateY(-4px); box-shadow: 0 12px 40px rgba(0,0,0,.08); }
  .ws-benefit-icon { width: 52px; height: 52px; border-radius: 12px; background: rgba(var(--accent-rgb), .1); display: flex; align-items: center; justify-content: center; font-size: 1.3rem; color: var(--accent); margin-bottom: 18px; }
  .ws-benefit-card h4 { font-size: 1.15rem; font-weight: 700; margin-bottom: 10px; }
  .ws-benefit-card p { color: var(--text-secondary); line-height: 1.7; font-size: .95rem; }

  /* ===== Products ===== */
  .ws-products { padding: 90px 0; background: var(--bg-secondary); }
  .ws-products-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; }
  .ws-product-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 16px; padding: 36px 30px; display: flex; flex-direction: column; }
  .ws-product-header { margin-bottom: 20px; }
  .ws-product-header h3 { font-size: 1.3rem; font-weight: 700; margin-bottom: 10px; }
  .ws-product-badge { display: inline-block; background: rgba(var(--accent-rgb), .1); color: var(--accent); padding: 4px 14px; border-radius: 100px; font-size: .8rem; font-weight: 600; }
  .ws-product-specs { list-style: none; padding: 0; margin: 0 0 24px; flex: 1; }
  .ws-product-specs li { padding: 10px 0; border-bottom: 1px solid var(--border); color: var(--text-secondary); font-size: .93rem; }
  .ws-product-specs li:last-child { border-bottom: none; }
  .ws-product-specs li strong { color: var(--text-primary); }

  /* ===== Process ===== */
  .ws-process { padding: 90px 0; background: var(--bg); }
  .ws-process-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px; }
  .ws-process-step { text-align: center; padding: 30px 20px; }
  .ws-process-num { font-size: 2.5rem; font-weight: 800; color: var(--accent); margin-bottom: 16px; }
  .ws-process-step h4 { font-size: 1.1rem; font-weight: 700; margin-bottom: 10px; }
  .ws-process-step p { color: var(--text-secondary); line-height: 1.7; font-size: .93rem; }

  /* ===== Industries ===== */
  .ws-industries { padding: 90px 0; background: var(--bg-secondary); }
  .ws-industries-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  .ws-industry-item { display: flex; align-items: center; gap: 14px; padding: 20px 24px; background: var(--card-bg); border: 1px solid var(--border); border-radius: 12px; transition: all .3s; }
  .ws-industry-item:hover { border-color: var(--accent); }
  .ws-industry-item i { font-size: 1.3rem; color: var(--accent); width: 24px; text-align: center; }
  .ws-industry-item span { font-weight: 600; font-size: .95rem; }

  /* ===== CTA ===== */
  .ws-cta { padding: 90px 0; }
  .ws-cta-inner { background: linear-gradient(135deg, var(--primary), var(--primary-dark, #0a0f1e)); padding: 60px; border-radius: 24px; text-align: center; }
  .ws-cta-inner h2 { color: #fff; font-size: clamp(1.5rem, 3vw, 2rem); margin-bottom: 16px; }
  .ws-cta-inner p { color: rgba(255,255,255,.75); max-width: 600px; margin: 0 auto 30px; line-height: 1.7; }
  .ws-cta-actions { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }

  /* ===== Responsive ===== */
  @media (max-width: 992px) {
    .ws-benefits-grid, .ws-products-grid { grid-template-columns: repeat(2, 1fr); }
    .ws-process-grid { grid-template-columns: repeat(2, 1fr); }
    .ws-industries-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .ws-benefits-grid, .ws-products-grid, .ws-process-grid { grid-template-columns: 1fr; }
    .ws-industries-grid { grid-template-columns: 1fr; }
    .ws-cta-inner { padding: 40px 24px; }
  }
</style>
