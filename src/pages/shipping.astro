---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Worldwide Chemical Shipping & Logistics" description="Global shipping for industrial chemicals from Germany. Hazmat-certified transport, secure packaging & international delivery for all UE Chemicals products." activePage="shipping">

  <!-- ========== HERO ========== -->
  <section class="page-hero">
    <div class="container">
      <div class="section-label">Logistics</div>
      <h1>Shipping & Logistics</h1>
      <p>Safe, compliant worldwide delivery of hazardous chemical products with full documentation and tracking.</p>
    </div>
  </section>

  <!-- ========== SHIPPING OVERVIEW ========== -->
  <section class="ship-overview">
    <div class="container">
      <div class="ship-intro">
        <h2>Worldwide Chemical Shipping</h2>
        <p>UE Chemicals ships to destinations worldwide from our facility in Essen, Germany. All shipments are handled by licensed hazardous materials carriers in full compliance with international transport regulations. We ensure your products arrive safely, on time, and with complete documentation.</p>
      </div>

      <div class="ship-stats-row">
        <div class="ship-stat">
          <div class="ship-stat-icon"><i class="fas fa-globe-europe"></i></div>
          <h4>Global Coverage</h4>
          <p>We ship to Europe, Asia, Africa, North & South America, and Oceania.</p>
        </div>
        <div class="ship-stat">
          <div class="ship-stat-icon"><i class="fas fa-shield-halved"></i></div>
          <h4>Fully Insured</h4>
          <p>All shipments are insured against loss and damage during transit.</p>
        </div>
        <div class="ship-stat">
          <div class="ship-stat-icon"><i class="fas fa-file-certificate"></i></div>
          <h4>Full Documentation</h4>
          <p>SDS, TDS, COA, and customs paperwork included with every shipment.</p>
        </div>
        <div class="ship-stat">
          <div class="ship-stat-icon"><i class="fas fa-box"></i></div>
          <h4>Discreet Packaging</h4>
          <p>UN-approved containers with proper hazmat labeling and secure sealing.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TRANSPORT REGULATIONS ========== -->
  <section class="ship-regs">
    <div class="container">
      <div class="text-center" style="margin-bottom:50px;">
        <div class="section-label">Compliance</div>
        <h2>Transport Regulations</h2>
        <p style="max-width:650px;margin:0 auto;color:var(--body-text);">All shipments comply with the following international hazardous goods transport frameworks.</p>
      </div>

      <div class="ship-regs-grid">
        <div class="ship-reg-card">
          <div class="ship-reg-icon"><i class="fas fa-truck"></i></div>
          <h4>Road Transport (ADR)</h4>
          <p>European Agreement concerning the International Carriage of Dangerous Goods by Road. All road shipments within Europe comply with ADR requirements including:</p>
          <ul>
            <li>Licensed hazmat carrier transport</li>
            <li>Driver ADR certification</li>
            <li>Emergency Instructions in Writing (EIW) onboard</li>
            <li>Proper segregation from food items and oxidizers</li>
          </ul>
        </div>
        <div class="ship-reg-card">
          <div class="ship-reg-icon"><i class="fas fa-ship"></i></div>
          <h4>Sea Freight (IMDG Code)</h4>
          <p>International Maritime Dangerous Goods Code. Ocean shipments comply with IMDG requirements:</p>
          <ul>
            <li>IMDG Class 8 & 6.1 classification</li>
            <li>Marine pollutant labeling where applicable</li>
            <li>Proper documentation and container segregation</li>
            <li>UN-specification packaging</li>
          </ul>
        </div>
        <div class="ship-reg-card">
          <div class="ship-reg-icon"><i class="fas fa-plane"></i></div>
          <h4>Air Freight (IATA DGR)</h4>
          <p>International Air Transport Association Dangerous Goods Regulations. Air shipments follow strict IATA protocols:</p>
          <ul>
            <li>Cargo-only aircraft (not passenger flights)</li>
            <li>UN certified leak-proof packaging</li>
            <li>Shipper's Declaration for Dangerous Goods</li>
            <li>IATA hazardous goods compliance</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PACKAGING ========== -->
  <section class="ship-packaging">
    <div class="container">
      <div class="ship-pack-grid">
        <div class="ship-pack-content">
          <div class="section-label">Packaging</div>
          <h2>UN-Approved Packaging Standards</h2>
          <p>All chemical products are packaged in UN-specification containers rated for hazardous materials transport. Our packaging meets the highest safety standards to ensure product integrity during transit.</p>
          <div class="ship-pack-specs">
            <div class="ship-pack-spec">
              <i class="fas fa-check-circle"></i>
              <div>
                <strong>Steel Flasks</strong>
                <p>Standard 34.5 kg / 76 lbs UN-approved steel flasks for mercury products.</p>
              </div>
            </div>
            <div class="ship-pack-spec">
              <i class="fas fa-check-circle"></i>
              <div>
                <strong>HDPE Containers</strong>
                <p>High-density polyethylene bottles packed in steel drums with absorbent cushioning.</p>
              </div>
            </div>
            <div class="ship-pack-spec">
              <i class="fas fa-check-circle"></i>
              <div>
                <strong>Hazmat Labeling</strong>
                <p>Every package labeled with UN number, proper shipping name, hazard class, and packing group.</p>
              </div>
            </div>
            <div class="ship-pack-spec">
              <i class="fas fa-check-circle"></i>
              <div>
                <strong>Tamper-Proof Sealing</strong>
                <p>Sealed containers with tamper-evident closures for maximum security.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="ship-pack-labels">
          <h4>Required Labels & Markings</h4>
          <div class="ship-label-grid">
            <div class="ship-label-item">
              <i class="fas fa-skull-crossbones"></i>
              <span>Toxic</span>
            </div>
            <div class="ship-label-item">
              <i class="fas fa-flask-vial"></i>
              <span>Corrosive</span>
            </div>
            <div class="ship-label-item">
              <i class="fas fa-leaf"></i>
              <span>Marine Pollutant</span>
            </div>
            <div class="ship-label-item">
              <i class="fas fa-temperature-high"></i>
              <span>Keep from Heat</span>
            </div>
            <div class="ship-label-item">
              <i class="fas fa-hand"></i>
              <span>Handle with Care</span>
            </div>
            <div class="ship-label-item">
              <i class="fas fa-barcode"></i>
              <span>UN Number</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== DELIVERY TIMELINE ========== -->
  <section class="ship-timeline">
    <div class="container">
      <div class="text-center" style="margin-bottom:50px;">
        <div class="section-label">Timelines</div>
        <h2>Estimated Delivery Times</h2>
      </div>
      <div class="ship-timeline-table">
        <table>
          <thead>
            <tr>
              <th>Destination</th>
              <th>Method</th>
              <th>Estimated Time</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Germany (Domestic)</td>
              <td>Road (ADR)</td>
              <td>1–3 business days</td>
            </tr>
            <tr>
              <td>EU Countries</td>
              <td>Road / Sea</td>
              <td>3–7 business days</td>
            </tr>
            <tr>
              <td>United Kingdom</td>
              <td>Sea / Air</td>
              <td>5–10 business days</td>
            </tr>
            <tr>
              <td>North America</td>
              <td>Sea / Air</td>
              <td>7–14 business days</td>
            </tr>
            <tr>
              <td>South America</td>
              <td>Sea / Air</td>
              <td>10–18 business days</td>
            </tr>
            <tr>
              <td>Asia & Middle East</td>
              <td>Sea / Air</td>
              <td>10–21 business days</td>
            </tr>
            <tr>
              <td>Africa</td>
              <td>Sea / Air</td>
              <td>14–25 business days</td>
            </tr>
            <tr>
              <td>Oceania</td>
              <td>Sea / Air</td>
              <td>14–25 business days</td>
            </tr>
          </tbody>
        </table>
        <p class="ship-timeline-note"><i class="fas fa-info-circle"></i> Delivery times are estimates and may vary due to customs processing, destination regulations, and carrier schedules. Tracking information is provided for all shipments.</p>
      </div>
    </div>
  </section>

  <!-- ========== ORDER PROCESS ========== -->
  <section class="ship-process">
    <div class="container">
      <div class="text-center" style="margin-bottom:50px;">
        <div class="section-label">Process</div>
        <h2>How It Works</h2>
      </div>
      <div class="ship-steps">
        <div class="ship-step">
          <div class="ship-step-num">01</div>
          <h4>Request a Quote</h4>
          <p>Submit your product inquiry through our contact form or email. Include product, quantity, and destination.</p>
        </div>
        <div class="ship-step">
          <div class="ship-step-num">02</div>
          <h4>Receive Proforma Invoice</h4>
          <p>We'll send a detailed Proforma Invoice with pricing, payment details, and estimated delivery timeline.</p>
        </div>
        <div class="ship-step">
          <div class="ship-step-num">03</div>
          <h4>Confirm Payment</h4>
          <p>Complete payment via the agreed method. Orders are processed within 1–3 business days after confirmation.</p>
        </div>
        <div class="ship-step">
          <div class="ship-step-num">04</div>
          <h4>Track Your Shipment</h4>
          <p>Receive tracking details and monitor your shipment until it arrives at your doorstep.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== CTA ========== -->
  <section class="cta-section">
    <div class="container text-center">
      <h2>Ready to Ship?</h2>
      <p>Contact us for a quote including shipping costs to your destination.</p>
      <div class="cta-actions">
        <a href="/contact" class="btn btn-accent">Get a Quote <i class="fas fa-arrow-right"></i></a>
        <a href="/ordering" class="btn btn-outline">Ordering Info <i class="fas fa-arrow-right"></i></a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Shipping Overview */
  .ship-overview { padding: 80px 0; }
  .ship-intro { max-width: 800px; margin: 0 auto 50px; text-center; }
  .ship-intro h2 { margin-bottom: 16px; }
  .ship-intro p { color: var(--body-text); line-height: 1.8; }
  .ship-stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px; }
  .ship-stat { text-align: center; padding: 30px 20px; border-radius: 12px; background: var(--surface); border: 1px solid var(--border-light); }
  .ship-stat-icon { font-size: 2rem; color: var(--primary); margin-bottom: 16px; }
  .ship-stat h4 { margin-bottom: 8px; font-size: 1.1rem; }
  .ship-stat p { color: var(--body-text); font-size: 0.9rem; line-height: 1.6; }

  /* Transport Regs */
  .ship-regs { padding: 80px 0; background: var(--surface); }
  .ship-regs-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; }
  .ship-reg-card { padding: 36px; border-radius: 12px; background: var(--bg); border: 1px solid var(--border-light); }
  .ship-reg-icon { font-size: 2rem; color: var(--primary); margin-bottom: 16px; }
  .ship-reg-card h4 { margin-bottom: 12px; }
  .ship-reg-card p { color: var(--body-text); font-size: 0.92rem; line-height: 1.7; margin-bottom: 16px; }
  .ship-reg-card ul { margin: 0; padding-left: 20px; }
  .ship-reg-card li { color: var(--body-text); font-size: 0.9rem; line-height: 1.7; margin-bottom: 6px; }

  /* Packaging */
  .ship-packaging { padding: 80px 0; }
  .ship-pack-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 50px; align-items: start; }
  .ship-pack-content .section-label { margin-bottom: 12px; }
  .ship-pack-content h2 { margin-bottom: 16px; }
  .ship-pack-content > p { color: var(--body-text); line-height: 1.8; margin-bottom: 30px; }
  .ship-pack-specs { display: flex; flex-direction: column; gap: 20px; }
  .ship-pack-spec { display: flex; gap: 14px; align-items: flex-start; }
  .ship-pack-spec i { color: var(--primary); font-size: 1.2rem; margin-top: 3px; flex-shrink: 0; }
  .ship-pack-spec strong { display: block; margin-bottom: 4px; }
  .ship-pack-spec p { color: var(--body-text); font-size: 0.9rem; line-height: 1.6; margin: 0; }
  .ship-pack-labels { background: var(--dark); border-radius: 16px; padding: 36px; }
  .ship-pack-labels h4 { color: #fff; margin-bottom: 24px; text-align: center; }
  .ship-label-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
  .ship-label-item { display: flex; align-items: center; gap: 10px; background: rgba(255,255,255,0.08); padding: 14px 16px; border-radius: 8px; }
  .ship-label-item i { color: var(--accent); font-size: 1.2rem; }
  .ship-label-item span { color: rgba(255,255,255,0.9); font-size: 0.9rem; font-weight: 500; }

  /* Timeline */
  .ship-timeline { padding: 80px 0; background: var(--surface); }
  .ship-timeline-table { max-width: 800px; margin: 0 auto; }
  .ship-timeline-table table { width: 100%; border-collapse: collapse; background: var(--bg); border-radius: 12px; overflow: hidden; }
  .ship-timeline-table th { background: var(--dark); color: #fff; padding: 16px 20px; text-align: left; font-weight: 600; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .ship-timeline-table td { padding: 14px 20px; border-bottom: 1px solid var(--border-light); color: var(--body-text); font-size: 0.92rem; }
  .ship-timeline-table tr:last-child td { border-bottom: none; }
  .ship-timeline-table tr:hover td { background: var(--surface); }
  .ship-timeline-note { margin-top: 20px; color: var(--body-text); font-size: 0.85rem; text-align: center; }
  .ship-timeline-note i { color: var(--primary); margin-right: 6px; }

  /* Process */
  .ship-process { padding: 80px 0; }
  .ship-steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px; }
  .ship-step { text-align: center; padding: 30px 20px; }
  .ship-step-num { font-size: 2.5rem; font-weight: 800; color: var(--primary); opacity: 0.3; margin-bottom: 12px; }
  .ship-step h4 { margin-bottom: 10px; }
  .ship-step p { color: var(--body-text); font-size: 0.9rem; line-height: 1.6; }

  /* CTA */
  .cta-section { padding: 80px 0; background: var(--dark); }
  .cta-section h2 { color: #fff; margin-bottom: 16px; }
  .cta-section p { color: rgba(255,255,255,0.7); margin-bottom: 30px; }
  .cta-actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }

  @media (max-width: 1024px) {
    .ship-stats-row { grid-template-columns: repeat(2, 1fr); }
    .ship-regs-grid { grid-template-columns: 1fr; }
    .ship-pack-grid { grid-template-columns: 1fr; }
    .ship-steps { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .ship-stats-row { grid-template-columns: 1fr; }
    .ship-steps { grid-template-columns: 1fr; }
    .ship-timeline-table { overflow-x: auto; }
  }
</style>
