---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy Policy" description="Privacy Policy for UE Chemicals. Learn how we collect, use, and protect your personal information." activePage="">

  <!-- ========== HERO ========== -->
  <section class="lg-hero">
    <div class="lg-hero-bg"></div>
    <div class="container lg-hero-inner">
      <div class="lg-hero-badge"><i class="fas fa-shield-halved"></i> Legal</div>
      <h1>Privacy Policy</h1>
      <p class="lg-hero-sub">How we collect, use, and protect your personal information in compliance with the GDPR.</p>
      <div class="lg-hero-meta">
        <span><i class="fas fa-calendar"></i> Last Updated: July 2025</span>
        <span><i class="fas fa-gavel"></i> GDPR Compliant</span>
      </div>
    </div>
  </section>

  <!-- ========== CONTENT ========== -->
  <section class="lg-content">
    <div class="container">
      <div class="lg-grid">

        <!-- Sidebar TOC -->
        <aside class="lg-sidebar">
          <div class="lg-toc">
            <h4>Table of Contents</h4>
            <nav>
              <a href="#introduction">1. Introduction</a>
              <a href="#info-collect">2. Information We Collect</a>
              <a href="#how-use">3. How We Use Your Information</a>
              <a href="#legal-basis">4. Legal Basis for Processing</a>
              <a href="#data-sharing">5. Data Sharing &amp; Disclosure</a>
              <a href="#data-retention">6. Data Retention</a>
              <a href="#cookies">7. Cookies</a>
              <a href="#your-rights">8. Your Rights</a>
              <a href="#data-security">9. Data Security</a>
              <a href="#intl-transfers">10. International Transfers</a>
              <a href="#children">11. Children's Privacy</a>
              <a href="#changes">12. Changes to This Policy</a>
              <a href="#contact">13. Contact Us</a>
            </nav>
          </div>
        </aside>

        <!-- Main Content -->
        <div class="lg-main">

          <div class="lg-section" id="introduction">
            <div class="lg-section-num">01</div>
            <h3>Introduction</h3>
            <p>UE Chemicals ("we," "our," or "us"), located at Bangkok, 10110, Thailand, is committed to protecting your personal data. This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you visit our website useful-chemicals.com or interact with our services.</p>
          </div>

          <div class="lg-section" id="info-collect">
            <div class="lg-section-num">02</div>
            <h3>Information We Collect</h3>
            <div class="lg-card">
              <h4><i class="fas fa-user"></i> Personal Data You Provide</h4>
              <ul>
                <li><strong>Contact Information:</strong> Name, email address, phone number, and company name when you submit a quote request or contact form.</li>
                <li><strong>Order Information:</strong> Product inquiries, quantity requirements, and shipping details.</li>
                <li><strong>Communication Data:</strong> Any messages or correspondence you send to us.</li>
              </ul>
            </div>
            <div class="lg-card">
              <h4><i class="fas fa-desktop"></i> Automatically Collected Data</h4>
              <ul>
                <li><strong>Usage Data:</strong> IP address, browser type, operating system, referring URLs, pages visited, and time spent on our site.</li>
                <li><strong>Cookies:</strong> We use essential cookies to ensure proper website functionality. See Section 7 for details.</li>
              </ul>
            </div>
          </div>

          <div class="lg-section" id="how-use">
            <div class="lg-section-num">03</div>
            <h3>How We Use Your Information</h3>
            <p>We use your personal data for the following purposes:</p>
            <ul>
              <li>Responding to your inquiries and quote requests.</li>
              <li>Processing and fulfilling orders.</li>
              <li>Sending order confirmations and shipping notifications.</li>
              <li>Improving our website, products, and customer experience.</li>
              <li>Complying with legal obligations and regulatory requirements.</li>
              <li>Communicating about product updates, safety information, or changes to our terms.</li>
            </ul>
          </div>

          <div class="lg-section" id="legal-basis">
            <div class="lg-section-num">04</div>
            <h3>Legal Basis for Processing (GDPR)</h3>
            <p>Under the General Data Protection Regulation (GDPR), we process your data based on:</p>
            <div class="lg-basis-grid">
              <div class="lg-basis-item"><strong>Consent</strong><span>When you voluntarily submit a contact or quote form.</span></div>
              <div class="lg-basis-item"><strong>Contractual Necessity</strong><span>To process your orders and provide our services.</span></div>
              <div class="lg-basis-item"><strong>Legitimate Interest</strong><span>To improve our services and ensure website security.</span></div>
              <div class="lg-basis-item"><strong>Legal Obligation</strong><span>To comply with applicable laws and regulations.</span></div>
            </div>
          </div>

          <div class="lg-section" id="data-sharing">
            <div class="lg-section-num">05</div>
            <h3>Data Sharing &amp; Disclosure</h3>
            <p>We do not sell, rent, or trade your personal information to third parties. We may share your data with:</p>
            <ul>
              <li><strong>Service Providers:</strong> Trusted third-party services that assist with email delivery, hosting, and analytics, bound by confidentiality agreements.</li>
              <li><strong>Legal Authorities:</strong> When required by law, regulation, or legal process.</li>
              <li><strong>Business Transfers:</strong> In connection with a merger, acquisition, or sale of assets.</li>
            </ul>
          </div>

          <div class="lg-section" id="data-retention">
            <div class="lg-section-num">06</div>
            <h3>Data Retention</h3>
            <p>We retain your personal data only for as long as necessary to fulfill the purposes outlined in this policy, or as required by law. Quote requests and contact form submissions are retained for up to 24 months unless you request earlier deletion.</p>
          </div>

          <div class="lg-section" id="cookies">
            <div class="lg-section-num">07</div>
            <h3>Cookies</h3>
            <p>Our website uses essential cookies to ensure basic functionality (e.g., remembering your cookie consent preference). We do not use tracking or advertising cookies. You can control cookies through your browser settings.</p>
          </div>

          <div class="lg-section" id="your-rights">
            <div class="lg-section-num">08</div>
            <h3>Your Rights</h3>
            <p>Under the GDPR, you have the right to:</p>
            <div class="lg-rights-grid">
              <div class="lg-right"><i class="fas fa-eye"></i><strong>Access</strong><span>Request a copy of your personal data.</span></div>
              <div class="lg-right"><i class="fas fa-pen"></i><strong>Rectification</strong><span>Request correction of inaccurate data.</span></div>
              <div class="lg-right"><i class="fas fa-trash"></i><strong>Erasure</strong><span>Request deletion ("right to be forgotten").</span></div>
              <div class="lg-right"><i class="fas fa-pause"></i><strong>Restriction</strong><span>Limit processing of your data.</span></div>
              <div class="lg-right"><i class="fas fa-download"></i><strong>Portability</strong><span>Transfer your data to another controller.</span></div>
              <div class="lg-right"><i class="fas fa-hand"></i><strong>Objection</strong><span>Object to processing based on legitimate interest.</span></div>
            </div>
            <p style="margin-top: 16px;">To exercise any of these rights, contact us at <a href="mailto:info@useful-chemicals.com">info@useful-chemicals.com</a>.</p>
          </div>

          <div class="lg-section" id="data-security">
            <div class="lg-section-num">09</div>
            <h3>Data Security</h3>
            <p>We implement appropriate technical and organizational measures to protect your personal data against unauthorized access, alteration, disclosure, or destruction. This includes encrypted data transmission (SSL/TLS) and secure hosting infrastructure.</p>
          </div>

          <div class="lg-section" id="intl-transfers">
            <div class="lg-section-num">10</div>
            <h3>International Transfers</h3>
            <p>Your data may be processed outside the European Economic Area (EEA) by our service providers. In such cases, we ensure appropriate safeguards are in place, such as Standard Contractual Clauses approved by the European Commission.</p>
          </div>

          <div class="lg-section" id="children">
            <div class="lg-section-num">11</div>
            <h3>Children's Privacy</h3>
            <p>Our services are not directed to individuals under the age of 18. We do not knowingly collect personal data from minors.</p>
          </div>

          <div class="lg-section" id="changes">
            <div class="lg-section-num">12</div>
            <h3>Changes to This Policy</h3>
            <p>We may update this Privacy Policy from time to time. Changes will be posted on this page with an updated revision date. We encourage you to review this page periodically.</p>
          </div>

          <div class="lg-section" id="contact">
            <div class="lg-section-num">13</div>
            <h3>Contact Us</h3>
            <p>If you have questions about this Privacy Policy or wish to exercise your data rights, contact us at:</p>
            <div class="lg-contact-card">
              <div><i class="fas fa-envelope"></i> <a href="mailto:info@useful-chemicals.com">info@useful-chemicals.com</a></div>
              <div><i class="fas fa-map-marker-alt"></i> Bangkok, 10110, Thailand</div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ===== Hero ===== */
  .lg-hero { position: relative; padding: 130px 0 60px; overflow: hidden; }
  .lg-hero-bg { position: absolute; inset: 0; background: linear-gradient(135deg, #0a0f1e 0%, #1a1f2e 100%); }
  .lg-hero-inner { position: relative; z-index: 1; max-width: 700px; }
  .lg-hero-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); padding: 8px 18px; border-radius: 100px; font-size: .83rem; color: var(--accent); margin-bottom: 20px; font-weight: 600; }
  .lg-hero h1 { font-size: clamp(2rem, 4.5vw, 3rem); font-weight: 800; color: var(--white); margin-bottom: 14px; }
  .lg-hero-sub { color: rgba(255,255,255,.65); font-size: 1.05rem; line-height: 1.7; margin-bottom: 20px; }
  .lg-hero-meta { display: flex; gap: 24px; flex-wrap: wrap; }
  .lg-hero-meta span { display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,.45); font-size: .85rem; }
  .lg-hero-meta i { color: var(--accent); font-size: .8rem; }

  /* ===== Layout ===== */
  .lg-content { padding: 70px 0 90px; background: var(--white); }
  .lg-grid { display: grid; grid-template-columns: 250px 1fr; gap: 50px; }

  /* Sidebar */
  .lg-sidebar { position: sticky; top: 100px; align-self: start; }
  .lg-toc { background: var(--light-bg); border: 1px solid var(--border); border-radius: 14px; padding: 24px; }
  .lg-toc h4 { font-size: .85rem; text-transform: uppercase; letter-spacing: 1px; color: var(--dark); margin-bottom: 16px; }
  .lg-toc nav { display: flex; flex-direction: column; gap: 0; }
  .lg-toc nav a { display: block; padding: 8px 12px; font-size: .84rem; color: var(--body-text); text-decoration: none; border-radius: 6px; transition: var(--transition); border-left: 2px solid transparent; }
  .lg-toc nav a:hover { background: var(--white); color: var(--accent); border-left-color: var(--accent); }

  /* Sections */
  .lg-section { padding: 30px 0; border-bottom: 1px solid var(--border); position: relative; }
  .lg-section:last-child { border-bottom: none; }
  .lg-section-num { font-size: 2rem; font-weight: 800; color: rgba(252,82,32,.12); position: absolute; top: 26px; right: 0; }
  .lg-section h3 { font-size: 1.3rem; font-weight: 700; margin-bottom: 14px; color: var(--near-black); }
  .lg-section p { color: var(--body-text); line-height: 1.8; margin-bottom: 14px; }
  .lg-section ul { margin: 0 0 16px 20px; }
  .lg-section li { color: var(--body-text); line-height: 1.8; margin-bottom: 8px; }
  .lg-section a { color: var(--accent); text-decoration: underline; }

  /* Cards inside sections */
  .lg-card { background: var(--light-bg); border: 1px solid var(--border); border-radius: 12px; padding: 24px; margin-bottom: 16px; }
  .lg-card h4 { font-size: 1rem; font-weight: 700; margin-bottom: 12px; display: flex; align-items: center; gap: 10px; }
  .lg-card h4 i { color: var(--accent); font-size: .95rem; }
  .lg-card ul { margin-bottom: 0; }

  /* Basis grid */
  .lg-basis-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 14px; }
  .lg-basis-item { background: var(--light-bg); border: 1px solid var(--border); border-radius: 10px; padding: 18px; }
  .lg-basis-item strong { display: block; font-size: .95rem; margin-bottom: 4px; color: var(--near-black); }
  .lg-basis-item span { font-size: .87rem; color: var(--body-text); line-height: 1.6; }

  /* Rights grid */
  .lg-rights-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-top: 14px; }
  .lg-right { background: var(--light-bg); border: 1px solid var(--border); border-radius: 10px; padding: 18px; text-align: center; }
  .lg-right i { font-size: 1.2rem; color: var(--accent); margin-bottom: 8px; display: block; }
  .lg-right strong { display: block; font-size: .9rem; margin-bottom: 4px; }
  .lg-right span { font-size: .82rem; color: var(--body-text); line-height: 1.5; }

  /* Contact card */
  .lg-contact-card { background: var(--light-bg); border: 1px solid var(--border); border-radius: 12px; padding: 20px 24px; display: flex; flex-direction: column; gap: 10px; margin-top: 10px; }
  .lg-contact-card div { display: flex; align-items: center; gap: 10px; font-size: .93rem; }
  .lg-contact-card i { color: var(--accent); width: 18px; text-align: center; }

  /* Responsive */
  @media (max-width: 900px) {
    .lg-grid { grid-template-columns: 1fr; }
    .lg-sidebar { position: static; }
    .lg-rights-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .lg-basis-grid, .lg-rights-grid { grid-template-columns: 1fr; }
    .lg-section-num { display: none; }
  }
</style>
