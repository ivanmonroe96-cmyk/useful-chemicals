---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Disclaimer – Liability & Usage Notice" description="Disclaimer for UE Chemicals. Liability limitations, product usage responsibilities, and legal notices for our industrial chemical products and website content." activePage="">

  <!-- ========== HERO ========== -->
  <section class="lg-hero">
    <div class="lg-hero-bg"></div>
    <div class="container lg-hero-inner">
      <div class="lg-hero-badge"><i class="fas fa-triangle-exclamation"></i> Legal</div>
      <h1>Disclaimer</h1>
      <p class="lg-hero-sub">Liability limitations, product usage responsibilities, and legal notices for our industrial chemical products.</p>
      <div class="lg-hero-meta">
        <span><i class="fas fa-calendar"></i> Last Updated: March 2026</span>
        <span><i class="fas fa-gavel"></i> German Law</span>
      </div>
    </div>
  </section>

  <!-- ========== CONTENT ========== -->
  <section class="lg-content">
    <div class="container">
      <div class="lg-grid">

        <!-- Sidebar TOC -->
        <aside class="lg-sidebar">
          <div class="lg-toc">
            <h4>Table of Contents</h4>
            <nav>
              <a href="#general">1. General Disclaimer</a>
              <a href="#product-use">2. Product Use Disclaimer</a>
              <a href="#limitation">3. Limitation of Liability</a>
              <a href="#professional">4. Professional Responsibility</a>
              <a href="#regulatory">5. Regulatory Compliance</a>
              <a href="#no-guarantee">6. No Guarantee of Results</a>
              <a href="#third-party">7. Third-Party Links</a>
              <a href="#ip">8. Intellectual Property</a>
              <a href="#indemnification">9. Indemnification</a>
              <a href="#changes">10. Changes</a>
              <a href="#governing">11. Governing Law</a>
              <a href="#contact">12. Contact</a>
            </nav>
          </div>
        </aside>

        <!-- Main Content -->
        <div class="lg-main">

          <div class="lg-section" id="general">
            <div class="lg-section-num">01</div>
            <h3>General Disclaimer</h3>
            <p>The information provided on this website (useful-chemicals.com) is for general informational purposes only. While UE Chemicals strives to keep the information up to date and accurate, we make no representations or warranties of any kind, express or implied, about the completeness, accuracy, reliability, suitability, or availability of the information, products, services, or related graphics contained on this website.</p>
          </div>

          <div class="lg-section" id="product-use">
            <div class="lg-section-num">02</div>
            <h3>Product Use Disclaimer</h3>
            <div class="lg-highlight">
              <i class="fas fa-exclamation-triangle"></i>
              <p>All chemical products supplied by UE Chemicals are intended strictly for legitimate industrial, research, scientific, and commercial purposes.</p>
            </div>
            <p>By purchasing or requesting a quote for any of our products — including Caluanie Muelear Oxidize, Red Liquid Mercury, and Silver Liquid Mercury — you acknowledge and agree that:</p>
            <ul>
              <li>You will use the products solely for lawful purposes and in compliance with all applicable local, national, and international laws and regulations.</li>
              <li>You are responsible for obtaining all necessary permits, licenses, and authorizations required in your jurisdiction.</li>
              <li>You will handle all products in accordance with the Safety Data Sheet (SDS) and technical documentation provided with your order.</li>
              <li>You accept full responsibility for the safe handling, storage, transport, use, and disposal of all products purchased.</li>
            </ul>
          </div>

          <div class="lg-section" id="limitation">
            <div class="lg-section-num">03</div>
            <h3>Limitation of Liability</h3>
            <p>To the fullest extent permitted by applicable law, UE Chemicals shall not be liable for any direct, indirect, incidental, special, consequential, or punitive damages arising from:</p>
            <ul>
              <li>The use or inability to use our products, including damages from improper handling, storage, or application.</li>
              <li>The use of or reliance on any information provided on this website.</li>
              <li>Any errors, omissions, or inaccuracies in product descriptions or technical specifications.</li>
              <li>Personal injury, property damage, or environmental damage caused by misuse or failure to follow safety guidelines.</li>
            </ul>
          </div>

          <div class="lg-section" id="professional">
            <div class="lg-section-num">04</div>
            <h3>Professional Responsibility</h3>
            <p>Our products are designed for use by trained professionals with appropriate knowledge and experience in handling hazardous chemicals. Users must:</p>
            <div class="dc-req-grid">
              <div class="dc-req-item"><i class="fas fa-hard-hat"></i><span>Employ appropriate personal protective equipment (PPE) at all times.</span></div>
              <div class="dc-req-item"><i class="fas fa-wind"></i><span>Ensure adequate ventilation and containment measures.</span></div>
              <div class="dc-req-item"><i class="fas fa-clipboard-check"></i><span>Follow all workplace health &amp; safety regulations (EU Directive 89/391/EEC).</span></div>
              <div class="dc-req-item"><i class="fas fa-kit-medical"></i><span>Maintain proper emergency response and spill containment plans.</span></div>
              <div class="dc-req-item"><i class="fas fa-tags"></i><span>Comply with CLP Regulation (EC 1272/2008) for hazard communication.</span></div>
            </div>
          </div>

          <div class="lg-section" id="regulatory">
            <div class="lg-section-num">05</div>
            <h3>Regulatory Compliance</h3>
            <p>UE Chemicals operates in compliance with EU REACH Regulation (EC 1907/2006), EU Mercury Regulation (EU 2017/852), and all applicable German and EU chemical safety laws. However, it is the buyer's sole responsibility to ensure that the purchase, import, use, and disposal of our products comply with all laws and regulations applicable in their jurisdiction.</p>
          </div>

          <div class="lg-section" id="no-guarantee">
            <div class="lg-section-num">06</div>
            <h3>No Guarantee of Results</h3>
            <p>While our products are manufactured to the highest quality standards with certified purity levels, UE Chemicals does not guarantee specific results from the use of our products. Product performance may vary depending on application conditions, user expertise, and environmental factors.</p>
          </div>

          <div class="lg-section" id="third-party">
            <div class="lg-section-num">07</div>
            <h3>Third-Party Links</h3>
            <p>This website may contain links to third-party websites. These links are provided for convenience only and do not imply endorsement by UE Chemicals. We have no control over and accept no responsibility for the content, privacy policies, or practices of any third-party websites.</p>
          </div>

          <div class="lg-section" id="ip">
            <div class="lg-section-num">08</div>
            <h3>Intellectual Property</h3>
            <p>All content on this website, including text, images, logos, product descriptions, and technical data, is the intellectual property of UE Chemicals and is protected by German copyright law (Urheberrechtsgesetz). Unauthorized reproduction, distribution, or use of any content is prohibited without prior written consent.</p>
          </div>

          <div class="lg-section" id="indemnification">
            <div class="lg-section-num">09</div>
            <h3>Indemnification</h3>
            <p>By using our website or purchasing our products, you agree to indemnify and hold harmless UE Chemicals, its directors, employees, and agents from and against any claims, damages, expenses, or liabilities arising from your use of our products or violation of this disclaimer.</p>
          </div>

          <div class="lg-section" id="changes">
            <div class="lg-section-num">10</div>
            <h3>Changes to This Disclaimer</h3>
            <p>UE Chemicals reserves the right to update or modify this disclaimer at any time without prior notice. Changes become effective upon publication on this website. We encourage you to review this page periodically.</p>
          </div>

          <div class="lg-section" id="governing">
            <div class="lg-section-num">11</div>
            <h3>Governing Law</h3>
            <p>This disclaimer is governed by and construed in accordance with the laws of the Kingdom of Thailand. Any disputes arising from or in connection with this disclaimer shall be subject to the exclusive jurisdiction of the courts of Bangkok, Thailand.</p>
          </div>

          <div class="lg-section" id="contact">
            <div class="lg-section-num">12</div>
            <h3>Contact Information</h3>
            <p>For any questions regarding this disclaimer, please contact us:</p>
            <div class="lg-contact-card">
              <div><i class="fas fa-building"></i> <strong>UE Chemicals</strong></div>
              <div><i class="fas fa-map-marker-alt"></i> Bangkok, 10110, Thailand</div>
              <div><i class="fas fa-envelope"></i> <a href="mailto:info@useful-chemicals.com">info@useful-chemicals.com</a></div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ===== Hero ===== */
  .lg-hero { position: relative; padding: 130px 0 60px; overflow: hidden; }
  .lg-hero-bg { position: absolute; inset: 0; background: linear-gradient(135deg, #0a0f1e 0%, #1a1f2e 100%); }
  .lg-hero-inner { position: relative; z-index: 1; max-width: 700px; }
  .lg-hero-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); padding: 8px 18px; border-radius: 100px; font-size: .83rem; color: var(--accent); margin-bottom: 20px; font-weight: 600; }
  .lg-hero h1 { font-size: clamp(2rem, 4.5vw, 3rem); font-weight: 800; color: var(--white); margin-bottom: 14px; }
  .lg-hero-sub { color: rgba(255,255,255,.65); font-size: 1.05rem; line-height: 1.7; margin-bottom: 20px; }
  .lg-hero-meta { display: flex; gap: 24px; flex-wrap: wrap; }
  .lg-hero-meta span { display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,.45); font-size: .85rem; }
  .lg-hero-meta i { color: var(--accent); font-size: .8rem; }

  /* ===== Layout ===== */
  .lg-content { padding: 70px 0 90px; background: var(--white); }
  .lg-grid { display: grid; grid-template-columns: 250px 1fr; gap: 50px; }

  /* Sidebar */
  .lg-sidebar { position: sticky; top: 100px; align-self: start; }
  .lg-toc { background: var(--light-bg); border: 1px solid var(--border); border-radius: 14px; padding: 24px; }
  .lg-toc h4 { font-size: .85rem; text-transform: uppercase; letter-spacing: 1px; color: var(--dark); margin-bottom: 16px; }
  .lg-toc nav { display: flex; flex-direction: column; }
  .lg-toc nav a { display: block; padding: 8px 12px; font-size: .84rem; color: var(--body-text); text-decoration: none; border-radius: 6px; transition: var(--transition); border-left: 2px solid transparent; }
  .lg-toc nav a:hover { background: var(--white); color: var(--accent); border-left-color: var(--accent); }

  /* Sections */
  .lg-section { padding: 30px 0; border-bottom: 1px solid var(--border); position: relative; }
  .lg-section:last-child { border-bottom: none; }
  .lg-section-num { font-size: 2rem; font-weight: 800; color: rgba(252,82,32,.12); position: absolute; top: 26px; right: 0; }
  .lg-section h3 { font-size: 1.3rem; font-weight: 700; margin-bottom: 14px; color: var(--near-black); }
  .lg-section p { color: var(--body-text); line-height: 1.8; margin-bottom: 14px; }
  .lg-section ul { margin: 0 0 16px 20px; }
  .lg-section li { color: var(--body-text); line-height: 1.8; margin-bottom: 8px; }
  .lg-section a { color: var(--accent); text-decoration: underline; }

  /* Highlight */
  .lg-highlight { display: flex; gap: 14px; background: rgba(252,82,32,.05); border: 1px solid rgba(252,82,32,.15); border-radius: 10px; padding: 18px 20px; margin-bottom: 14px; }
  .lg-highlight i { color: var(--accent); font-size: 1.1rem; flex-shrink: 0; margin-top: 3px; }
  .lg-highlight p { margin: 0; font-size: .93rem; }

  /* Requirements grid */
  .dc-req-grid { display: flex; flex-direction: column; gap: 10px; margin-top: 14px; }
  .dc-req-item { display: flex; align-items: flex-start; gap: 14px; background: var(--light-bg); border: 1px solid var(--border); border-radius: 10px; padding: 16px 20px; }
  .dc-req-item i { color: var(--accent); font-size: 1rem; margin-top: 2px; width: 20px; text-align: center; flex-shrink: 0; }
  .dc-req-item span { font-size: .9rem; color: var(--body-text); line-height: 1.6; }

  /* Contact card */
  .lg-contact-card { background: var(--light-bg); border: 1px solid var(--border); border-radius: 12px; padding: 20px 24px; display: flex; flex-direction: column; gap: 10px; margin-top: 10px; }
  .lg-contact-card div { display: flex; align-items: center; gap: 10px; font-size: .93rem; }
  .lg-contact-card i { color: var(--accent); width: 18px; text-align: center; }

  /* Responsive */
  @media (max-width: 900px) {
    .lg-grid { grid-template-columns: 1fr; }
    .lg-sidebar { position: static; }
  }
  @media (max-width: 600px) {
    .lg-section-num { display: none; }
  }
</style>
