---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTranslations, t, localizedPath } from '../i18n/index';
import { defaultLang } from '../i18n/languages';

const lang = defaultLang;
const tr = getTranslations(lang);
const lp = (path: string) => localizedPath(path, lang);
---


<BaseLayout lang={lang} title={t(tr, "applications.meta_title")} description={t(tr, "applications.meta_desc")} activePage="applications">

  <!-- ========== HERO ========== -->
  <section class="app-hero">
    <div class="app-hero-bg">
      <img src="/images/Applications-of-Our-Industrial-Chemicals.jpg" alt={t(tr, "applications.hero_title")} />
      <div class="app-hero-overlay"></div>
    </div>
    <div class="container app-hero-inner">
      <div class="app-hero-content">
        <div class="app-hero-badge"><i class="fas fa-industry"></i> {t(tr, "applications.hero_badge")}</div>
        <h1>{t(tr, "applications.hero_title")}</h1>
        <p class="app-hero-sub">{t(tr, "applications.hero_sub")}</p>
        <div class="app-hero-actions">
          <a href={lp("/contact")} class="btn btn-accent">{t(tr, "common.request_consultation")} <i class="fas fa-arrow-right"></i></a>
          <a href={lp("/products")} class="btn btn-outline-white">{t(tr, "common.our_products")} <i class="fas fa-arrow-right"></i></a>
        </div>
      </div>
      <div class="app-hero-stats">
        <div class="app-hero-stat">
          <span class="app-hero-stat-num">{t(tr, "applications.hero_stat1")}</span>
          <span class="app-hero-stat-label">{t(tr, "applications.hero_stat1_label")}</span>
        </div>
        <div class="app-hero-stat-divider"></div>
        <div class="app-hero-stat">
          <span class="app-hero-stat-num">{t(tr, "applications.hero_stat2")}</span>
          <span class="app-hero-stat-label">{t(tr, "applications.hero_stat2_label")}</span>
        </div>
        <div class="app-hero-stat-divider"></div>
        <div class="app-hero-stat">
          <span class="app-hero-stat-num">{t(tr, "applications.hero_stat3")}</span>
          <span class="app-hero-stat-label">{t(tr, "applications.hero_stat3_label")}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== INDUSTRY MARQUEE ========== -->
  <section class="app-marquee">
    <div class="app-marquee-track">
      <div class="app-marquee-items">
        <span><i class="fas fa-gears"></i> {t(tr, "applications.marquee1")}</span>
        <span><i class="fas fa-flask"></i> {t(tr, "applications.marquee2")}</span>
        <span><i class="fas fa-gem"></i> {t(tr, "applications.marquee3")}</span>
        <span><i class="fas fa-microscope"></i> {t(tr, "applications.marquee4")}</span>
        <span><i class="fas fa-microchip"></i> {t(tr, "applications.marquee5")}</span>
        <span><i class="fas fa-coins"></i> {t(tr, "applications.marquee6")}</span>
        <span><i class="fas fa-stethoscope"></i> {t(tr, "applications.marquee7")}</span>
        <span><i class="fas fa-temperature-half"></i> {t(tr, "applications.marquee8")}</span>
        <span><i class="fas fa-gears"></i> {t(tr, "applications.marquee1")}</span>
        <span><i class="fas fa-flask"></i> {t(tr, "applications.marquee2")}</span>
        <span><i class="fas fa-gem"></i> {t(tr, "applications.marquee3")}</span>
        <span><i class="fas fa-microscope"></i> {t(tr, "applications.marquee4")}</span>
        <span><i class="fas fa-microchip"></i> {t(tr, "applications.marquee5")}</span>
        <span><i class="fas fa-coins"></i> {t(tr, "applications.marquee6")}</span>
        <span><i class="fas fa-stethoscope"></i> {t(tr, "applications.marquee7")}</span>
        <span><i class="fas fa-temperature-half"></i> {t(tr, "applications.marquee8")}</span>
      </div>
    </div>
  </section>

  <!-- ========== CHEMICAL SHOWCASE: CALUANIE ========== -->
  <section class="chem-showcase">
    <div class="container">
      <div class="chem-showcase-header">
        <div>
          <div class="section-label">{t(tr, "applications.showcase_label")}</div>
          <h2>{t(tr, "applications.showcase_title")}</h2>
        </div>
        <p class="chem-showcase-intro">{t(tr, "applications.showcase_intro")}</p>
      </div>
    </div>

    <!-- Caluanie Block -->
    <div class="chem-block">
      <div class="chem-block-image">
        <img src="/images/caluanie-muelear-oxidize-for-sale.jpg" alt={t(tr, "applications.cal_title")} />
        <div class="chem-block-label">01</div>
      </div>
      <div class="chem-block-content">
        <div class="chem-block-tag">{t(tr, "applications.cal_tag")}</div>
        <h3>{t(tr, "applications.cal_title")}</h3>
        <div class="chem-apps">
          <div class="chem-app-item">
            <div class="chem-app-num">01</div>
            <div class="chem-app-detail">
              <h5>{t(tr, "applications.cal_app1_title")}</h5>
              <p>{t(tr, "applications.cal_app1_desc")}</p>
            </div>
          </div>
          <div class="chem-app-item">
            <div class="chem-app-num">02</div>
            <div class="chem-app-detail">
              <h5>{t(tr, "applications.cal_app2_title")}</h5>
              <p>{t(tr, "applications.cal_app2_desc")}</p>
            </div>
          </div>
          <div class="chem-app-item">
            <div class="chem-app-num">03</div>
            <div class="chem-app-detail">
              <h5>{t(tr, "applications.cal_app3_title")}</h5>
              <p>{t(tr, "applications.cal_app3_desc")}</p>
            </div>
          </div>
        </div>
        <a href={lp("/products/caluanie")} class="btn btn-primary">{t(tr, "common.view_product")} <i class="fas fa-arrow-right"></i></a>
      </div>
    </div>

    <!-- Red Mercury Block -->
    <div class="chem-block chem-block--reverse">
      <div class="chem-block-image">
        <img src="/images/red-liquid-mercury-for-sale-usa.png" alt={t(tr, "applications.red_title")} />
        <div class="chem-block-label">02</div>
      </div>
      <div class="chem-block-content">
        <div class="chem-block-tag">{t(tr, "applications.red_tag")}</div>
        <h3>{t(tr, "applications.red_title")}</h3>
        <div class="chem-apps">
          <div class="chem-app-item">
            <div class="chem-app-num">01</div>
            <div class="chem-app-detail">
              <h5>{t(tr, "applications.red_app1_title")}</h5>
              <p>{t(tr, "applications.red_app1_desc")}</p>
            </div>
          </div>
          <div class="chem-app-item">
            <div class="chem-app-num">02</div>
            <div class="chem-app-detail">
              <h5>{t(tr, "applications.red_app2_title")}</h5>
              <p>{t(tr, "applications.red_app2_desc")}</p>
            </div>
          </div>
          <div class="chem-app-item">
            <div class="chem-app-num">03</div>
            <div class="chem-app-detail">
              <h5>{t(tr, "applications.red_app3_title")}</h5>
              <p>{t(tr, "applications.red_app3_desc")}</p>
            </div>
          </div>
        </div>
        <a href={lp("/products/red-mercury")} class="btn btn-primary">{t(tr, "common.view_product")} <i class="fas fa-arrow-right"></i></a>
      </div>
    </div>

    <!-- Silver Mercury Block -->
    <div class="chem-block">
      <div class="chem-block-image">
        <img src="/images/silver-liquid-mercury-for-sale.png" alt={t(tr, "applications.silver_title")} />
        <div class="chem-block-label">03</div>
      </div>
      <div class="chem-block-content">
        <div class="chem-block-tag">{t(tr, "applications.silver_tag")}</div>
        <h3>{t(tr, "applications.silver_title")}</h3>
        <div class="chem-apps">
          <div class="chem-app-item">
            <div class="chem-app-num">01</div>
            <div class="chem-app-detail">
              <h5>{t(tr, "applications.silver_app1_title")}</h5>
              <p>{t(tr, "applications.silver_app1_desc")}</p>
            </div>
          </div>
          <div class="chem-app-item">
            <div class="chem-app-num">02</div>
            <div class="chem-app-detail">
              <h5>{t(tr, "applications.silver_app2_title")}</h5>
              <p>{t(tr, "applications.silver_app2_desc")}</p>
            </div>
          </div>
          <div class="chem-app-item">
            <div class="chem-app-num">03</div>
            <div class="chem-app-detail">
              <h5>{t(tr, "applications.silver_app3_title")}</h5>
              <p>{t(tr, "applications.silver_app3_desc")}</p>
            </div>
          </div>
        </div>
        <a href={lp("/products/silver-mercury")} class="btn btn-primary">{t(tr, "common.view_product")} <i class="fas fa-arrow-right"></i></a>
      </div>
    </div>
  </section>

  <!-- ========== INDUSTRIES GRID (DARK) ========== -->
  <section class="app-industries">
    <div class="container">
      <div class="app-industries-header">
        <div class="section-label">{t(tr, "applications.industries_label")}</div>
        <h2>{t(tr, "applications.industries_title")}</h2>
      </div>
      <div class="app-industries-grid">
        <div class="app-ind-card">
          <div class="app-ind-icon"><i class="fas fa-gears"></i></div>
          <h5>{t(tr, "applications.ind1_title")}</h5>
          <p>{t(tr, "applications.ind1_desc")}</p>
        </div>
        <div class="app-ind-card">
          <div class="app-ind-icon"><i class="fas fa-flask"></i></div>
          <h5>{t(tr, "applications.ind2_title")}</h5>
          <p>{t(tr, "applications.ind2_desc")}</p>
        </div>
        <div class="app-ind-card">
          <div class="app-ind-icon"><i class="fas fa-gem"></i></div>
          <h5>{t(tr, "applications.ind3_title")}</h5>
          <p>{t(tr, "applications.ind3_desc")}</p>
        </div>
        <div class="app-ind-card">
          <div class="app-ind-icon"><i class="fas fa-microscope"></i></div>
          <h5>{t(tr, "applications.ind4_title")}</h5>
          <p>{t(tr, "applications.ind4_desc")}</p>
        </div>
        <div class="app-ind-card">
          <div class="app-ind-icon"><i class="fas fa-microchip"></i></div>
          <h5>{t(tr, "applications.ind5_title")}</h5>
          <p>{t(tr, "applications.ind5_desc")}</p>
        </div>
        <div class="app-ind-card">
          <div class="app-ind-icon"><i class="fas fa-coins"></i></div>
          <h5>{t(tr, "applications.ind6_title")}</h5>
          <p>{t(tr, "applications.ind6_desc")}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== ENHANCING INDUSTRIES SPLIT ========== -->
  <section class="app-split">
    <div class="app-split-image">
      <img src="/images/industrial-worker-holding-plastic-cans-with-chemicals-production-plant.jpg" alt={t(tr, "applications.split_title")} />
    </div>
    <div class="app-split-content">
      <div class="section-label">{t(tr, "applications.split_label")}</div>
      <h2>{t(tr, "applications.split_title")}</h2>
      <p>{t(tr, "applications.split_desc")}</p>
      <div class="app-split-features">
        <div class="app-split-feat">
          <div class="app-split-feat-icon"><i class="fas fa-shield-halved"></i></div>
          <div>
            <h6>{t(tr, "applications.split_feat2_title")}</h6>
            <p>{t(tr, "applications.split_feat2_desc")}</p>
          </div>
        </div>
        <div class="app-split-feat">
          <div class="app-split-feat-icon"><i class="fas fa-certificate"></i></div>
          <div>
            <h6>{t(tr, "applications.split_feat3_title")}</h6>
            <p>{t(tr, "applications.split_feat3_desc")}</p>
          </div>
        </div>
      </div>
      <a href={lp("/contact")} class="btn btn-primary">{t(tr, "common.contact_us")} <i class="fas fa-arrow-right"></i></a>
    </div>
  </section>

  <!-- ========== PRODUCT LINKS ========== -->
  <section class="app-products">
    <div class="container">
      <div class="app-products-header">
        <div>
          <div class="section-label">{t(tr, "applications.products_label")}</div>
          <h2>{t(tr, "applications.products_title")}</h2>
        </div>
        <a href={lp("/products")} class="btn btn-outline">{t(tr, "common.view_all_products")} <i class="fas fa-arrow-right"></i></a>
      </div>
      <div class="app-products-grid">
        <a href={lp("/products/caluanie")} class="app-prod-card">
          <div class="app-prod-img">
            <img src="/images/caluanie-muelear-oxidize-for-sale.jpg" alt={t(tr, "applications.cal_title")} />
            <div class="app-prod-num">01</div>
          </div>
          <div class="app-prod-body">
            <h3>{t(tr, "applications.cal_tag")}</h3>
            <p>{t(tr, "applications.prod1_desc")}</p>
            <span class="app-prod-link">{t(tr, "common.learn_more")} <i class="fas fa-arrow-right"></i></span>
          </div>
        </a>
        <a href={lp("/products/red-mercury")} class="app-prod-card">
          <div class="app-prod-img">
            <img src="/images/red-liquid-mercury-for-sale-usa.png" alt={t(tr, "applications.red_title")} />
            <div class="app-prod-num">02</div>
          </div>
          <div class="app-prod-body">
            <h3>{t(tr, "applications.red_tag")}</h3>
            <p>{t(tr, "applications.prod2_desc")}</p>
            <span class="app-prod-link">{t(tr, "common.learn_more")} <i class="fas fa-arrow-right"></i></span>
          </div>
        </a>
        <a href={lp("/products/silver-mercury")} class="app-prod-card">
          <div class="app-prod-img">
            <img src="/images/silver-liquid-mercury-for-sale.png" alt={t(tr, "applications.silver_title")} />
            <div class="app-prod-num">03</div>
          </div>
          <div class="app-prod-body">
            <h3>{t(tr, "applications.prod3_name")}</h3>
            <p>{t(tr, "applications.prod3_desc")}</p>
            <span class="app-prod-link">{t(tr, "common.learn_more")} <i class="fas fa-arrow-right"></i></span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ========== CTA ========== -->
  <section class="app-cta">
    <div class="container">
      <div class="app-cta-inner">
        <div class="app-cta-content">
          <h2>{t(tr, "applications.cta_title")}</h2>
          <p>{t(tr, "applications.cta_desc")}</p>
        </div>
        <div class="app-cta-actions">
          <a href={lp("/contact")} class="btn btn-white">{t(tr, "common.get_quote")} <i class="fas fa-arrow-right"></i></a>
          <a href={lp("/ordering")} class="btn btn-outline-white">{t(tr, "common.how_to_order")} <i class="fas fa-arrow-right"></i></a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ========================================
     APPLICATIONS PAGE STYLES
     ======================================== */

  /* Hero */
  .app-hero {
    position: relative;
    min-height: 85vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .app-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .app-hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .app-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(25,24,23,0.93) 0%, rgba(25,24,23,0.75) 50%, rgba(252,82,32,0.12) 100%);
  }
  .app-hero-inner {
    position: relative;
    z-index: 1;
    padding-top: 140px;
    padding-bottom: 100px;
  }
  .app-hero-content { max-width: 680px; }
  .app-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 20px;
    border: 1px solid rgba(255,255,255,0.2);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: rgba(255,255,255,0.8);
    margin-bottom: 24px;
  }
  .app-hero-badge i {
    color: var(--accent);
    font-size: 13px;
  }
  .app-hero h1 {
    color: var(--white);
    font-size: clamp(38px, 5.5vw, 72px);
    line-height: 1.05;
    margin-bottom: 24px;
    letter-spacing: -1px;
  }
  .app-hero-sub {
    color: rgba(255,255,255,0.65);
    font-size: 18px;
    line-height: 1.7;
    max-width: 540px;
    margin-bottom: 40px;
  }
  .app-hero-actions { display: flex; gap: 16px; flex-wrap: wrap; }
  .btn-outline-white {
    background: transparent;
    color: var(--white);
    border: 2px solid rgba(255,255,255,0.3);
  }
  .btn-outline-white:hover {
    background: var(--white);
    color: var(--near-black);
    border-color: var(--white);
  }

  /* Hero Stats */
  .app-hero-stats {
    display: flex;
    align-items: center;
    gap: 40px;
    margin-top: 80px;
    padding-top: 40px;
    border-top: 1px solid rgba(255,255,255,0.12);
  }
  .app-hero-stat-num {
    display: block;
    font-size: 28px;
    font-weight: 800;
    color: var(--white);
    letter-spacing: -0.5px;
  }
  .app-hero-stat-label {
    display: block;
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: 4px;
  }
  .app-hero-stat-divider {
    width: 1px;
    height: 50px;
    background: rgba(255,255,255,0.12);
  }

  /* Marquee */
  .app-marquee {
    background: var(--near-black);
    padding: 16px 0;
    overflow: hidden;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .app-marquee-track { overflow: hidden; }
  .app-marquee-items {
    display: flex;
    gap: 60px;
    animation: appMarquee 30s linear infinite;
    white-space: nowrap;
    width: max-content;
  }
  .app-marquee-items span {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: rgba(255,255,255,0.4);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }
  .app-marquee-items span i { color: var(--accent); font-size: 14px; }
  @keyframes appMarquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Chemical Showcase */
  .chem-showcase {
    padding-top: 120px;
    background: var(--white);
  }
  .chem-showcase-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 40px;
    margin-bottom: 80px;
    max-width: var(--max-width);
    margin-left: auto;
    margin-right: auto;
    padding: 0 24px 80px;
    border-bottom: 1px solid var(--border);
  }
  .chem-showcase-header h2 {
    font-size: clamp(28px, 3.5vw, 50px);
    line-height: 1.15;
  }
  .chem-showcase-intro {
    max-width: 380px;
    font-size: 16px;
    color: var(--body-text);
    text-align: right;
  }

  /* Chemical Block */
  .chem-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 600px;
  }
  .chem-block-image {
    position: relative;
    overflow: hidden;
  }
  .chem-block-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .chem-block:hover .chem-block-image img {
    transform: scale(1.04);
  }
  .chem-block-label {
    position: absolute;
    top: 30px;
    left: 30px;
    font-size: 60px;
    font-weight: 800;
    color: var(--white);
    line-height: 1;
    opacity: 0.15;
    letter-spacing: -2px;
  }
  .chem-block-content {
    padding: 70px 60px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--light-bg);
  }
  .chem-block--reverse { direction: rtl; }
  .chem-block--reverse > * { direction: ltr; }
  .chem-block--reverse .chem-block-content {
    background: var(--white);
  }
  .chem-block--reverse .chem-block-label {
    left: auto;
    right: 30px;
  }
  .chem-block-tag {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--accent);
    margin-bottom: 16px;
  }
  .chem-block-content h3 {
    font-size: clamp(22px, 2.5vw, 32px);
    line-height: 1.2;
    margin-bottom: 30px;
  }

  /* Application Items */
  .chem-apps {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 35px;
  }
  .chem-app-item {
    display: flex;
    gap: 20px;
    padding: 22px 0;
    border-bottom: 1px solid var(--border);
    align-items: flex-start;
  }
  .chem-app-item:first-child { padding-top: 0; }
  .chem-app-item:last-child { border-bottom: none; }
  .chem-app-num {
    font-size: 13px;
    font-weight: 800;
    color: var(--accent);
    letter-spacing: 1px;
    flex-shrink: 0;
    padding-top: 2px;
  }
  .chem-app-detail h5 {
    font-size: 16px;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .chem-app-detail p {
    font-size: 14px;
    color: var(--body-text);
    margin: 0;
    line-height: 1.6;
  }

  /* Industries Section */
  .app-industries {
    padding: 120px 0;
    background: var(--near-black);
  }
  .app-industries-header {
    text-align: center;
    margin-bottom: 60px;
  }
  .app-industries-header .section-label {
