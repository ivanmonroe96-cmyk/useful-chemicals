---
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = [
  {
    title: "How to Safely Handle and Store Mercury Products",
    excerpt: "A comprehensive guide to best practices for handling, storing, and transporting liquid mercury in industrial and laboratory settings.",
    date: "July 2025",
    category: "Safety",
    image: "/images/Buy-Silver-Liquid-Mercury.jpg",
    slug: "#"
  },
  {
    title: "Understanding Caluanie Muelear Oxidize: Applications & Benefits",
    excerpt: "Discover the industrial applications of Caluanie Muelear Oxidize, from metalworking and mineral extraction to chemical refining processes.",
    date: "July 2025",
    category: "Products",
    image: "/images/caluanie-muelear-oxidize-for-sale.jpg",
    slug: "#"
  },
  {
    title: "EU REACH Compliance for Chemical Imports: What You Need to Know",
    excerpt: "An overview of EU REACH regulations, mercury handling restrictions, and compliance requirements for chemical importers and distributors.",
    date: "July 2025",
    category: "Compliance",
    image: "/images/buy-new-stock-caluanie-muelear-oxidize.jpg",
    slug: "#"
  },
  {
    title: "Red Mercury: Properties, Uses, and Sourcing Guide",
    excerpt: "Learn about the unique properties of Red Liquid Mercury (Sb₂O₇Hg₂), its verified industrial applications, and how to source authentic product.",
    date: "July 2025",
    category: "Products",
    image: "/images/buy-red-liquid-mercury-usa.jpg",
    slug: "#"
  },
  {
    title: "International Shipping of Hazardous Chemicals: ADR, IMDG & IATA",
    excerpt: "Understanding the regulatory frameworks for transporting dangerous goods by road, sea, and air — and how to ensure full compliance.",
    date: "July 2025",
    category: "Logistics",
    image: "/images/red-liquid-mercury-for-sale-usa.png",
    slug: "#"
  },
  {
    title: "Gold Mining with Mercury: Methods, Safety, and Alternatives",
    excerpt: "An exploration of mercury amalgamation in gold extraction, safety protocols, environmental considerations, and modern alternatives.",
    date: "July 2025",
    category: "Industry",
    image: "/images/caluanie-muelear-oxidize-manufacturer-in-usa.webp",
    slug: "#"
  }
];
---

<BaseLayout title="Blog - Chemical Industry Insights" description="Read the latest insights on chemical products, safety guidelines, regulatory compliance, shipping logistics, and industry trends from UE Chemicals." activePage="">

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="section-label">Insights</div>
      <h1>Blog</h1>
      <p>Chemical industry insights, product guides, safety best practices, and regulatory updates.</p>
    </div>
  </section>

  <!-- Blog Grid -->
  <section class="blog-section">
    <div class="container">
      <div class="blog-grid">
        {posts.map((post) => (
          <article class="blog-card">
            <div class="blog-card-img">
              <img src={post.image} alt={post.title} />
              <span class="blog-card-cat">{post.category}</span>
            </div>
            <div class="blog-card-body">
              <span class="blog-card-date"><i class="fas fa-calendar"></i> {post.date}</span>
              <h3>{post.title}</h3>
              <p>{post.excerpt}</p>
              <span class="blog-card-link">Coming Soon <i class="fas fa-arrow-right"></i></span>
            </div>
          </article>
        ))}
      </div>

      <div class="blog-cta">
        <p>More articles coming soon. Subscribe to stay updated on chemical industry insights and product news.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container text-center">
      <h2>Have Questions About Our Products?</h2>
      <p>Our expert team is ready to assist with product information, safety guidance, and technical support.</p>
      <div class="cta-actions">
        <a href="/contact" class="btn btn-accent">Contact Us <i class="fas fa-arrow-right"></i></a>
        <a href="/faq" class="btn btn-outline">View FAQ <i class="fas fa-arrow-right"></i></a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .blog-section { padding: 80px 0; }
  .blog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; margin-bottom: 50px; }

  .blog-card { border-radius: 12px; overflow: hidden; background: var(--surface); border: 1px solid var(--border-light); transition: transform 0.3s, box-shadow 0.3s; }
  .blog-card:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(0,0,0,0.08); }

  .blog-card-img { position: relative; height: 200px; overflow: hidden; }
  .blog-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; }
  .blog-card:hover .blog-card-img img { transform: scale(1.05); }
  .blog-card-cat { position: absolute; top: 14px; left: 14px; background: var(--primary); color: #fff; padding: 4px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }

  .blog-card-body { padding: 24px; }
  .blog-card-date { font-size: 0.8rem; color: var(--body-text); display: flex; align-items: center; gap: 6px; margin-bottom: 10px; }
  .blog-card-date i { color: var(--primary); }
  .blog-card-body h3 { font-size: 1.15rem; line-height: 1.4; margin-bottom: 10px; }
  .blog-card-body p { color: var(--body-text); font-size: 0.9rem; line-height: 1.6; margin-bottom: 16px; }
  .blog-card-link { color: var(--primary); font-weight: 600; font-size: 0.9rem; display: inline-flex; align-items: center; gap: 6px; }

  .blog-cta { text-align: center; }
  .blog-cta p { color: var(--body-text); font-size: 1rem; }

  .cta-section { padding: 80px 0; background: var(--dark); }
  .cta-section h2 { color: #fff; margin-bottom: 16px; }
  .cta-section p { color: rgba(255,255,255,0.7); margin-bottom: 30px; }
  .cta-actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }

  @media (max-width: 1024px) { .blog-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) { .blog-grid { grid-template-columns: 1fr; } }
</style>
