---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTranslations } from '../i18n/index';
import { defaultLang } from '../i18n/languages';

const lang = defaultLang;
const tr = getTranslations(lang);
const impressum = tr.impressum;
const tocItems = [
  { id: 'company', label: impressum.toc_company },
  { id: 'contact', label: impressum.toc_contact },
  { id: 'represented', label: impressum.toc_represented },
  { id: 'responsible', label: impressum.toc_responsible },
  { id: 'dispute', label: impressum.toc_dispute },
  { id: 'liability-content', label: impressum.toc_liability_content },
  { id: 'liability-links', label: impressum.toc_liability_links },
  { id: 'copyright', label: impressum.toc_copyright },
  { id: 'regulatory', label: impressum.toc_regulatory },
];
const regulatoryItems = [
  { title: impressum.reg1_title, desc: impressum.reg1_desc },
  { title: impressum.reg2_title, desc: impressum.reg2_desc },
  { title: impressum.reg3_title, desc: impressum.reg3_desc },
  { title: impressum.reg4_title, desc: impressum.reg4_desc },
  { title: impressum.reg5_title, desc: impressum.reg5_desc },
  { title: impressum.reg6_title, desc: impressum.reg6_desc },
];
---

<BaseLayout lang={lang} title={impressum.meta_title} description={impressum.meta_desc} activePage="">

  <!-- ========== HERO ========== -->
  <section class="lg-hero">
    <div class="lg-hero-bg"></div>
    <div class="container lg-hero-inner">
      <div class="lg-hero-badge"><i class="fas fa-building-columns"></i> {impressum.hero_badge}</div>
      <h1>{impressum.title}</h1>
      <p class="lg-hero-sub">{impressum.hero_sub}</p>
      <div class="lg-hero-meta">
        <span><i class="fas fa-location-dot"></i> {impressum.location}</span>
        <span><i class="fas fa-scale-balanced"></i> {impressum.tmg}</span>
      </div>
    </div>
  </section>

  <!-- ========== CONTENT ========== -->
  <section class="lg-content">
    <div class="container">
      <div class="lg-grid">

        <!-- Sidebar -->
        <aside class="lg-sidebar">
          <div class="lg-toc">
            <h4>{impressum.sections}</h4>
            <nav>
              {tocItems.map((item) => <a href={`#${item.id}`}>{item.label}</a>)}
            </nav>
          </div>
        </aside>

        <!-- Main Content -->
        <div class="lg-main">

          <div class="lg-section" id="company">
            <div class="lg-section-num">01</div>
            <h3>{impressum.company_title}</h3>
            <div class="im-company-card">
              <div class="im-company-logo"><i class="fas fa-flask"></i></div>
              <div>
                <strong>{impressum.company_name}</strong>
                <p>{impressum.company_address}<br />{impressum.company_country}</p>
              </div>
            </div>
          </div>

          <div class="lg-section" id="contact">
            <div class="lg-section-num">02</div>
            <h3>{impressum.contact_title}</h3>
            <div class="im-contact-grid">
              <div class="im-contact-item">
                <i class="fas fa-envelope"></i>
                <div>
                  <span class="im-contact-label">{impressum.email_label}</span>
                  <a href="mailto:info@useful-chemicals.com">info@useful-chemicals.com</a>
                </div>
              </div>
              <div class="im-contact-item">
                <i class="fas fa-globe"></i>
                <div>
                  <span class="im-contact-label">{impressum.website_label}</span>
                  <a href="https://useful-chemicals.com">useful-chemicals.com</a>
                </div>
              </div>
            </div>
          </div>

          <div class="lg-section" id="represented">
            <div class="lg-section-num">03</div>
            <h3>{impressum.represented_title}</h3>
            <p>{impressum.represented_desc}</p>
          </div>

          <div class="lg-section" id="responsible">
            <div class="lg-section-num">04</div>
            <h3>{impressum.responsible_title}</h3>
            <p set:html={impressum.responsible_desc.replace(/\n/g, '<br />')}></p>
          </div>

          <div class="lg-section" id="dispute">
            <div class="lg-section-num">05</div>
            <h3>{impressum.dispute_title}</h3>
            <p>{impressum.dispute_desc1} <a href="https://ec.europa.eu/consumers/odr" target="_blank" rel="noopener noreferrer">https://ec.europa.eu/consumers/odr</a></p>
            <p>{impressum.dispute_desc2}</p>
          </div>

          <div class="lg-section" id="liability-content">
            <div class="lg-section-num">06</div>
            <h3>{impressum.liability_content_title}</h3>
            <p>{impressum.liability_content_desc1}</p>
            <p>{impressum.liability_content_desc2}</p>
          </div>

          <div class="lg-section" id="liability-links">
            <div class="lg-section-num">07</div>
            <h3>{impressum.liability_links_title}</h3>
            <p>{impressum.liability_links_desc1}</p>
            <p>{impressum.liability_links_desc2}</p>
          </div>

          <div class="lg-section" id="copyright">
            <div class="lg-section-num">08</div>
            <h3>{impressum.copyright_title}</h3>
            <p>{impressum.copyright_desc1}</p>
            <p>{impressum.copyright_desc2}</p>
          </div>

          <div class="lg-section" id="regulatory">
            <div class="lg-section-num">09</div>
            <h3>{impressum.regulatory_title}</h3>
            <p>{impressum.regulatory_intro}</p>
            <div class="im-reg-grid">
              {regulatoryItems.map((item) => (
                <div class="im-reg-item">
                  <strong>{item.title}</strong>
                  <span>{item.desc}</span>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ===== Hero ===== */
  .lg-hero { position: relative; padding: 130px 0 60px; overflow: hidden; }
  .lg-hero-bg { position: absolute; inset: 0; background: linear-gradient(135deg, #0a0f1e 0%, #1a1f2e 100%); }
  .lg-hero-inner { position: relative; z-index: 1; max-width: 700px; }
  .lg-hero-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); padding: 8px 18px; border-radius: 100px; font-size: .83rem; color: var(--accent); margin-bottom: 20px; font-weight: 600; }
  .lg-hero h1 { font-size: clamp(2rem, 4.5vw, 3rem); font-weight: 800; color: var(--white); margin-bottom: 14px; }
  .lg-hero-sub { color: rgba(255,255,255,.65); font-size: 1.05rem; line-height: 1.7; margin-bottom: 20px; }
  .lg-hero-meta { display: flex; gap: 24px; flex-wrap: wrap; }
  .lg-hero-meta span { display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,.45); font-size: .85rem; }
  .lg-hero-meta i { color: var(--accent); font-size: .8rem; }

  /* ===== Layout ===== */
  .lg-content { padding: 70px 0 90px; background: var(--white); }
  .lg-grid { display: grid; grid-template-columns: 250px 1fr; gap: 50px; }

  /* Sidebar */
  .lg-sidebar { position: sticky; top: 100px; align-self: start; }
  .lg-toc { background: var(--light-bg); border: 1px solid var(--border); border-radius: 14px; padding: 24px; }
  .lg-toc h4 { font-size: .85rem; text-transform: uppercase; letter-spacing: 1px; color: var(--dark); margin-bottom: 16px; }
  .lg-toc nav { display: flex; flex-direction: column; }
  .lg-toc nav a { display: block; padding: 8px 12px; font-size: .84rem; color: var(--body-text); text-decoration: none; border-radius: 6px; transition: var(--transition); border-left: 2px solid transparent; }
  .lg-toc nav a:hover { background: var(--white); color: var(--accent); border-left-color: var(--accent); }

  /* Sections */
  .lg-section { padding: 30px 0; border-bottom: 1px solid var(--border); position: relative; }
  .lg-section:last-child { border-bottom: none; }
  .lg-section-num { font-size: 2rem; font-weight: 800; color: rgba(252,82,32,.12); position: absolute; top: 26px; right: 0; }
  .lg-section h3 { font-size: 1.3rem; font-weight: 700; margin-bottom: 14px; color: var(--near-black); }
  .lg-section p { color: var(--body-text); line-height: 1.8; margin-bottom: 14px; }
  .lg-section a { color: var(--accent); text-decoration: underline; }

  /* Company card */
  .im-company-card { display: flex; align-items: center; gap: 20px; background: var(--light-bg); border: 1px solid var(--border); border-radius: 14px; padding: 24px 28px; }
  .im-company-logo { width: 56px; height: 56px; border-radius: 14px; background: var(--near-black); display: flex; align-items: center; justify-content: center; color: var(--accent); font-size: 1.4rem; flex-shrink: 0; }
  .im-company-card strong { display: block; font-size: 1.15rem; margin-bottom: 4px; color: var(--near-black); }
  .im-company-card p { margin: 0; font-size: .93rem; color: var(--body-text); line-height: 1.6; }

  /* Contact grid */
  .im-contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .im-contact-item { display: flex; align-items: center; gap: 14px; background: var(--light-bg); border: 1px solid var(--border); border-radius: 12px; padding: 18px 22px; }
  .im-contact-item i { font-size: 1.1rem; color: var(--accent); }
  .im-contact-label { display: block; font-size: .75rem; text-transform: uppercase; letter-spacing: .8px; color: var(--dark); opacity: .5; font-weight: 600; margin-bottom: 2px; }
  .im-contact-item a { color: var(--near-black); font-weight: 600; font-size: .93rem; text-decoration: none; }
  .im-contact-item a:hover { color: var(--accent); }

  /* Regulation grid */
  .im-reg-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 10px; }
  .im-reg-item { background: var(--light-bg); border: 1px solid var(--border); border-radius: 10px; padding: 18px 20px; }
  .im-reg-item strong { display: block; font-size: .95rem; margin-bottom: 4px; color: var(--near-black); }
  .im-reg-item span { font-size: .84rem; color: var(--body-text); line-height: 1.5; }

  /* Contact card */
  .lg-contact-card { background: var(--light-bg); border: 1px solid var(--border); border-radius: 12px; padding: 20px 24px; display: flex; flex-direction: column; gap: 10px; margin-top: 10px; }
  .lg-contact-card div { display: flex; align-items: center; gap: 10px; font-size: .93rem; }
  .lg-contact-card i { color: var(--accent); width: 18px; text-align: center; }

  /* Responsive */
  @media (max-width: 900px) {
    .lg-grid { grid-template-columns: 1fr; }
    .lg-sidebar { position: static; }
    .im-reg-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .lg-section-num { display: none; }
    .im-contact-grid { grid-template-columns: 1fr; }
  }
</style>
